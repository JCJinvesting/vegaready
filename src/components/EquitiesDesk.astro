  { k: gl('EMBI', 'EM credit (EMBI)') + ' spread', m: byNo['2.1'], n: 'sovereign risk premium', live: true },
  { k: gl('OVX', 'Oil vol (OVX)'), m: byNo['9.1'], n: 'energy-shock gauge', live: true },
  { k: gl('VXEEM', 'EM equity vol (VXEEM)'), m: byNo['9.3'], n: 'EM risk appetite', live: true },
  { k: 'Stock–bond correlation', m: byNo['9.2'], n: 'diversification regime', live: true },
  { k: 'USD/JPY carry', m: byNo['1.3'], n: 'carry-unwind tripwire', live: true },
  { k: 'Gold spot', m: byId['gold.spot'], n: 'real-asset / haven bid', live: true },
  { k: 'BTC-ETF flow', m: byId['crypto.btc_etf_flow'], n: 'downstream risk node', live: true },
  { k: '10Y Treasury yield', m: null, n: 'discount-rate anchor', live: false },
  { k: '2s10s curve', m: null, n: 'recession lead', live: false },
  { k: 'HY credit OAS', m: null, n: 'credit-stress lead', live: false },
  { k: 'Copper', m: null, n: 'global-growth pulse', live: false },
];

// ── illustrative hero charts (SVG; labeled feed-pending until D7 wires real series) ──
const charts = {
