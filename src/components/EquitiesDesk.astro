  .srcgrid{display:flex;flex-wrap:wrap;gap:7px}
  .srcpill{font-family:'Lora',serif;font-size:11px;color:var(--muted);border:1px solid var(--cardline);border-radius:6px;padding:5px 11px;background:var(--card)}
