<!-- §8 CROSS-ASSET (live registry tiles) -->
<section class="dsec" id="crossasset"><div class="wrap">
  <div class="sec-head"><div><div class="eyebrow">{T.crossasset.eye} · {T.crossasset.q}</div><h2>{T.crossasset.h}.</h2></div><span class="fresh-tag">{T.crossasset.fresh}</span></div>
  <p class="lead" set:html={T.crossasset.lead}></p>
  <div class="xa">{xa.map((x) => (
    <div class={`xa-tile ${x.live ? 'live' : 'pend'}`}>
      <div class="xa-k" set:html={x.k}></div>
      <div class={`xa-v ${x.live ? wvc(x.m) : ''}`} style={x.live ? '' : 'color:var(--latent);font-size:15px'}>{x.live ? fmt(x.m) : '—'}</div>
      <div class="xa-n">{x.live ? x.n : x.n + ' · feed pending'}</div>
    </div>
  ))}</div>
  <p class="tnote">Live tiles read from the watch registry (data through <b>{dataThrough}</b>); greyed tiles await the FRED rates/credit feed. <b>Caveat:</b> these correlations are regime-dependent — they converge toward 1.0 in stress, exactly when diversification is needed most.</p>
  <div class="track-grid">
    <div class="track"><div class="tk-h">What we track</div><ul>{T.crossasset.track.map(([x, m]) => (<li><span class={`mn mn-${m}`}>{m}</span><span set:html={x}></span></li>))}</ul></div>
    <div class="track-side"><div class="lvbox"><div class="lv-h">Leading-indicator value</div><div class="lv-v">{T.crossasset.lv[0]}</div><p>{T.crossasset.lv[1]}</p></div><div class="srcline"><b>Sources</b> <span class="dconf" style="border-color:var(--cardline)">{T.crossasset.tier}</span> {T.crossasset.src}</div></div>
  </div>
  <p class="tnote deep">{relatedSectors}</p>
</div></section>

<!-- §9 CATALYSTS & SCENARIOS -->
<section class="dsec" id="catalysts"><div class="wrap">
  <div class="sec-head"><div><div class="eyebrow">§9 · What changes the view, and when?</div><h2>Catalysts &amp; scenarios.</h2></div><span class="fresh-tag">3× daily</span></div>
  <p class="lead">Catalysts <b>annotate</b> the framework above — they don't rewrite it. Scenario tilts are <span class="vt">scenario</span> framework priors, never recommendations.</p>

  <div class="tk-h" style="margin:14px 0 6px">Forward catalyst calendar</div>
  <div style="overflow-x:auto"><table class="dtbl">
    <thead><tr><th>Event</th><th>Driver</th><th>Impact tier</th><th>Sections it touches</th><th>Date</th></tr></thead>
    <tbody>{calendar.map((c) => (<tr><td class="nm">{c.d}</td><td class="mono">{c.w}</td><td><span class={`dconf ${c.tier === 'High' ? 'high' : c.tier === 'Med' ? 'low' : 'medium'}`}>{c.tier}</span></td><td>{c.touches}</td><td class="mono" style="color:var(--latent)">feed pending</td></tr>))}</tbody>
  </table></div>
  <p class="tnote">Dates wire in with the calendar feed; events shown are the standing high-impact set the desk always tracks.</p>

  <div class="tk-h" style="margin:22px 0 6px">Scenario-conditional tilts</div>
  <div style="overflow-x:auto"><table class="dtbl">
    <thead><tr><th>Scenario</th><th>Trigger</th><th>Likely equity read</th><th>Sector / factor tilt (prior)</th></tr></thead>
    <tbody>{scenarios.map((s) => (<tr><td class="nm">{s.sc}</td><td class="mono">{s.tr}</td><td>{s.read}</td><td>{s.tilt}</td></tr>))}</tbody>
  </table></div>

  <div class="tk-h" style="margin:22px 0 6px">Active catalysts affecting equities</div>
  {activeCats.length === 0 && (<div class="emptycat">No active catalyst is materially moving equities right now — the durable framework above stands on its own.</div>)}
  <div class="catstack">
    {activeCats.map((c) => (
      <details class="catmod active" open>
        <summary><span class="cm-badge act">{STATE_LABEL[c.state]}</span><span class="cm-title">{c.overviewTitle}</span><span class="cm-chan">index bifurcation · sector rotation · GCC</span></summary>
        <div class="cm-body">
          <div class="eyebrow" style="margin:8px 0 6px">The bifurcation</div>
          <div style="overflow-x:auto"><table class="dtbl"><thead><tr><th>Index</th><th>Region</th><th>Peak decline <span class="vt">realized</span></th><th>Recovery</th><th>Conf</th></tr></thead>
            <tbody>{indexShock.map((r) => (<tr><td class="nm">{r.index}</td><td class="mono">{r.region}</td><td>{r.decline}</td><td class="mono">{r.recovery}</td><td><span class={`dconf ${confCls(r.conf)}`}>{r.conf}</span></td></tr>))}</tbody></table></div>
          <p class="tnote">{indexNote}</p>

          <div class="eyebrow" style="margin:20px 0 4px">Winners &amp; losers under this catalyst</div>
          <p class="tnote" style="margin:0 0 8px"><b>Definition:</b> winners/losers of <i>this catalyst's</i> repricing — vs the pre-catalyst baseline, sector-relative, over the repricing window, in the <b>currently realized scenario</b>. Sectors flip across scenarios — switch below.</p>
          <div style="overflow-x:auto"><table class="dtbl"><thead><tr><th>Sector</th><th>Status (realized)</th><th>Mechanism</th><th>ETF</th><th>Conf</th></tr></thead>
            <tbody>{sectorMap.map((r) => (<tr><td class="nm">{r.sector}</td><td><span class={wl(r.status)}>{r.status}</span></td><td>{r.mechanism}</td><td class="mono">{r.etf}</td><td><span class={`dconf ${confCls(r.conf)}`}>{r.conf}</span></td></tr>))}</tbody></table></div>
          <div class="scenchips" id="scenchips">{sectorScenario.map((s, i) => (<button class={`scenchip${i === 0 ? ' on' : ''}`} data-i={i}>{s.scenario}</button>))}</div>
          {sectorScenario.map((s, i) => (<div class={`scenpane${i === 0 ? ' on' : ''}`} data-i={i}><p class="tnote" style="margin:0">{s.impact}</p></div>))}
          <p class="tnote"><b>Precedent:</b> {sectorPrecedent}</p>

          <div class="eyebrow" style="margin:20px 0 6px">GCC repricing</div>
          <p class="tnote" style="margin:0 0 8px">{gcc.thesis}</p>
          <div class="bisplit"><div class="bi-b win"><div class="bi-h">Saudi — oil-revenue winner</div><p>{gcc.saudi}</p></div><div class="bi-b lose"><div class="bi-h">UAE — security loser</div><p>{gcc.uae}</p></div><div class="bi-b mix"><div class="bi-h">Qatar — LNG casualty</div><p>{gcc.qatar}</p></div></div>

          <div class="deep">
            <div class="eyebrow" style="margin:20px 0 6px">Factor rotation under this catalyst</div>
            <div style="overflow-x:auto"><table class="dtbl"><thead><tr><th>Factor</th><th>vs market</th><th>Mechanism</th><th>Conf</th></tr></thead><tbody>{factorRotation.map((r) => (<tr><td class="nm">{r.factor}</td><td>{r.perf}</td><td>{r.mechanism}</td><td><span class={`dconf ${confCls(r.conf)}`}>{r.conf}</span></td></tr>))}</tbody></table></div>
            <div class="takes">{factorObservations.map((t, i) => (<div class="take"><span class="tn">{i + 1}</span><p>{t}</p></div>))}</div>
            <details class="dcard" style="margin-top:16px"><summary><span class="dc-t">Country × scenario matrix</span><span class="dc-cat">expand</span></summary><div class="dc-body"><div style="overflow-x:auto"><table class="dtbl"><thead><tr><th>Country</th><th>{SCEN[0]}</th><th>{SCEN[1]}</th><th>{SCEN[2]}</th><th>{SCEN[3]}</th></tr></thead><tbody>{countryScenario.map((r) => (<tr><td class="nm">{r.country}</td><td>{r.hormuz}</td><td>{r.oil_strike}</td><td>{r.cable}</td><td class="win">{r.ceasefire}</td></tr>))}</tbody></table></div></div></details>
            <div class="dcallout" style="margin-top:14px"><div class="dc-h">Risk-parity / <span class="gloss" data-def={G['Vol-control']}>vol-control</span> deleveraging</div><p>{deleveraging}</p></div>
            <div class="dcallout data"><div class="dc-h">Crypto spillover → the terminal node</div><p>{cryptoSpillover}</p></div>
          </div>
        </div>
      </details>
    ))}
    {monCats.map((c) => (<details class="catmod"><summary><span class="cm-badge mon">{STATE_LABEL[c.state]}</span><span class="cm-title">{c.overviewTitle}</span><span class="cm-chan">{c.channels ? c.channels.slice(0, 2).join(' · ') : ''}</span></summary><div class="cm-body"><p class="tnote" style="margin:0">{c.summary}{c.watchingNote ? <span class="muted"> — {c.watchingNote}</span> : null}</p></div></details>))}
  </div>
  <p class="tnote deep"><b>Simultaneous catalysts:</b> when events cluster, we group them into one high-density window, name competing drivers + a residual when they conflict, and widen the affected sections' confidence rather than forcing one story. Charts anchor to multi-cycle history to fight recency bias.</p>
</div></section>

<!-- §10 EVIDENCE & METHODOLOGY -->
<section class="dsec" id="evidence"><div class="wrap">
  <div class="sec-head"><div><div class="eyebrow">§10 · Why should I believe this?</div><h2>Evidence &amp; methodology.</h2></div></div>
  <p class="lead">Two confidences, kept distinct: <b>data confidence</b> (are the numbers sound) and <b>attribution confidence</b> (did the driver cause the move). Observed facts render in neutral type; interpretation is labeled and carries its own attribution chip — interpretation never inherits the data's confidence.</p>
  <div class="legend-grid">
    <div class="legendbox"><div class="lg-h">Value types</div>{valueTypes.map(([k, d]) => (<div class="lg-row"><span class="vt">{k}</span><span>{d}</span></div>))}</div>
    <div class="legendbox"><div class="lg-h">Source tiers</div>{sourceTiers.map(([k, d, ex]) => (<div class="lg-row"><span class="dconf" style="border-color:var(--cardline)">{k}</span><span><b style="color:var(--ink)">{d}</b> — {ex}</span></div>))}</div>
  </div>
  <div class="deep">
    <details class="dcard"><summary><span class="dc-t">Numbers upgraded to HIGH confidence ({upgradedConfidence.length})</span><span class="dc-cat">expand</span></summary><div class="dc-body"><ol style="margin:0;padding-left:20px">{upgradedConfidence.map((x) => (<li style="font-size:12.5px;color:var(--muted);line-height:1.6;margin-bottom:6px">{x}</li>))}</ol></div></details>
    <details class="dcard"><summary><span class="dc-t">Could not verify / proxy only ({proxyOnly.length})</span><span class="dc-cat">expand</span></summary><div class="dc-body"><ol style="margin:0;padding-left:20px">{proxyOnly.map((x) => (<li style="font-size:12.5px;color:var(--muted);line-height:1.6;margin-bottom:6px">{x}</li>))}</ol></div></details>
    <div class="eyebrow" style="margin:18px 0 6px">Scenario trade expressions</div>
    <details class="atier"><summary><span class="at-lock">▣</span> Analyst desk · trade expressions <span class="at-tag">Analyst tier</span></summary><div class="at-body"><p class="at-bound">Scenario implications, not individualized advice. No price targets or buy/sell calls. Directional and instrument-level expressions are for the analyst audience only.</p>{scenarioTrades.map((s) => (<div class="tradeblock"><div class="tb-h" style="color:var(--eyeb)">{s.scenario} — {s.label}</div><p class="tb-r">{s.regime}</p><div style="overflow-x:auto"><table class="dtbl"><thead><tr><th>Dir.</th><th>Trade</th><th>Instrument</th><th>Rationale</th></tr></thead><tbody>{s.trades.map((t) => (<tr><td><span class={dirCls(t.direction)}>{t.direction}</span></td><td class="nm">{t.trade}</td><td class="mono">{t.instrument}</td><td>{t.rationale}</td></tr>))}</tbody></table></div></div>))}</div></details>
    <div class="eyebrow" style="margin:18px 0 6px">Detail files</div>
    {cards.map((c) => (<details class="dcard"><summary><div><div class="dc-t">{c.title}<span class="dc-cat">{c.category}</span></div><div class="dc-s">{c.summary}</div></div><span class={`dconf ${c.confidence}`}>{c.confidence}</span></summary><div class="dc-body"><div class="dc-mgrid">{c.metrics.map((mm) => (<div class="dc-m"><div class="dc-ml">{mm.label}</div><div class="dc-mv">{mm.value}</div></div>))}</div>{c.sources && c.sources.length > 0 && (<div class="dc-src">{c.sources.map((u, i) => (<a href={u.url} target="_blank" rel="noopener">[{i + 1}]</a>))}</div>)}</div></details>))}
    <div class="dcallout" style="margin-top:14px"><div class="dc-h">Data quality</div><p><b class="win">HIGH</b> — {dataQuality.high}</p><p style="margin-top:6px"><b class="mix">MODERATE</b> — {dataQuality.moderate}</p><p style="margin-top:6px"><b style="color:var(--latent)">Quarantined</b> — {dataQuality.quarantined}</p></div>
    <div class="tk-h" style="margin:18px 0 8px">Glossary</div>
    <div class="glosslist">{gloss.map(([t, d]) => (<div><b>{t}</b> — {d}</div>))}</div>
    <div class="tk-h" style="margin:18px 0 8px">Primary sources</div>
    <div class="srcgrid">{sources.map(([n, u]) => (<a class="srcpill" href={`https://${u}`} target="_blank" rel="noopener">{n} ↗</a>))}</div>
  </div>
  <p class="tnote">Research and analysis only — no investment recommendations, price targets, or personalized advice. Scenario tilts are conditional framework priors. NAAIM states its index is not predictive; the business-cycle framework is a historical tendency, not a guarantee.</p>
</div></section>
