  .chnav a.chA b{color:var(--chA)}.chnav a.chB b{color:var(--chB)}.chnav a.chC b{color:var(--chC)}.chnav a.chD b{color:var(--chD)}.chnav a.chE b{color:var(--chE)}.chnav a.chF b{color:var(--chF)}.chnav a.chG b{color:var(--chG)}
  .laydeck a.chA b{color:var(--chA)}.laydeck a.chB b{color:var(--chB)}.laydeck a.chC b{color:var(--chC)}.laydeck a.chD b{color:var(--chD)}.laydeck a.chE b{color:var(--chE)}.laydeck a.chF b{color:var(--chF)}.laydeck a.chG b{color:var(--chG)}
