  <div class="hookstack">{hooks.map((h, i) => (
    <div class="hook"><div class="hk-n">{i + 1}</div><div>
      <div class="hk-h">{h.n} <span class={`dconf ${h.c}`}>{h.c === 'high' ? 'well-established' : 'contested'}</span></div>
