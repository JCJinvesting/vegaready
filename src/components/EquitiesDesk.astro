  .regcell{display:block;background:color-mix(in srgb,var(--ink) 4%,transparent);border:1px solid var(--cardline);border-radius:8px;padding:9px 12px;text-decoration:none;transition:border-color .15s ease-out}
  .regcell:hover{border-color:var(--struct)}
  .rg-k{font-family:'Lora',serif;font-size:8.5px;letter-spacing:.05em;text-transform:uppercase;color:var(--muted);line-height:1.3;min-height:22px}
  .rg-v{font-family:'Fraunces',serif;font-size:17px;font-weight:600;color:var(--ink)}
  .rg-v.neg{color:var(--neg)}.rg-v.warn{color:var(--warn)}.rg-v.latent{color:var(--latent)}
  .regband{background:var(--sx-anchor);border-left:3px solid var(--eyeb);padding:8px 12px;font-size:12px;color:var(--body);line-height:1.6;border-radius:0 6px 6px 0}
  .regband b{color:var(--ink)}
  .rb-sep{margin:0 8px;color:var(--muted)}
  .rb-link{text-decoration:none}
  .rb-link:hover .dconf{border-color:var(--eyeb)}
  /* ── GCC bisplit: sentence bullets, normal weight (kills the bold wall) ── */
  .bi-pts{list-style:none;margin:0;padding:0;display:grid;gap:7px}
  .bi-pts li{position:relative;padding-left:15px;font-size:13.5px;line-height:1.55;color:var(--body);font-weight:400}
  .bi-pts li::before{content:"";position:absolute;left:1px;top:8px;width:5px;height:5px;border-radius:50%;background:var(--cardline)}
  .bi-b.win .bi-pts li::before{background:var(--pos)}
  .bi-b.lose .bi-pts li::before{background:var(--neg)}
  .bi-b.mix .bi-pts li::before{background:var(--warn)}
  /* ── scenario definitions (realized vs monitored) ── */
  .scdefs{display:grid;grid-template-columns:1fr 1fr;gap:11px;margin:4px 0 10px}
  .scdef{background:var(--card);border:1px solid var(--cardline);border-left:3px solid var(--latent);border-radius:11px;padding:13px 17px}
  .scdef.realized{border-left-color:var(--eyeb)}
  .scd-top{display:flex;align-items:center;justify-content:space-between;gap:10px;margin-bottom:7px;flex-wrap:wrap}
  .scd-h{font-family:'Fraunces',serif;font-size:14.5px;font-weight:600;color:var(--ink)}
  .scd-status{font-family:'Lora',serif;font-size:8.5px;font-weight:700;letter-spacing:.08em;text-transform:uppercase;border-radius:3px;padding:2px 7px;border:1px solid}
  .scd-status.realized{color:var(--eyeb);border-color:color-mix(in srgb,var(--eyeb) 45%,transparent);background:color-mix(in srgb,var(--eyeb) 10%,transparent)}
  .scd-status.monitored{color:var(--latent);border-color:var(--cardline)}
  .scdef p{font-size:13.5px;line-height:1.56;color:var(--body);margin:0}
  .scdef p b{color:var(--ink)}
  /* ── analyst density bump (Brand-Kit v1.1 ladder: content prose ≥13.5px) ── */
  .chan-card p{font-size:14.5px;line-height:1.6}
  .ch-tell{font-size:12px}
  .tx-row{font-size:13.5px;line-height:1.55}
  .trio-card p{font-size:13.5px;line-height:1.56}
  .tr-src{font-size:11.5px}
  .hook p{font-size:14px;line-height:1.58}
  .hook .keypts{margin:2px 0 9px}
  .fc-t{font-size:13.5px;line-height:1.58}
  .fc-row{font-size:12px}
  .falsify li{font-size:13px}
  .plainol li{font-size:13px}
  .track li{font-size:14px}
  .prof-r{font-size:13px}
  .lg-row{font-size:12.5px}
  .glosslist div{font-size:12px}
  .lvbox p{font-size:12.5px}
  .dcallout p{font-size:14px;line-height:1.58}
  @media(max-width:920px){.orient,.track-grid,.legend-grid,.snap,.glosslist,.taxgrid,.falsgrid{grid-template-columns:1fr}.triogrid,.doctrip{grid-template-columns:1fr}.snap-chart.wide,.snap-chart.clock{max-width:none}.oi-row{grid-template-columns:1fr;gap:4px}.prof-k{width:auto;display:block;margin-bottom:2px}.scalebar{grid-template-columns:1fr;gap:6px}}
  @media(max-width:760px){.lay-wl,.lay-gloss,.lay-ex,.lay-herogrid{grid-template-columns:1fr}.lay-h1{font-size:29px}.lay-scn-r{grid-template-columns:1fr;gap:5px}.lay-gauge{justify-self:start}}
  @media(max-width:560px){.snap .kpibar{grid-template-columns:1fr 1fr}.reggrid{grid-template-columns:1fr 1fr}}
</style>

<script is:inline>
  (async function(){var el=document.getElementById('liveAsOf');try{var r=await fetch('/data-status.json',{cache:'no-store'});if(!r.ok){if(el)el.textContent='live';return;}var s=await r.json();var w=s.dataDate||(s.metrics&&s.metrics.newest)||'';if(el)el.textContent=(s.state==='ok'?(w||'live')+(s.day?' · day '+s.day:''):'last good data');}catch(e){if(el)el.textContent='live';}})();
  (function(){
    function apply(mode){
      document.body.setAttribute('data-disc',mode);
      document.querySelectorAll('.disc button').forEach(function(x){x.classList.toggle('on',x.getAttribute('data-disc')===mode);});
      document.querySelectorAll('details.dcard').forEach(function(d){d.open=(mode==='deep');});
    }
    document.querySelectorAll('.disc button').forEach(function(b){b.addEventListener('click',function(){apply(b.getAttribute('data-disc'));});});
    var init=document.body.getAttribute('data-disc')||(document.body.getAttribute('data-mode')==='overview'?'skim':'deep');
    apply(init);
  })();
  (function(){var links=Array.prototype.slice.call(document.querySelectorAll('#secnav a'));var ids=links.map(function(a){return a.getAttribute('href').slice(1)});var io=new IntersectionObserver(function(es){es.forEach(function(e){if(e.isIntersecting){var i=ids.indexOf(e.target.id);if(i>=0){links.forEach(function(x){x.classList.remove('on')});links[i].classList.add('on');}}});},{rootMargin:'-45% 0px -50% 0px'});ids.forEach(function(id){var el=document.getElementById(id);if(el)io.observe(el);});})();
  (function(){['sectbl','cxstbl'].forEach(function(id){var tb=document.getElementById(id);if(!tb)return;var body=tb.querySelector('tbody');tb.querySelectorAll('th.sort').forEach(function(th){th.addEventListener('click',function(){var col=th.getAttribute('data-col');var asc=!th.classList.contains('asc');tb.querySelectorAll('th.sort').forEach(function(x){x.classList.remove('asc','desc')});th.classList.add(asc?'asc':'desc');var rows=Array.prototype.slice.call(body.querySelectorAll('tr'));rows.sort(function(a,b){var av=+a.getAttribute('data-'+col),bv=+b.getAttribute('data-'+col);return asc?av-bv:bv-av;});rows.forEach(function(r){body.appendChild(r)});});});});})();
  (function(){var chips=document.getElementById('scenchips');if(!chips)return;var panes=document.querySelectorAll('.scenpane');chips.addEventListener('click',function(ev){var b=ev.target.closest('.scenchip');if(!b)return;var i=b.getAttribute('data-i');chips.querySelectorAll('.scenchip').forEach(function(x){x.classList.remove('on')});b.classList.add('on');panes.forEach(function(p){p.classList.toggle('on',p.getAttribute('data-i')===i)});});})();
  (function(){
    function goDeep(){var btn=document.querySelector('.disc button[data-disc="deep"]');if(btn)btn.click();}
    document.querySelectorAll('[data-godeep]').forEach(function(b){b.addEventListener('click',goDeep);});
    document.querySelectorAll('.chnav a, .skdigest a, .laydeck a.lk').forEach(function(a){a.addEventListener('click',function(){if(document.body.getAttribute('data-disc')==='skim')goDeep();});});
    (function(){var raf=null;function upd(){document.body.classList.toggle('scrolled',window.scrollY>480);}window.addEventListener('scroll',function(){if(raf)return;raf=requestAnimationFrame(function(){raf=null;upd();});},{passive:true});upd();})();
  })();
</script>
