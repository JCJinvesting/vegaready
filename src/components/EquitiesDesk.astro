  .doc-h{font-family:'Lora',serif;font-size:10px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--eyeb);margin-bottom:7px}
  .doc-card p{font-size:13.5px;line-height:1.56;color:var(--body);margin:0}
  /* ── SKIM tier: the inverse primitive + skim-built content (Skim Completeness Law) ── */
  body[data-disc="deep"] .skim-only{display:none}
  .skbanner{display:flex;align-items:center;gap:12px;flex-wrap:wrap;background:color-mix(in srgb,var(--eyeb) 8%,var(--card));border:1px solid color-mix(in srgb,var(--eyeb) 30%,var(--cardline));border-radius:10px;padding:11px 16px;font-size:13.5px;line-height:1.55;color:var(--body);margin-bottom:16px}
