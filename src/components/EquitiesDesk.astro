  .skd-row.chA .skd-n{color:var(--chA)}.skd-row.chB .skd-n{color:var(--chB)}.skd-row.chC .skd-n{color:var(--chC)}.skd-row.chD .skd-n{color:var(--chD)}.skd-row.chE .skd-n{color:var(--chE)}.skd-row.chF .skd-n{color:var(--chF)}.skd-row.chG .skd-n{color:var(--chG)}
