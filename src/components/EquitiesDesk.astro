        <div class="dc-body">
          <div class="prof-sens">{p.sens}</div>
          <div class="prof-rows">
            <div class="prof-r"><span class="prof-k">KPIs</span>{p.kpis}</div>
            <div class="prof-r"><span class="prof-k">Leading indicators</span>{p.leads}</div>
            <div class="prof-r"><span class="prof-k">Classic risks</span>{p.risks}</div>
            <div class="prof-r"><span class="prof-k">Lead / lag</span>{p.ll}</div>
          </div>
        </div></details>
    ))}
    <p class="tnote">Sensitivity ratings are <b>framework priors for IA defaults, not forecasts</b>. Sector definitions per GICS (S&amp;P / MSCI); liquid proxies are the SPDR Select Sector ETFs.</p>
  </div>
</div></section>

