---
import '../styles/desk.css';
import '../styles/desk-content.css';
import '../styles/desk-v2.css';
import '../styles/skin-steel.css';
import { indexShock, indexNote, sectorMap, sectorScenario, sectorPrecedent, earningsSummary, passThrough, factorRotation, factorObservations, countryScenario, gcc, gccHedge, deleveraging, cryptoSpillover, scenarioTrades, cards, upgradedConfidence, proxyOnly, dataQuality, relatedSectors } from '../data/analysis/equities.js';
import { metrics, lastUpdated } from '../data/analysis/watchmetrics.js';
import { CATALYSTS, STATE_LABEL } from '../data/catalysts';
import Wayfinder from './Wayfinder.astro';

const { mode = 'analyst' } = Astro.props;

// Wayfinder (kit §4e): trail = where you are; rail = every lateral move from here.
const wfTrail = mode === 'layman'
  ? [{ label: 'Layman', href: '/layman' }, { label: 'Markets', href: '/markets' }, { label: 'Equities' }]
  : [{ label: 'Markets', href: '/markets' }, { label: 'Equities' }];
const wfRail = mode === 'layman'
  ? [
      { label: 'Equities', href: '/layman/markets/equities', current: true },
      { label: 'Credit', href: '/layman/markets/credit' },
      { label: 'All editions', href: '/layman' },
    ]
  : [
      { label: 'Equities', href: '/markets/equities', current: true },
      { label: 'Credit', href: '/markets/credit' },
      { label: 'Dollar & FX', href: '/markets/gold-fx' },
      { label: 'Commodities', href: '/markets/energy' },
      { label: 'Crypto', href: '/markets/crypto' },
      { label: 'Cross-asset', href: '/markets/cross-asset' },
    ];

const byNo = {}; const byId = {}; metrics.forEach(m => { if (m.signalNo) byNo[m.signalNo] = m; byId[m.id] = m; });
const fmt = (m) => (m ? `${m.value}${m.unit && m.unit !== 'count' ? ' ' + m.unit : ''}` : '—');
const wvc = (m) => (m && m.status === 'critical' ? 'neg' : m && m.status === 'alert' ? 'warn' : m && m.status === 'watch' ? 'latent' : '');
// hero instrument cluster — one cell per decision variable the framework consumes (all live registry, global)
const reg = [
  { k: 'The tape · % > 50-DMA', m: byNo['8.2'], sec: '#breadth' },
  { k: 'The crowd · factor unwind', m: byNo['8.1'], sec: '#factors' },
  { k: 'Tripwire · stock–bond corr', m: byNo['9.2'], sec: '#falsifiers' },
  { k: 'Global risk · EM vol (VXEEM)', m: byNo['9.3'], sec: '#crossasset' },
  { k: 'Smoke detector · EMBI', m: byNo['2.1'], sec: '#crossasset' },
  { k: 'Dollar · DXY', m: byNo['1.2'], sec: '#crossasset' },
];
// split generated prose into sentence-level bullets (content verbatim, structure added)
const sentSplit = (s) => (s || '').split(/(?<=[.;])\s+(?=[A-Z0-9“(+~−-])/).map((x) => x.trim()).filter(Boolean);
// country×scenario matrix: parse outcome status from generated text → colour class + sort rank
const cxsCls = (t) => { const u = (t || '').trim().toUpperCase(); if (u.startsWith('MIXED/WINNER')) return 'mix'; if (u.startsWith('WINNER')) return 'win'; if (u.startsWith('MIXED-LOSER') || u.startsWith('LOSER')) return 'lose'; if (u.startsWith('MIXED') || u.startsWith('NEUTRAL')) return 'mix'; return ''; };
const cxsRank = (t) => { const u = (t || '').trim().toUpperCase(); if (u.startsWith('WINNER')) return 4; if (u.startsWith('MIXED/WINNER')) return 3; if (u.startsWith('MIXED-LOSER')) return 1; if (u.startsWith('LOSER')) return 0; return 2; };
const wl = (s) => { const u = (s || '').toUpperCase(); return u.startsWith('WINNER') ? 'win' : u.startsWith('LOSER') ? 'lose' : 'mix'; };
const confCls = (c) => { const u = (c || '').toUpperCase(); return u.startsWith('HIGH') ? 'high' : u.startsWith('LOW') ? 'low' : 'medium'; };
const dirCls = (x) => (x === 'Long' ? 'win' : x === 'Short' ? 'lose' : 'mix');
const dataThrough = lastUpdated || 'recent';
const breadthPct = byNo['8.2'] ? `${byNo['8.2'].value}%` : '—';

// ── competing drivers (attribution buckets) ──
const drivers = [
  { d: 'AI / mega-cap capex cycle', b: 'primary', n: 'Insulates the index; widens the breadth gap' },
  { d: 'Rates & liquidity', b: 'material', n: 'Discount-rate pressure on long-duration growth' },
  { d: 'Earnings & revisions', b: 'material', n: 'Revision momentum leads price — with a documented lag' },
  { d: 'Positioning / crowding', b: 'material', n: 'Crowded books reprice first in any funding shock' },
  { d: 'Active catalyst (Iran–Gulf)', b: 'secondary', n: 'Overlay — see §Catalysts' },
  { d: 'Residual / unexplained', b: 'uncertain', n: 'Explicitly named; never assumed zero' },
];

// ── the 30-second read ──
const read30 = [
  '<b>Classify the channel before the direction.</b> A funding shock sells what is <i>owned</i>; an earnings shock sells what is <i>exposed</i>. The whole desk hangs on that split.',
  'The <b>index masks the damage</b>: mega-cap AI insulation up top, thinning breadth underneath — watch the average stock, not the average of the index.',
  '<b>Prices move first, forecasts follow.</b> Consensus EPS lags a real shock by weeks to a quarter — it confirms regimes, it never calls them.',
  '<b>Credit must agree.</b> A vol spike without HY spreads widening is a positioning event, not a fundamental one. Two barometers, one rule.',
  'A live <b>Iran–Gulf catalyst</b> is overlaid (§Catalysts) — an earnings-channel shock for energy and transports, a funding watch for everything else.',
];

// ── pre-committed falsifiers (full board in §12; one-liners here) ──
const falsifiers = [
  'HY spreads break and STAY above ~600–700bp for 20+ sessions — credit calls the shock fundamental.',
  'A crowded-factor dislocation keeps extending past a week with no Quant-Quake-style snap-back.',
  'Sector EPS cut >5% inside the first earnings season — including in cost-insulated sectors.',
  '%>200-DMA pinned under ~30% for 20+ sessions while the cap-weight index recovers without it.',
  'Stock–bond correlation flips positive and stays there — the dash-for-cash signature.',
];
// Plain-first falsifier board: pt = plain title (the headline), plain = the primary text,
// scale = reference anchors so numbers mean something, t/d/f = the analyst proof footer.
const falsifierBoard = [
  { pt: 'If junk-bond stress stays high for a month', n: 'Sustained HY OAS regime break',
    plain: 'Companies with shaky finances pay <b>extra</b> interest to borrow — today about 2.75 percentage points over the US government rate. A scary headline can spike that premium for a day or two and mean nothing. But if it jumps past <b>6–7 percentage points and stays there for about a month of trading days</b>, the bond market is declaring the damage real, not mechanical — and we abandon the “this will snap back” read.',
    scale: [['~275bp', 'today — calm', 'pos'], ['600–700bp', 'the trigger', 'warn'], ['~2,000bp', '2008 panic', 'neg']],
    t: 'HY OAS breaks and stays above ~600–700bp for 20+ consecutive sessions (vs the benign ~275bp mid-2026 regime). Spike-and-revert is mechanical; sustained is fundamental.', d: 'FRED BAMLH0A0HYM2 · daily', f: 'The “credit confirms benign fundamentals” clause', c: 'high' },
  { pt: 'If a crowded-trade crash doesn’t bounce within a week', n: 'No Quant-Quake reversal',
    plain: 'When selling is <b>forced</b> — funds hit margin calls and must dump positions — it exhausts itself fast: 2007’s “quant quake” rebounded within four days. So we give any crowded-trade crash about a week. If it <b>keeps falling past that window</b>, the seller isn’t a margin call anymore; it’s conviction. The “mechanical, will-bounce” story dies on schedule.',
    scale: [['Days 1–4', 'forced selling typical', 'warn'], ['~Day 5', 'snap-back due', 'pos'], ['Past a week', 'conviction — read falsified', 'neg']],
    t: 'Within ~5 sessions of a crowded-factor dislocation, the Aug-2007-style partial snap-back fails to appear; value/momentum or large/small keeps extending past a week.', d: 'Kenneth French dailies · IWM/SPY · RSP/SPY', f: 'The Unwind Hypothesis — the “mechanical, mean-reverting” read', c: 'high' },
  { pt: 'If profit forecasts get slashed fast and everywhere', n: 'Fast, broad, cost-insulated EPS cuts',
    plain: 'Analysts cut profit forecasts slowly and reluctantly — usually a quarter late. So speed itself is a signal: if forecasts get slashed by <b>more than 5% within a single earnings season</b>, and the cuts hit even companies with <b>no direct cost exposure</b> to the shock, then demand itself is breaking — not just margins being squeezed. That’s recession behaviour, not plumbing.',
    scale: [['Slow trims, exposed sectors', 'normal lag', 'pos'], ['>5% in one season', 'the trigger', 'warn'], ['Cuts in insulated sectors too', 'demand breaking', 'neg']],
    t: 'Consensus sector EPS revised down >5% within the first earnings season (~3 months), including sectors with no direct input-cost exposure — demand destruction, not margin compression.', d: 'Consensus EPS calendars · revision breadth', f: 'The “contained funding event” read', c: 'medium' },
  { pt: 'If the rally’s ground doesn’t heal underneath', n: 'Breadth fails to recover',
    plain: 'After a genuine plumbing shock, the rebound should be <b>broad</b> — most stocks recovering together. If fewer than about <b>3 in 10 stocks</b> sit above their own long-term trendline for a month while the headline index “recovers,” the recovery is a handful of giants carrying a sick market on their shoulders. The ground hasn’t healed; the durability read is falsified.',
    scale: [['~55%', 'today — narrow but standing', 'warn'], ['Below ~30% for a month', 'the trigger', 'neg'], ['~70%+', 'healthy broad rally', 'pos']],
    t: '%>200-DMA stays below ~30% for 20+ sessions while the cap-weight index recovers, or RSP/SPY breaks a 40-week low and holds it. Mean-reverting shocks broaden on the rebound.', d: 'Barchart $S5TH · StockCharts $SPXA200R · RSP/SPY', f: 'The durability / mean-reversion read', c: 'high' },
  { pt: 'If stocks and safe bonds keep falling together', n: 'Persistent positive stock–bond correlation',
    plain: 'Stocks and safe government bonds normally <b>seesaw</b> — when one falls, money hides in the other. The rare and serious exception is when both fall <b>together, day after day</b>: it means everyone is selling everything to raise cash, the March-2020 signature. A one-day flip means little. Holding positive for <b>about a month of trading days</b> means the system itself is under stress — the “contained event” read is dead.',
    scale: [['−0.3', 'normal seesaw', 'pos'], ['+0.3 briefly', 'uneasy — current zone', 'warn'], ['Positive ~a month', 'systemic — the trigger', 'neg']],
    t: 'SPX/UST return correlation flips positive and stays there ≥20 sessions — Treasuries and equities falling together is the FSB’s dash-for-cash signature crossing into systemic.', d: '20-day rolling corr · FRED/Yahoo dailies', f: 'The “contained, mean-reverting funding event” thesis', c: 'high' },
  { pt: 'If banks stop trusting each other', n: 'Interbank funding tripwire',
    plain: 'Banks lend to each other constantly — it’s the financial system’s bloodstream, and this spread is its <b>blood pressure</b>. It measures how much extra banks charge each other versus the risk-free rate. Calm readings sit near 0.1–0.2 percentage points. Past <b>~0.4 points (40bp)</b>, banks are pricing real distrust of each other — and every “markets are functioning smoothly” assumption on this page is void, instantly.',
    scale: [['~10–20bp', 'calm', 'pos'], ['~40bp', 'the trigger', 'warn'], ['100bp+', '2008-grade seizure', 'neg']],
    t: 'FRA-OIS / SOFR spread blows past ~40bp — money-market plumbing stress that bypasses every equity-side falsifier and goes straight to the funding system.', d: 'FRA-OIS / SOFR spread · daily', f: 'Any “smooth liquidity” regime, instantly', c: 'high' },
];

// ── the unit primer — defines every recurring unit ONCE, in plain words (deep tier, near top) ──
const unitPrimer = [
  ['Basis points (bp)', '1bp = one hundredth of a percentage point; 100bp = 1%. “Spreads widened 50bp” means risky borrowing got half a percentage point more expensive.'],
  ['Session', 'One trading day. 5 sessions ≈ a week; 20 sessions ≈ a month. “20+ sessions” means a condition persisted about a month — not a one-day scare.'],
  ['Spread / OAS', 'The extra interest a risky borrower pays over the US government rate. Junk-rated companies today: ~275bp (2.75%). Stress: 600–700bp. The 2008 panic: ~2,000bp.'],
  ['Moving average (DMA)', 'A stock’s average price over its last 50 or 200 trading days — its own trendline. “Above the 200-DMA” = above its long-term trend.'],
  ['Correlation', 'Runs −1 to +1. Negative: two things seesaw (normal for stocks vs safe bonds). Positive and holding: they fall together — the danger pattern.'],
  ['Percentile', 'Where today ranks against history. 90th percentile = higher than 90% of all past readings.'],
];

// ── hero cluster decoder (deep) ──
const heroDecode = [
  { k: 'The tape · 55%', p: 'Of the big US stocks, how many sit above their own 50-day trendline. A strong rally has most stocks marching; 55% means half the army is missing.', a: 'Under ~30% while the index sits at highs' },
  { k: 'The crowd · −1%/wk', p: 'How much the popular “style” trades lost this week. Sharp drops mean crowded funds are being squeezed out of the same doors at once.', a: 'Several negative weeks in a row' },
  { k: 'Tripwire · 0.3', p: 'Do stocks and safe bonds seesaw (normal) or fall together (danger)? Falling together means everyone is raising cash at once.', a: 'Positive and holding for ~a month' },
  { k: 'Global risk · 35.3', p: 'The price of insuring emerging-market stocks against swings — fear in the world’s riskier markets, where stress usually shows first.', a: 'Sustained climbs with no relief' },
  { k: 'Smoke detector · EMBI', p: 'What lenders charge developing-country governments above the US rate. Credit stress surfaces here before it reaches US stocks.', a: 'Fast widening without a policy response' },
  { k: 'Dollar · 100.5', p: 'The dollar’s strength against major currencies. A surging dollar tightens the screws on everyone worldwide who borrowed in dollars.', a: 'Rapid climbs — a global margin call' },
];

// ── plumbing decoder (deep) ──
const plumbDecode = [
  { k: 'Buybacks', p: 'Companies are often their own biggest customers, steadily buying their own shares. Before earnings they must step away from the register — the “blackout.” A steady daily buyer disappears for weeks.', proof: 'Earnings calendars + NASPP window norms · §8 table row 1' },
  { k: 'CTAs / vol-control', p: 'Autopilot funds that buy when markets are calm and trending, and sell when volatility jumps — all watching the same triggers. They don’t read news; they read the speedometer.', proof: 'CFTC TFF (weekly) + OFR monitor · §8 table row 2' },
  { k: '0DTE options', p: 'Bets on where the market closes today — same-day lottery tickets that now make up roughly half of all S&P option volume. Their hedging can amplify intraday swings.', proof: 'Cboe/OCC volume data · §8 table row 3' },
  { k: 'Dealer gamma', p: 'The firms selling those options must constantly buy and sell stock to stay balanced — sometimes leaning against the wind (calming), sometimes with it (amplifying). Which mode we’re in is an estimate, never a fact.', proof: 'Cboe open interest (inputs free; the “level” is a vendor model) · §8 table row 4' },
];

// ── timeline strips (deep) — dated facts already sourced on this page ──
const tlQQ = { h: 'August 2007 — anatomy of a quant quake', steps: [
  ['July 2007', 'The quiet bleed', 'Value strategies leak losses for weeks; nobody connects it to mortgages yet.', 'pre'],
  ['Aug 6–9', 'Forced selling', 'A margin call in mortgages forces stock sales; the most reliable strategies lose 5–30% in four days.', 'neg'],
  ['Aug 10', 'The snap-back', 'Forced selling exhausts; prices rebound within days. Whoever sold into the panic locked in the loss.', 'pos'],
]};
const tlDFC = { h: 'Feb–Mar 2020 — the two-phase panic', steps: [
  ['Late Feb', 'Flight to safety', 'Sell risky, buy safe — the ordinary scare. Treasuries rally as stocks fall.', 'warn'],
  ['Mid-March', 'Dash for cash', 'Even Treasuries get sold. $125bn flees prime money funds; the S&P drops 12% in a day; VIX hits 83.', 'neg'],
  ['Late March', 'The backstop', 'Central-bank liquidity opens. Only then does the spiral stop — valuation never got the chance.', 'pos'],
]};
const tlRev = { h: 'How long the truth takes — from shock to forecasts', steps: [
  ['Hours', 'Price reacts', 'Markets reprice the shock immediately — before anyone updates a spreadsheet.', 'neg'],
  ['1–6 weeks', 'Consensus stirs', 'Analysts begin trimming nearest-quarter numbers, gated by the calendar.', 'warn'],
  ['~3 months', 'Sectors confess', 'The first earnings season shows real damage (an oil shock: ~−1.9% aggregate profits).', 'warn'],
  ['After guidance', 'Annual resets', 'Full-year forecasts finally move — long after prices already did.', 'pre'],
]};
const tlBlk = { h: 'One quarter in the life of the buyback bid', steps: [
  ['Weeks 1–8', 'Window open', 'Companies repurchase their own shares — a steady daily buyer in the market.', 'pos'],
  ['~5 weeks out', 'Blackout begins', 'Discretionary buying pauses before earnings (pre-set 10b5-1 autopilot plans may continue).', 'warn'],
  ['Earnings day', 'The report', 'Results released; the quiet period peaks.', 'pre'],
  ['+48 hours', 'Window reopens', 'The corporate bid returns to the market.', 'pos'],
]};
const tlGulf = { h: 'The Iran–Gulf shock — what happened when', steps: [
  ['Mar 2', 'Freight panic peak', 'Tanker rates hit a record $736k/day-equivalent; war-risk insurance ~2.5% of hull value per week.', 'neg'],
  ['March', 'Hormuz closure window', 'Transit blocked or uninsurable. UAE output forced down toward ~1.9M bpd; Qatar declares force majeure at Ras Laffan.', 'neg'],
  ['Apr 9', 'Petroline strike', 'Drone strike cuts the Saudi east–west bypass by 700k bpd — the workaround itself gets hit.', 'warn'],
  ['By late Apr', 'Bypass restored', 'Petroline back to 7.0M bpd; Saudi exports ~3–4M bpd around Hormuz.', 'pos'],
  ['Today', 'Partial normalization', 'War-risk premia ~1% (from 2.5%); §scenarios above tracks the next branch.', 'pre'],
]};

// ════════ LAYMAN DEEP — Waves 2–7: every analyst-deep artifact, retold plainly with provenance ════════
// W2a · the market's weather gauges (regime)
const layRegime = [
  { k: 'The fear price (VIX)', p: 'What investors pay to insure against market swings over the next month. Cheap insurance = calm; expensive insurance = fear. It’s the closest thing markets have to a mood ring — priced in real money.', a: 'Calm ~12 · nervy 20+ · crisis 30+ · the 2020 record: 83' },
  { k: 'Distance from trend', p: 'How far the index sits above or below its own 200-day average price. Far above = stretched, like a runner sprinting ahead of their training pace. Far below = beaten down.', a: 'Watch when far above trend while fewer stocks participate' },
  { k: 'Felt vs paid volatility', p: 'Two numbers: how much the market has actually been swinging (realized), and how much swing the insurance market is pricing (implied). When insurance costs far more than recent reality, traders are braced for something.', a: 'A wide gap in either direction marks a regime change brewing' },
  { k: 'Today’s fear vs next month’s', p: 'Normally, insurance for further-out dates costs more than today’s (more time, more risk). When TODAY costs more than next month — “backwardation” — the market wants protection right now. That inversion is the stress signature.', a: 'Inversion = the panic is now, not hypothetical' },
];
// W2b · three thermometers for the rally (breadth, plain + trackable)
const layTrio = [
  { h: 'Count the soldiers', m: 'How many stocks are above their own long-term trend', p: 'A real advance has most of the army marching, not just the generals. When the index climbs while this count falls, the rally is hollowing out from underneath — historically the classic warning.', src: 'Free, daily: StockCharts $SPXA200R · Barchart $S5TH' },
  { h: 'Generals vs the army', m: 'The equal-weight index versus the famous one', p: 'The S&P you hear about gives giants more votes. Its equal-weight twin gives all 500 companies one vote each. When the famous index wins and the fair-vote one lags badly, a handful of giants are carrying everyone.', src: 'Free, daily: the RSP / SPY ratio on any charting site' },
  { h: 'Fresh peaks vs fresh wounds', m: 'Stocks hitting yearly highs minus those hitting yearly lows', p: 'Cuts through all the weighting math: is the typical stock having a good year or a bad one? An index at record highs while more stocks hit yearly LOWS than highs is the single most reliable free warning sign.', src: 'Free, daily: WSJ market data · StockCharts $NYHL' },
];
// W3a · the four flavours of money trouble (plain taxonomy)
const layFlavours = [
  { h: 'The margin-call stampede', ep: '2007', p: 'One big borrower is forced to sell, dragging down everyone who owns the same trades. Violent, fast — and it usually <b>snaps back within days</b> once the forced seller is done. The 2007 quant quake above is the textbook case.' },
  { h: 'The pawn-shop rush', ep: '1998', p: 'When a giant fails, everyone suddenly pays up for things that are <b>easy to sell</b> and dumps anything obscure. Small and hard-to-trade holdings fall hardest — not because they’re bad, but because they’re illiquid.' },
  { h: 'The everything-must-go cash run', ep: '2020', p: 'Pure panic: even the safest assets get sold, because people don’t want safety — they want <b>cash</b>. The rarest and most serious flavour. It ends when a central bank opens the liquidity taps, not when prices get “cheap enough.”' },
  { h: 'The burst pipe in one room', ep: '2022', p: 'A funding crisis that stays trapped in one corner — UK pension funds and their bond collateral in 2022 — while the wider stock market barely notices. The lesson: always ask <b>which room</b> the pipe burst in before evacuating the building.' },
];
// W3b · seven crises, one scoreboard (episode evidence, plain)
const layScore = [
  { y: '1998 · Russia/LTCM', what: 'A giant hedge fund failed; everyone rushed to easy-to-sell assets', fell: 'Small companies fell hardest (−7% worse than big ones)', note: 'Quality held up' },
  { y: '2008 · The financial crisis', what: 'Banks themselves were the problem; lending froze worldwide', fell: 'The market lost ~42%; small and value stocks suffered most', note: 'Strong-balance-sheet companies beat weak ones by 13 points — the cleanest quality win on record' },
  { y: '2011 · Euro debt scare', what: 'Markets feared European governments would default', fell: '−18%, small caps again worst', note: 'Defensives beat economy-sensitive stocks by 16 points' },
  { y: '2020 · COVID cash run', what: 'The everything-must-go panic — even safe bonds were sold', fell: '−34% in five weeks; cheap “value” stocks crushed (−18)', note: 'The shock: even quality LOST money — the one crisis where nothing defended' },
  { y: '2022 · UK pension scare', what: 'A burst pipe in one room — British bond collateral', fell: 'UK bonds, badly. Stock styles barely moved', note: 'Proof that a funding crisis can stay contained' },
  { y: '2023 · Bank deposit runs', what: 'Regional US banks lost deposits overnight', fell: 'Small and bank-heavy value stocks', note: 'Quality and necessities held — the system did not' },
];
// W4a · what are we paying for stocks? (valuation, plain + scale)
const layValue = [
  { k: 'The price of $1 of profit (P/E)', p: 'If a company earns $1 per share each year and the share costs $20, you’re paying 20× earnings. The higher the multiple, the more future you’re paying for in advance — and the less room for disappointment.', a: 'US large stocks have historically averaged ~16–17×; well above that means optimism is already in the price' },
  { k: 'The smoothed version (CAPE)', p: 'One great or terrible year can distort the picture, so this stretches profits over ten inflation-adjusted years. It’s useless for timing next month — but historically meaningful for what the NEXT DECADE of returns looks like from a given starting price.', a: 'Track it free: Professor Shiller’s data, Yale (updated monthly)' },
  { k: 'The danger pay (equity risk premium)', p: 'Stocks should pay more than safe government bonds — that extra is your compensation for the rollercoaster. Around <b>3.2% today</b>, it’s historically thin: you’re taking stock-market risk for not much more than bond-market reward. Thin pay doesn’t predict a crash; it means little cushion if one comes.', a: 'Thin ~3% · typical ~4–5% · generous 6%+ (free: Damodaran, NYU, monthly)' },
  { k: 'Where returns actually come from', p: 'Over any stretch, a stock market’s return ≈ profit growth + change in the mood multiple + cash paid out (dividends and buybacks). When profits stall, only mood and payouts are left — and mood is the part that vanishes fastest.', a: 'The analyst page’s “return bridge” chart is exactly this, drawn' },
];
// W4b · who confesses first (revision lags by industry, plain)
const layConfess = [
  { s: 'Oil producers', lag: 'Days to weeks', p: 'The shock IS their product’s price — analysts just read it off the screen.' },
  { s: 'Airlines & shippers', lag: '1–3 months', p: 'They sold tickets and contracts before fuel spiked and can’t reprice them — the squeeze shows up a quarter later.' },
  { s: 'Insurers', lag: 'Months, then years', p: 'Storm claims hit fast; long-tail claims (injuries, lawsuits) settle over years as the real costs surface.' },
  { s: 'Defense contractors', lag: 'Quarters to years', p: 'Their stocks jump on headlines, but revenue moves through multi-year government contracts — the slowest confession on the street.' },
  { s: 'Retailers & brands', lag: '3–6 months', p: 'Analysts wait to see whether shoppers absorb higher prices or walk away before cutting numbers.' },
];
// W5a · the eleven neighborhoods (sectors, plain + trackable)
const layHoods = [
  { s: 'Technology', t: 'XLK', p: 'The growth engine — software, chips, cloud. Loves falling interest rates (its profits live far in the future), suffers when rates rise.' },
  { s: 'Communications', t: 'XLC', p: 'Two families in one house: ad-driven internet giants (economy-sensitive) and boring telecoms (defensive).' },
  { s: 'Consumer discretionary', t: 'XLY', p: 'The wants, not the needs — cars, travel, fashion. First to feel it when households tighten belts.' },
  { s: 'Consumer staples', t: 'XLP', p: 'The needs — food, soap, toothpaste. People buy them in any economy, which is why this neighborhood shines in downturns.' },
  { s: 'Health care', t: 'XLV', p: 'Demand barely follows the economy — illness doesn’t check the business cycle. Policy headlines are its real weather.' },
  { s: 'Financials', t: 'XLF', p: 'Banks and insurers. Unusual: often HELPED by rising rates (wider lending margins) — but punished hard when borrowers start defaulting.' },
  { s: 'Industrials', t: 'XLI', p: 'Machines, freight, aerospace. The economy’s muscle — orders boom mid-cycle, roll over before recessions.' },
  { s: 'Materials', t: 'XLB', p: 'Chemicals, metals, mining. Rides global construction and China’s appetite; an inflation-era favourite.' },
