  /* ── decoder rows: header → full-width body → full-width meta footer. NOTHING wraps narrow. ── */
  .decoder{display:grid;gap:8px;margin:4px 0 10px}
  .dec-row{display:grid;grid-template-columns:1fr;row-gap:7px;background:var(--card);border:1px solid var(--cardline);border-radius:9px;padding:12px 16px;align-items:start}
