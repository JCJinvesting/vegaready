  .lay-ex{display:grid;grid-template-columns:1fr 1fr;gap:12px}
  .lay-exc{background:var(--card);border:1px solid var(--cardline);border-radius:12px;padding:15px 20px}
  .lay-exc h3{font-family:'Lora',serif;font-size:12px;font-weight:700;letter-spacing:.04em;text-transform:uppercase;color:var(--ink);margin:0 0 7px}
  .lay-exc p{font-size:15.5px;line-height:1.62;color:var(--body);margin:0}
  .lay-exc p b{color:var(--ink)}
  .lay-exc .exc-lead{color:var(--ink);font-weight:500;margin:0 0 11px}
  .lay-exc .exc-pts{list-style:none;margin:0;padding:0;display:grid;gap:7px}
