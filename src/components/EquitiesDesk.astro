  .lay-cards .lay-card:nth-child(2){border-left-color:var(--chC)}.lay-cards .lay-card:nth-child(2) .lc-n{color:var(--chC)}
  .lay-cards .lay-card:nth-child(3){border-left-color:var(--chB)}.lay-cards .lay-card:nth-child(3) .lc-n{color:var(--chB)}
  .lay-cards .lay-card:nth-child(4){border-left-color:var(--chF)}.lay-cards .lay-card:nth-child(4) .lc-n{color:var(--chF)}
  .lay-cards .lay-card:nth-child(5){border-left-color:var(--chG)}.lay-cards .lay-card:nth-child(5) .lc-n{color:var(--chG)}
  .lay-kpi{border-top:3px solid var(--cardline)}
