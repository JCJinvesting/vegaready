      </div>
    )}
    {id === 'earnings' && (<div class="deep" style="margin:4px 0 14px">{passThrough.map((c) => (<div class="kvrow"><div class="kv-k">{c.channel}</div><p>{c.detail}</p></div>))}</div>)}
    <div class="track-grid">
