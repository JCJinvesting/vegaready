  .lay-whatif .lay-scn-r:nth-child(1){border-left-color:var(--neg)}
  .lay-whatif .lay-scn-r:nth-child(2){border-left-color:var(--pos)}
  .lay-whatif .lay-scn-r:nth-child(3){border-left-color:var(--warn)}
  .lay-whatif .lay-scn-r:nth-child(4){border-left-color:var(--pos)}
  @media(max-width:760px){.sk60-grid{grid-template-columns:1fr}.sk-go{margin-left:0}.skd-row{grid-template-columns:38px 1fr}.skd-go{display:none}}
  /* ── layman chapter system: jump-nav + dividers (accents = sanctioned skin tokens chA–chG) ── */
  .chnav{display:flex;flex-wrap:wrap;gap:9px;align-items:center}
