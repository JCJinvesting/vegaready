  .remember li::before{content:"";position:absolute;left:2px;top:9px;width:9px;height:9px;border-radius:50%;background:var(--eyeb)}
  .remember b{color:var(--ink)}
  /* ── cross-tier polish: accent beats, header dashes, semantic tints ── */
  .lay-sech h2::before{content:"";display:inline-block;width:18px;height:3px;background:var(--eyeb);margin-right:11px;vertical-align:middle;border-radius:2px}
  .lay-card{border-left:3px solid var(--cardline)}
