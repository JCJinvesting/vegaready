  .ls-then{font-size:15.5px;line-height:1.62;color:var(--body)}
  .lay-pq{max-width:34ch;margin:34px auto 30px;text-align:center;font-family:'Playfair Display',Georgia,serif;font-style:italic;font-weight:500;font-size:22px;line-height:1.42;color:var(--ink);padding:4px 0}
