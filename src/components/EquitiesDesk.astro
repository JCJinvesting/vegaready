];

// ── durable sector sensitivity matrix (sortable summary) ──
const sectors = [
  { s: 'Energy', cyc: ['Cyclical', 4], rate: ['Low', 1, 'lo'], oil: ['High +', 5, 'hi'] },
  { s: 'Materials', cyc: ['Cyclical', 4], rate: ['Moderate', 2, 'mid'], oil: ['Input', 3, 'mid'] },
  { s: 'Industrials', cyc: ['Cyclical', 4], rate: ['Moderate', 2, 'mid'], oil: ['− input', 2, 'mid'] },
  { s: 'Cons. Discretionary', cyc: ['Most cyclical', 5], rate: ['− High', 4, 'hi'], oil: ['− input', 2, 'mid'] },
  { s: 'Financials', cyc: ['Cyclical', 4], rate: ['+ Benefit', 4, 'pos'], oil: ['Low', 1, 'lo'] },
  { s: 'Info. Technology', cyc: ['Growth', 3], rate: ['− Duration', 4, 'hi'], oil: ['Low', 1, 'lo'] },
  { s: 'Comm. Services', cyc: ['Mixed', 3], rate: ['− Duration', 3, 'mid'], oil: ['Low', 1, 'lo'] },
  { s: 'Cons. Staples', cyc: ['Defensive', 1], rate: ['− Mild', 2, 'mid'], oil: ['− input', 2, 'mid'] },
  { s: 'Health Care', cyc: ['Defensive', 1], rate: ['Low', 1, 'lo'], oil: ['Low', 1, 'lo'] },
  { s: 'Utilities', cyc: ['Defensive', 1], rate: ['−− High', 5, 'hi'], oil: ['Low', 1, 'lo'] },
  { s: 'Real Estate', cyc: ['Bond-proxy', 2], rate: ['−− High', 5, 'hi'], oil: ['Low', 1, 'lo'] },
];
const factors = [
  { f: 'Value', nat: 'cyclical', cls: 'cyc', d: 'Discount to fundamentals; leads in reflation/early-cycle' },
  { f: 'Growth', nat: 'long-duration', cls: 'cyc', d: 'Future earnings growth; rate-sensitive' },
  { f: 'Quality', nat: 'defensive', cls: 'def', d: 'Stable, high-quality earnings; mitigates downside' },
  { f: 'Momentum', nat: 'pro-cyclical', cls: 'cyc', d: 'Recent winners; crash-prone at turns' },
  { f: 'Low / Min-vol', nat: 'defensive', cls: 'def', d: 'Lower fluctuation; defensive ballast' },
  { f: 'Size', nat: 'cyclical', cls: 'cyc', d: 'Small-caps; leads when liquidity/cycle improve' },
];

// ── scenario table (Part D.2) ──
const scenarios = [
  { sc: 'Hawkish surprise', tr: 'Rates / real yields ↑', read: 'Long-duration & rate-sensitive pressured', tilt: 'Tech / Utilities / REITs (−); Financials (+ NIM/curve)' },
  { sc: 'Dovish surprise', tr: 'Rates ↓, easing', read: 'Risk-on, multiple expansion', tilt: 'Discretionary / Tech (+); defensives lag' },
  { sc: 'Growth re-accel', tr: 'PMIs / orders ↑', read: 'Cyclicals lead', tilt: 'Industrials / Materials / Financials (+)' },
  { sc: 'Growth scare', tr: 'PMIs / credit ↓', read: 'Defensive rotation', tilt: 'Staples / Health Care / Utilities (+)' },
];

// ── forward catalyst calendar (Part D.1 / Section 9) ──
const calendar = [
  { d: 'FOMC decision', w: 'rates', tier: 'High', touches: 'Regime · Valuation · Financials / Utilities / REITs' },
  { d: 'CPI release', w: 'inflation', tier: 'High', touches: 'Regime · rate-sensitive sectors' },
  { d: 'Jobs report', w: 'growth', tier: 'Med-High', touches: 'Cyclicals vs defensives' },
  { d: 'Earnings-season peak', w: 'fundamentals', tier: 'High', touches: 'Earnings · Sectors · Breadth' },
  { d: 'OPEC+ meeting', w: 'energy', tier: 'Med', touches: 'Energy · Cross-asset (oil)' },
];

// ── catalysts ──
const activeCats = CATALYSTS.filter(c => c.state === 'active');
const monCats = CATALYSTS.filter(c => c.state !== 'active');
const SCEN = ['Hormuz closure', 'Oil-infra strike', 'Cable severance', 'Ceasefire'];

const sources = [
  ['FRED', 'fred.stlouisfed.org/docs/api/fred/'], ['SEC EDGAR APIs', 'sec.gov/search-filings/edgar-application-programming-interfaces'],
  ['CBOE VIX', 'cboe.com/tradable-products/vix/'], ['CFTC COT', 'cftc.gov/MarketReports/CommitmentsofTraders/index.htm'],
  ['AAII Sentiment', 'aaii.com/sentimentsurvey'], ['NAAIM Exposure', 'naaim.org/programs/naaim-exposure-index/'],
  ['ICI flows', 'ici.org/research/stats/flows'], ['Kenneth French Data', 'mba.tuck.dartmouth.edu/pages/faculty/ken.french/data_library.html'],
  ['Damodaran ERP', 'pages.stern.nyu.edu/~adamodar/'], ['Shiller CAPE', 'econ.yale.edu/~shiller/data/ie_data.xls'],
  ['S&P / MSCI GICS', 'spglobal.com/spdji/en/landing/topic/gics/'], ['State Street SPDR', 'ssga.com'],
];

const read30 = [
  'The <b>index masks the damage</b>: the S&amp;P fell ~8% to a 6,316 trough, then made new highs on mega-cap AI insulation — breadth is the tell.',
  'Leadership is <b>narrow and defensive-tilted</b>; value, defensives and energy led while crowded long-duration growth unwound.',
  'Valuation is rich and the <b>equity risk premium thin</b> (≈3.2% Q1’26) — muted long-run return absent further multiple expansion.',
  '<b>Revisions</b> are the engine to watch — they lead price more reliably than levels.',
  'A live <b>Iran–Gulf catalyst</b> is overlaid (see §Catalysts), one driver among rates, AI-capex and positioning.',
];

const topicOrder = ['regime', 'breadth', 'valuation', 'earnings'];

// ── plain-language winners/losers (Overview mode) ──
const plain = (s) => (s || '').replace(/\s*\(.*?\)\s*/g, '').trim();
const ovWin = sectorMap.filter(r => (r.status || '').toUpperCase().startsWith('WINNER')).slice(0, 3).map(r => plain(r.sector));
const ovLose = sectorMap.filter(r => (r.status || '').toUpperCase().startsWith('LOSER')).slice(0, 3).map(r => plain(r.sector));
const ovWinTxt = ovWin.length ? ovWin.join(', ') : 'energy and defense';
const ovLoseTxt = ovLose.length ? ovLose.join(', ') : 'importers and rate-sensitive sectors';
