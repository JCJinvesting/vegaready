---
import '../styles/desk.css';
import '../styles/desk-content.css';
import '../styles/desk-v2.css';
import { indexShock, indexNote, sectorMap, sectorScenario, sectorPrecedent, earningsSummary, passThrough, factorRotation, factorObservations, countryScenario, gcc, gccHedge, deleveraging, cryptoSpillover, scenarioTrades, cards, upgradedConfidence, proxyOnly, dataQuality, relatedSectors } from '../data/analysis/equities.js';
import { metrics, lastUpdated } from '../data/analysis/watchmetrics.js';
import { CATALYSTS, STATE_LABEL } from '../data/catalysts';

const { mode = 'analyst' } = Astro.props;

const byNo = {}; const byId = {}; metrics.forEach(m => { if (m.signalNo) byNo[m.signalNo] = m; byId[m.id] = m; });
const fmt = (m) => (m ? `${m.value}${m.unit && m.unit !== 'count' ? ' ' + m.unit : ''}` : '—');
const wvc = (m) => (m && m.status === 'critical' ? 'neg' : m && m.status === 'alert' ? 'warn' : m && m.status === 'watch' ? 'latent' : '');
const eq = [{ k: 'Factor unwind', m: byNo['8.1'] }, { k: 'Index dispersion', m: byNo['8.2'] }, { k: 'GCC asymmetry', m: byNo['8.3'] }];
const wl = (s) => { const u = (s || '').toUpperCase(); return u.startsWith('WINNER') ? 'win' : u.startsWith('LOSER') ? 'lose' : 'mix'; };
const confCls = (c) => { const u = (c || '').toUpperCase(); return u.startsWith('HIGH') ? 'high' : u.startsWith('LOW') ? 'low' : 'medium'; };
const dirCls = (x) => (x === 'Long' ? 'win' : x === 'Short' ? 'lose' : 'mix');
const dataThrough = lastUpdated || 'recent';
const breadthPct = byNo['8.2'] ? `${byNo['8.2'].value}%` : '—';

// ── competing drivers (attribution buckets) ──
const drivers = [
  { d: 'AI / mega-cap capex cycle', b: 'primary', n: 'Insulates the index; widens the breadth gap' },
  { d: 'Rates & liquidity', b: 'material', n: 'Discount-rate pressure on long-duration growth' },
  { d: 'Earnings & revisions', b: 'material', n: 'Revision momentum leads price' },
  { d: 'Positioning / crowding', b: 'secondary', n: 'Crowded-factor unwind risk' },
  { d: 'Active catalyst (Iran–Gulf)', b: 'secondary', n: 'Overlay — see §Catalysts' },
  { d: 'Residual / unexplained', b: 'uncertain', n: 'Explicitly named; never assumed zero' },
];

// ── what would change the call (falsifiability) ──
const falsifiers = [
  'Breadth broadens — % above the 200-DMA reclaims ~60%+ and the advance/decline line confirms new index highs.',
  'The equity risk premium re-rates higher (earnings yield rises vs real yields), restoring a real return cushion.',
  'Revision breadth rolls over — net downgrades begin to lead price lower.',
  'The Iran–Gulf catalyst escalates onto a Hormuz-closure path, repricing energy higher and importers lower.',
];

// ── value types & source tiers (Part E) ──
const valueTypes = [
  ['Baseline', 'long-run norm / historical reference'], ['Current', 'latest observed print'],
  ['Nowcast', 'model estimate of the present from incomplete data'], ['Forecast', 'forward model / consensus estimate'],
  ['Scenario', 'conditional “if-then” path'],
];
const sourceTiers = [
  ['T1', 'Primary / official', 'SEC EDGAR · CFTC · CBOE · FRED · S&P/MSCI GICS'],
  ['T2', 'Reputable institutional', 'State Street SPDR · ICI · AAII · NAAIM · FT'],
  ['T3', 'Academic / research', 'Kenneth French · Damodaran · Shiller'],
  ['T4', 'Estimated / in-house', 'breadth composites · sentiment z-scores · regime label'],
];

// ── glossary (tooltips + page-level list) ──
const gloss = [
  ['ERP', 'Equity Risk Premium — equities’ excess return over the real risk-free yield; here earnings yield minus real yield.'],
  ['CAPE', 'Cyclically-Adjusted P/E — price ÷ the 10-year average of inflation-adjusted earnings; smooths the cycle.'],
  ['Breadth', 'How many stocks participate in a move — broad vs mega-cap-narrow.'],
  ['Dispersion', 'How widely individual stock or sector returns scatter around the index.'],
  ['Factor unwind', 'A crowded style factor (e.g. momentum) reversing as positioning is cut.'],
  ['2s10s', 'The 10-year minus 2-year Treasury yield; negative = inverted curve, a classic recession lead.'],
  ['OAS', 'Option-Adjusted Spread — a bond’s yield premium over Treasuries; wider = more credit stress.'],
  ['NTM', 'Next-Twelve-Months — forward-looking consensus estimates for the coming year.'],
  ['NIM', 'Net Interest Margin — a bank’s lending spread; steeper curves tend to help it.'],
  ['FFO', 'Funds From Operations — a REIT’s core cash-earnings metric.'],
  ['OVX', 'CBOE Crude Oil Volatility Index — the “oil VIX”; option-implied crude volatility.'],
  ['VXEEM', 'CBOE Emerging-Markets ETF Volatility Index — EM equity implied volatility.'],
  ['EMBI', 'Emerging Markets Bond Index spread — EM sovereign risk premium over Treasuries.'],
  ['McClellan', 'A breadth oscillator built from the difference between advancing and declining issues.'],
  ['Vol-control', 'Risk-parity / vol-control strategies cut exposure mechanically when volatility rises.'],
  ['Beta', 'Sensitivity of an asset’s move to the broad market.'],
];
const G = {}; gloss.forEach(([t, d]) => { G[t] = d; });
const gl = (term, label) => `<span class="gloss" data-def="${G[term]}">${label || term}</span>`;

// ── topic specs (Part B) — now with glance KPIs + a hero chart per section ──
const T = {
  regime: { eye: '§1', h: 'Market Regime', q: 'What environment are we in?', fresh: 'daily', chart: 'regime',
    lead: `The lens for everything below: trend, volatility and the macro backdrop set the prior for how to read every other module. We treat the regime label as a <b>prior, not a forecast</b>.`,
    kpi: [['VIX (implied vol)', '—', 'feed pending', null], ['% from 200-DMA', '—', 'feed pending', null], ['Realized vs implied (20d)', '—', 'feed pending', null], ['Vol term structure', '—', 'feed pending', null]],
    track: [['Index vs 50/200-day MA', 'M'], ['VIX level + ' + gl('Vol-control', 'vol term structure'), 'M'], ['Realized vs implied vol (20d)', 'M'], ['Macro nowcast backdrop', 'N'], ['Regime-switching model', 'N']],
    lv: ['Medium-high', 'VIX and vol-term-structure inversion often precede drawdowns; trend breaks are coincident-to-lagging.'],
    src: 'CBOE VIX (daily/intraday) · FRED macro series · index MAs', tier: 'T1',
    feed: [['VIX + term structure', 'CBOE — wire in'], ['% from 200-DMA', 'index feed — wire in']] },
  breadth: { eye: '§2', h: 'Breadth', q: 'Is the move real or narrow?', fresh: 'daily', chart: 'breadth',
    lead: `The fastest way to detect a fragile tape: deteriorating ${gl('Breadth', 'breadth')} under a rising index is a classic pre-correction divergence.`,
    kpi: [['% > 50-DMA', breadthPct, 'current', 'medium'], ['% > 200-DMA', '—', 'feed pending', null], ['Advance / decline', '—', 'feed pending', null], ['EW vs CW (RSP/SPY)', '—', 'feed pending', null]],
    track: [['% of constituents > 200-DMA', 'M'], ['Advance / decline line', 'M'], ['Equal-weight vs cap-weight (RSP/SPY)', 'M'], ['New highs − new lows', 'N'], [gl('McClellan', 'McClellan oscillator'), 'N']],
    lv: ['High', 'Narrowing leadership warns of corrections; broadening thrusts confirm uptrends.'],
    src: 'Constituent prices (T1 feed) · S&P EW vs CW methodology · in-house composites', tier: 'T1/T4',
    feed: [['% > 200-DMA', 'index feed'], ['A/D line', 'computed in-house'], ['EW/CW ratio', 'ETF feed']] },
  valuation: { eye: '§3', h: 'Valuation & Return Engine', q: 'What are we paying, and what return is embedded?', fresh: 'monthly · daily ERP', chart: 'valuation',
    lead: `Decomposes return into <b>earnings growth + multiple change + dividend/buyback yield</b>. ${gl('CAPE')} and ${gl('ERP')} are weak short-horizon timing tools but meaningful 7–10yr signals — labeled <i>baseline/context</i>, never nowcasts.`,
    kpi: [['Forward P/E', '—', 'feed pending', null], ['Shiller CAPE', '—', 'feed pending', null], ['Equity risk premium', '≈3.2%', 'baseline', 'medium'], ['Div + buyback yield', '—', 'feed pending', null]],
    track: [['Trailing & forward P/E vs history', 'M'], [gl('CAPE', 'Shiller CAPE'), 'M'], [gl('ERP', 'Equity risk premium') + ' (earnings yield − real yield)', 'M'], ['Return bridge: ΔPrice ≈ ΔEPS + ΔMultiple + Yield', 'M'], ['Regression-implied fair value', 'N']],
    lv: ['Low for timing, high for 7–10yr return', 'CAPE/ERP have weak short-horizon power but meaningful long-horizon signal.'],
    src: 'Shiller CAPE (monthly) · Damodaran implied ERP (monthly) · FRED real yields (daily) · forward multiples (T2)', tier: 'T3',
    feed: [['Forward P/E', 'estimate feed'], ['Shiller CAPE', 'Shiller ie_data (monthly)'], ['Implied ERP', '≈3.2% (Q1’26 ref) — Damodaran / earnings-yield − 10Y']] },
  earnings: { eye: '§4', h: 'Earnings & Revisions', q: 'Is the fundamental engine accelerating or stalling?', fresh: 'continuous · season', chart: 'earnings',
    lead: `Revision <b>momentum</b> is among the most reliable short-to-medium equity signals — it leads price more consistently than valuation levels. Reported (GAAP) and estimate (pro-forma) are kept separate.`,
    kpi: [['Fwd EPS growth', '—', 'feed pending', null], ['Revision breadth', '—', 'feed pending', null], ['Beat rate', '—', 'feed pending', null], ['Net margin trend', '—', 'feed pending', null]],
    track: [[gl('NTM', 'NTM/forward EPS growth') + ' (consensus)', 'M'], ['Revision breadth (up vs down)', 'M'], ['EPS surprise % / beat rate', 'M'], ['Revision diffusion by sector', 'N'], ['Margin decomposition', 'N']],
    lv: ['High', 'Revision momentum leads price more consistently than valuation.'],
    src: 'Estimate vendor (T2) · SEC EDGAR XBRL company-facts for filed actuals (T1, real-time)', tier: 'T1/T2',
    feed: [['Fwd EPS growth', 'estimate feed'], ['Revision breadth (4-wk)', 'estimate feed'], ['Beat rate', 'EDGAR + estimates']] },
  positioning: { eye: '§7', h: 'Positioning & Sentiment', q: 'Is the trade crowded?', fresh: 'weekly', chart: 'gauge',
    lead: `How much is already priced. Extremes are most informative; sentiment is a <b>conditioning variable, not a trigger</b> — NAAIM itself states its index is not predictive.`,
    kpi: [['AAII bull−bear', '—', 'feed pending', null], ['NAAIM exposure', '—', 'feed pending', null], ['CFTC net (non-comm.)', '—', 'feed pending', null], ['Fund flows', '—', 'feed pending', null]],
    track: [['AAII bull/bear', 'M'], ['NAAIM Exposure Index', 'M'], ['CFTC COT equity-index net positioning', 'M'], ['ICI fund flows / ETF net issuance', 'M'], ['Put/call ratios', 'N'], ['Positioning composite z-score', 'N']],
    lv: ['Medium, contrarian', 'Extremes mark turns; treat as conditioning, not a trigger.'],
    src: 'AAII (Thu, weekly) · NAAIM (Wed→Thu) · CFTC COT (Tue data, Fri 3:30pm ET) · ICI flows (weekly est. + monthly)', tier: 'T1/T2',
    feed: [['AAII bull−bear', 'AAII (public)'], ['NAAIM exposure', 'NAAIM (public)'], ['COT net non-comm.', 'CFTC (3-day lag)'], ['Weekly flows', 'ICI (estimate)']] },
  crossasset: { eye: '§8', h: 'Cross-Asset Linkages', q: 'What is the rest of the world saying about equities?', fresh: 'daily',
    lead: `Rates, credit, FX, commodities and vol often lead equities. <b>Caveat:</b> correlations are regime-dependent and spike toward 1.0 in stress — exactly when diversification fails.`,
    track: [['10y yield & ' + gl('2s10s', '2s10s curve'), 'M'], ['Credit spreads (IG/HY ' + gl('OAS') + ')', 'M'], ['USD (DXY)', 'M'], ['Oil / copper', 'M'], ['Gold · MOVE/VIX ratio', 'N'], ['Equity-bond correlation regime', 'N']],
    lv: ['Medium-high', 'Credit spreads and the yield curve are well-established macro leads; rising HY OAS / curve inversion often precede equity stress.'],
    src: 'FRED (yields, curves, OAS, USD, commodities — daily) · CBOE (vol) · live registry tiles below', tier: 'T1' },
};

// ── live cross-asset tiles (real registry data + honest feed-pending) ──
const xa = [
