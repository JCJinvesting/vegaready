  /* ── analyst key-points lists (lead + bullets pattern — Typography spec §lead/bullets) ── */
  .keypts{list-style:none;margin:0;padding:0;display:grid;gap:7px}
  .keypts li{position:relative;padding-left:17px;font-size:14px;line-height:1.58;color:var(--body)}
