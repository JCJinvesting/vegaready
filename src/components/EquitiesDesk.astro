  breadth: `<svg viewBox="0 0 320 120" role="img" aria-label="Illustrative: the index rises while breadth declines — a divergence"><polyline points="0,82 80,72 160,58 240,46 320,34" fill="none" stroke="var(--ink)" stroke-width="2"/><text x="2" y="30" fill="var(--ink)" font-size="8" font-family="Lora,serif">Index ↑</text><polyline points="0,52 80,60 160,72 240,86 320,98" fill="none" stroke="var(--neg)" stroke-width="2" stroke-dasharray="4 2"/><text x="232" y="112" fill="var(--neg)" font-size="8" font-family="Lora,serif">% &gt; 200-DMA ↓</text></svg>`,
  valuation: `<svg viewBox="0 0 320 120" role="img" aria-label="Illustrative: equity risk premium drifting below its historical normal range"><rect x="0" y="38" width="320" height="40" fill="var(--data)" opacity="0.12"/><line x1="0" y1="58" x2="320" y2="58" stroke="var(--muted)" stroke-width="1" stroke-dasharray="2 3"/><text x="2" y="52" fill="var(--muted)" font-size="8" font-family="Lora,serif">normal ERP range</text><polyline points="0,50 80,56 160,70 240,82 320,88" fill="none" stroke="var(--data)" stroke-width="2"/><circle cx="320" cy="88" r="3.5" fill="var(--data)"/><text x="226" y="104" fill="var(--data)" font-size="8" font-family="Lora,serif">ERP ≈3.2% — thin</text></svg>`,
  returnbridge: `<svg viewBox="0 0 320 124" role="img" aria-label="Illustrative return bridge: dividend yield plus earnings growth minus multiple change equals total return"><line x1="0" y1="98" x2="320" y2="98" stroke="var(--cardline)"/><rect x="18" y="80" width="42" height="18" fill="var(--pos)"/><text x="18" y="112" fill="var(--muted)" font-size="7.5" font-family="Lora,serif">Div + b/back</text><rect x="92" y="48" width="42" height="32" fill="var(--struct)"/><text x="96" y="112" fill="var(--muted)" font-size="7.5" font-family="Lora,serif">EPS growth</text><rect x="166" y="48" width="42" height="22" fill="var(--neg)"/><text x="172" y="112" fill="var(--muted)" font-size="7.5" font-family="Lora,serif">ΔP/E</text><rect x="252" y="62" width="42" height="36" fill="var(--eyeb)"/><text x="262" y="112" fill="var(--muted)" font-size="7.5" font-family="Lora,serif">Total</text></svg>`,
  earnings: `<svg viewBox="0 0 320 120" role="img" aria-label="Illustrative: net earnings-revision breadth oscillating around the zero line"><line x1="0" y1="60" x2="320" y2="60" stroke="var(--muted)" stroke-dasharray="2 3"/><text x="2" y="56" fill="var(--muted)" font-size="8" font-family="Lora,serif">net revisions = 0</text><polyline points="0,42 50,50 100,58 150,72 200,66 260,52 320,60" fill="none" stroke="var(--struct)" stroke-width="2"/><text x="250" y="40" fill="var(--struct)" font-size="8" font-family="Lora,serif">revision breadth</text></svg>`,
  gauge: `<svg viewBox="0 0 320 132" role="img" aria-label="Illustrative sentiment gauge resting near neutral"><path d="M34,116 A126,126 0 0,1 98,32" fill="none" stroke="var(--neg)" stroke-width="13"/><path d="M98,32 A126,126 0 0,1 222,32" fill="none" stroke="var(--warn)" stroke-width="13"/><path d="M222,32 A126,126 0 0,1 286,116" fill="none" stroke="var(--pos)" stroke-width="13"/><line x1="160" y1="116" x2="150" y2="46" stroke="var(--ink)" stroke-width="2.5"/><circle cx="160" cy="116" r="5" fill="var(--ink)"/><text x="26" y="130" fill="var(--neg)" font-size="8.5" font-family="Lora,serif">Fear</text><text x="142" y="20" fill="var(--warn)" font-size="8.5" font-family="Lora,serif">Neutral</text><text x="262" y="130" fill="var(--pos)" font-size="8.5" font-family="Lora,serif">Greed</text></svg>`,
};
const chartCap = {
  regime: 'Regime — index vs MA band, catalyst marked', breadth: 'Breadth divergence — index vs participation',
  valuation: 'Valuation — ERP vs its normal range', earnings: 'Earnings — net revision breadth vs zero', gauge: 'Sentiment — composite dial',
};

// ── GICS sector profiles (Part C) ──
const sectorProfiles = [
  { s: 'Information Technology', etf: 'XLK', dr: 'Secular digitization, cloud/AI capex, R&D intensity, long-duration cash flows', sens: 'Rates High(−) · Cycle High · Oil Low · USD Med(−) · Infl Med(−)', kpis: 'Revenue growth · operating margin · R&D/sales · cloud growth · forward P/E', leads: 'Enterprise capex intent · semi billings/bookings · cloud backlog · ISM new orders', risks: 'Multiple compression from real yields · mega-cap concentration · capex pullbacks', ll: 'Leads early-cycle on falling rates; vulnerable late-cycle as rates/valuations bite' },
  { s: 'Communication Services', etf: 'XLC', dr: 'Digital advertising, streaming/subscriptions, telecom infra; bifurcated (growth internet + defensive telecom)', sens: 'Rates Med(−) · Cycle Med · Oil Low · USD Med(−) · Infl Low–Med', kpis: 'Ad revenue growth · ARPU · subscriber net adds · EBITDA margin · churn', leads: 'Ad-spend surveys · ISM · consumer confidence · device/data trends', risks: 'Ad-budget cyclicality · antitrust · content-cost inflation · cord-cutting', ll: 'Internet/ad names track the cycle; telecom subset defensive and rate-sensitive' },
  { s: 'Consumer Discretionary', etf: 'XLY', dr: 'Household non-essential spend, autos, e-commerce, travel/leisure; high beta to consumer health', sens: 'Rates High(−) · Cycle High · Oil Med(−) · USD Med · Infl High(−)', kpis: 'Comp sales · traffic · gross margin · inventory/sales · discretionary spend share', leads: 'Consumer confidence · real wages · retail sales · credit availability · auto/mortgage rates', risks: 'Recession demand shock · margin squeeze · inventory gluts', ll: 'Classic early-cycle leader; early to roll over late-cycle' },
  { s: 'Consumer Staples', etf: 'XLP', dr: 'Inelastic food/beverage/household demand; pricing power, brand moats; defensive', sens: 'Rates Med(− bond-proxy) · Cycle Low (defensive) · Oil Low–Med · USD Med(−) · Infl Med (pass-through)', kpis: 'Organic sales · volume vs price · gross margin · FCF · dividend coverage', leads: 'Commodity input costs · FX · private-label share · real income', risks: 'Input inflation outpacing pricing · FX translation · volume loss to private label', ll: 'Outperforms late-cycle/recession; lags in early-cycle risk-on' },
