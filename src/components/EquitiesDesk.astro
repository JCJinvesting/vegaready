  .sk-go{font-family:'Lora',serif;font-size:11px;font-weight:700;letter-spacing:.05em;text-transform:uppercase;color:#241A05;background:var(--eyeb);border:none;border-radius:7px;padding:7px 14px;cursor:pointer;margin-left:auto}
  .sk-go:hover{background:#F8D49A}
  .srcfrom .sk-go{margin-left:8px;vertical-align:middle}
  .sk60{background:var(--card);border:1px solid var(--cardline);border-left:3px solid var(--eyeb);border-radius:0 12px 12px 0;padding:16px 20px}
  .sk60-h{font-family:'Lora',serif;font-size:10px;font-weight:700;letter-spacing:.16em;text-transform:uppercase;color:var(--eyeb);margin-bottom:9px}
  .sk60-call{font-size:15.5px;line-height:1.6;color:var(--body);margin:0 0 13px;max-width:80ch}
  .sk60-call b{color:var(--ink)}
  .sk60-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:10px;margin-bottom:13px}
