  .srcpill{font-size:11px;color:var(--data);border:1px solid var(--cardline);border-radius:20px;padding:4px 11px;text-decoration:none}
  .srcpill:hover{border-color:var(--data)}
  .tnote{font-size:11px;color:var(--muted);line-height:1.6;margin-top:14px;font-style:italic;max-width:92ch}
  .st-chip{font-family:'Lora',serif;font-size:8.5px;font-weight:700;letter-spacing:.03em;padding:1px 6px;border-radius:4px;white-space:nowrap}
  .st-live{color:var(--pos);background:color-mix(in srgb,var(--pos) 13%,transparent)}
  .st-pub{color:var(--data);background:color-mix(in srgb,var(--data) 13%,transparent)}
  .st-src{color:var(--bench);background:color-mix(in srgb,var(--bench) 13%,transparent)}
  .st-pending{color:var(--muted);background:color-mix(in srgb,var(--muted) 12%,transparent)}
  body[data-disc="skim"] .deep{display:none}
  /* designed Skim tier */
  .sk60{background:var(--anchor);border:1px solid var(--cardline);border-left:3px solid var(--eyeb);border-radius:0 13px 13px 0;padding:16px 20px;margin-bottom:8px}
  .sk60-h{font-family:'Lora',serif;font-size:10px;font-weight:700;letter-spacing:.09em;text-transform:uppercase;color:var(--eyeb);margin-bottom:8px}
