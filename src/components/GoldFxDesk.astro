  .sk60-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(130px,1fr));gap:10px;margin-bottom:12px}
  .sk60-c{background:var(--card);border:1px solid var(--cardline);border-radius:9px;padding:9px 12px}
  .sk60-v{font-family:'Fraunces',serif;font-size:20px;font-weight:600;color:var(--ink)}
  .sk60-l{font-size:10.5px;color:var(--muted);line-height:1.35;margin-top:2px}
  .sk60-w{font-size:13px;color:var(--body);line-height:1.55}
  .sk60-w b{color:var(--ink)}
  .skim-bl{font-size:13.5px;line-height:1.55;color:var(--body);background:var(--anchor);border:1px solid var(--cardline);border-radius:9px;padding:10px 14px;margin:10px 0 0}
  .skim-bl b{color:var(--eyeb)}
  .bl-go{display:inline-block;margin-left:6px;font-family:'Lora',serif;font-size:10px;font-weight:700;letter-spacing:.03em;color:var(--muted)}
  /* winners & losers lanes */
  .wl3{display:grid;grid-template-columns:repeat(3,1fr);gap:12px;margin-top:6px}
  @media(max-width:760px){.wl3{grid-template-columns:1fr}}
  .wl-lane{background:var(--card);border:1px solid var(--cardline);border-top:2px solid var(--cardline);border-radius:10px;padding:12px 14px}
  .wl-win{border-top-color:var(--pos)}
  .wl-mix{border-top-color:var(--struct)}
  .wl-lose{border-top-color:var(--neg)}
  .wl-h{font-family:'Lora',serif;font-size:10px;font-weight:700;letter-spacing:.06em;text-transform:uppercase;margin-bottom:9px}
  .wl-win .wl-h{color:var(--pos)}.wl-mix .wl-h{color:var(--struct)}.wl-lose .wl-h{color:var(--neg)}
  .wl-item{padding:7px 0;border-bottom:1px solid var(--cardline)}
  .wl-item:last-child{border-bottom:none}
  .wl-item b{display:block;font-family:'Fraunces',serif;font-size:13px;color:var(--ink);margin-bottom:1px}
  .wl-item span{font-size:11.5px;color:var(--body);line-height:1.4}
  /* dated catalyst watchlist */
  .cal{display:grid;gap:0;margin-top:4px}
  .cal-row{display:grid;grid-template-columns:120px 1fr;gap:14px;align-items:baseline;padding:9px 0 9px 12px;border-bottom:1px solid var(--cardline);border-left:2px solid var(--cardline)}
  .cal-cal{border-left-color:var(--data)}.cal-up{border-left-color:var(--neg)}.cal-dn{border-left-color:var(--pos)}
  @media(max-width:680px){.cal-row{grid-template-columns:1fr;gap:2px}}
  .cal-when{font-family:'Lora',serif;font-size:10px;font-weight:700;letter-spacing:.04em;text-transform:uppercase;color:var(--eyeb)}
  .cal-what b{font-family:'Fraunces',serif;font-size:13px;color:var(--ink);display:block;margin-bottom:1px}
  .cal-what span{font-size:12px;color:var(--body);line-height:1.45}
  .db-asof{font-family:'Lora',serif;font-weight:400;font-size:9.5px;text-transform:none;letter-spacing:0;color:var(--muted);font-style:italic;margin-left:8px}
</style>

<script is:inline>
  (async function(){var el=document.getElementById('liveAsOf');try{var r=await fetch('/data-status.json',{cache:'no-store'});if(!r.ok){if(el)el.textContent='live';return;}var s=await r.json();var w=s.dataDate||(s.metrics&&s.metrics.newest)||'';if(el)el.textContent=(s.state==='ok'?(w||'live'):'last good data');}catch(e){if(el)el.textContent='live';}})();
  (function(){
    function apply(mode){document.body.setAttribute('data-disc',mode);document.querySelectorAll('.disc button').forEach(function(x){x.classList.toggle('on',x.getAttribute('data-disc')===mode);});}
    document.querySelectorAll('.disc button').forEach(function(b){b.addEventListener('click',function(){apply(b.getAttribute('data-disc'));});});
    var init=document.body.getAttribute('data-disc')||(document.body.getAttribute('data-mode')==='overview'?'skim':'deep');apply(init);
  })();
  (function(){var links=Array.prototype.slice.call(document.querySelectorAll('#secnav a'));var ids=links.map(function(a){return a.getAttribute('href').slice(1)});var io=new IntersectionObserver(function(es){es.forEach(function(e){if(e.isIntersecting){var i=ids.indexOf(e.target.id);if(i>=0){links.forEach(function(x){x.classList.remove('on')});links[i].classList.add('on');}}});},{rootMargin:'-45% 0px -50% 0px'});ids.forEach(function(id){var el=document.getElementById(id);if(el)io.observe(el);});})();
  (function(){var tbl=document.getElementById('cohtbl');if(!tbl)return;var ths=tbl.querySelectorAll('th.sort');ths.forEach(function(th){th.addEventListener('click',function(){var col=th.getAttribute('data-col');var dir=th.getAttribute('data-dir')==='asc'?-1:1;th.setAttribute('data-dir',dir===1?'asc':'desc');var tb=tbl.querySelector('tbody');var rows=Array.prototype.slice.call(tb.querySelectorAll('tr'));rows.sort(function(a,b){return (parseFloat(a.getAttribute('data-'+col))-parseFloat(b.getAttribute('data-'+col)))*dir;});rows.forEach(function(r){tb.appendChild(r);});});});})();
</script>
