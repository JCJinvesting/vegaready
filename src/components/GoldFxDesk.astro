---
import '../styles/desk.css';
import '../styles/desk-content.css';
import '../styles/desk-v2.css';
import '../styles/skin-juniper.css';
import Wayfinder from './Wayfinder.astro';

const { mode = 'analyst' } = Astro.props;
const SNAP = 'as of 2026-06-12';

// ── Wayfinder (kit §4e) ──
const wfTrail = mode === 'layman'
  ? [{ label: 'Layman', href: '/layman' }, { label: 'Markets', href: '/markets' }, { label: 'Dollar, FX & Gold' }]
  : [{ label: 'Markets', href: '/markets' }, { label: 'Dollar, FX & Gold' }];
const wfRail = [
  { label: 'Equities', href: '/markets/equities' },
  { label: 'Credit', href: '/markets/credit' },
  { label: 'Dollar, FX & Gold', href: '/markets/gold-fx', current: true },
  { label: 'Commodities', href: '/markets/energy' },
  { label: 'Crypto', href: '/markets/crypto' },
  { label: 'Cross-asset', href: '/markets/cross-asset' },
];

// ── glossary (hover defs) ──
const gloss = [
  ['DXY', 'US Dollar Index — the dollar vs a fixed six-currency basket (EUR-heavy). ICE-administered; no free live feed, so this desk reads the dollar off a broad trade-weighted proxy.'],
  ['Broad dollar', 'A trade-weighted dollar index (FRED DTWEXBGS) spanning far more currencies than DXY; the wireable, free proxy for "the dollar".'],
  ['Real yield', 'Nominal yield minus expected inflation (measured by TIPS). The opportunity cost of holding non-yielding gold, and the dollar’s real-rate magnet. 0% is free money; +2% is firmly restrictive.'],
  ['Dollar smile', 'The pattern that the dollar is bid at both ends of the growth spectrum — in a global panic (haven bid) and a US-outperformance boom (rate bid) — and sags only in the benign rate-cutting middle.'],
  ['REER', 'Real Effective Exchange Rate — a currency’s trade-weighted, inflation-adjusted value; the standard gauge of over/undervaluation versus trading partners.'],
  ['Carry', 'Borrow a low-yield funding currency (yen, franc), invest in a higher-yield one; you earn the rate differential until an FX move erases it.'],
  ['Carry unwind', 'A disorderly exit from carry trades when the funding currency surges — self-reinforcing as losses force more covering. August 2024 is the template: ~10–15% of the yen book unwound and global vol spiked.'],
  ['Cross-currency basis', 'The extra cost of raising dollars via the FX-swap market versus onshore funding; a deeply negative basis signals an offshore-dollar squeeze.'],
  ['FIMA repo', 'The Fed’s repo facility for foreign official accounts — lets central banks raise dollars against their Treasuries instead of selling them. The designed alternative to dumping USTs.'],
  ['Swap lines', 'Standing Fed dollar-swap arrangements with five core central banks (ECB, BoJ, BoE, SNB, BoC); peaked near $450bn in May 2020. Activation caps an offshore-dollar squeeze.'],
  ['COT', 'CFTC Commitments of Traders — weekly futures positioning by trader type; the read on speculative crowding (e.g. net-short yen) and reversal risk.'],
  ['TIC', 'Treasury International Capital — monthly US data on foreign holdings and flows of Treasuries; the official scoreboard for who is buying or selling USTs.'],
  ['COFER', 'IMF Currency Composition of Official FX Reserves — the quarterly series tracking the dollar’s share of global reserves.'],
  ['DV01', 'Dollar value of one basis point — how much a bond position moves per 0.01% yield change; the unit for sizing a reserve sale’s footprint on the Treasury curve.'],
  ['mBridge', 'A multi-central-bank digital-currency platform for cross-border settlement that can bypass the dollar leg; small but scaling.'],
  ['Petrodollar', 'The 1974 arrangement whereby oil exporters earn dollars and recycle the surplus into US assets (esp. Treasuries) — a structural pillar of dollar demand.'],
  ['Triffin', 'The Triffin dilemma — the reserve-currency issuer must run deficits to supply the world its currency, which slowly erodes confidence in that very currency.'],
  ['SRF', 'The Fed’s Standing Repo Facility (permanent since July 2021) — the domestic backstop that caps funding-rate spikes; take-up is the cleanest real-time stress gauge.'],
  ['Fragile Five', 'India, Indonesia, Brazil, South Africa, Turkey — the 2013 taper-tantrum casualties, all running twin deficits with loose policy; the template for energy-importer FX stress.'],
];
const G = {}; gloss.forEach(([t, d]) => { G[t] = d; });
const gl = (term, label) => `<span class="gloss" data-def="${G[term]}">${label || term}</span>`;

// ── decoders ──
const valueTypes = [
  ['Current', 'latest observed print'], ['Baseline', 'long-run norm / historical reference'],
  ['Nowcast', 'estimate of the present from incomplete data'], ['Forecast', 'forward agency/consensus estimate'],
  ['Scenario', 'conditional “if-then” path'],
];
const sourceTiers = [
  ['T1', 'Primary / official', 'FRED · LBMA · CFTC COT · IMF COFER · BIS · Japan MOF · US TIC · Fed H.4.1 · EIA · RBI'],
  ['T2', 'Industry / analytic', 'World Gold Council · sell-side FX strategy · BIS research bulletins'],
  ['T3', 'Editorial / commentary', 'FT · Reuters · Economist'],
  ['T4', 'Derived / VegaReady model', 'broad-dollar proxy · gold–real-yield gap · reserve-sale DV01 · forced-seller ledger'],
];
const chipFor = (c) => c === 'live' ? { cls: 'st-live', g: '●', w: 'Live' }
  : c === 'pub' ? { cls: 'st-pub', g: '◐', w: 'Latest pub.' }
  : c === 'src' ? { cls: 'st-src', g: '◌', w: 'Source ready' }
  : c === 'nofeed' ? { cls: 'st-pending', g: '○', w: 'No free feed' }
  : { cls: 'st-pending', g: '○', w: 'Feed pending' };

// ── §0 desk panel tiles (mix of live + source-ready; gold corrected) ──
const panelTiles = [
  { k: gl('Broad dollar', 'Broad dollar') + ' (DTWEXBGS)', v: '~120', s: 'Firm, not euphoric — ~5% below the 2025 peak; the six-currency ' + gl('DXY', 'DXY') + ' is a separate gauge near 99.8', chip: 'live', src: 'FRED DTWEXBGS (Jan-2006=100) · ICE DXY paywalled', tier: 'T1/T4' },
  { k: gl('Real yield', 'Real 10y'), v: '+2.16%', s: 'Firmly restrictive — a dollar magnet', chip: 'live', src: 'FRED DFII10', tier: 'T1' },
  { k: 'USD/JPY', v: '~160', s: 'Yen pinned weak; intervention live', chip: 'live', src: 'FRED DEXJPUS', tier: 'T1' },
  { k: 'Gold (LBMA)', v: '~$4,365', s: '−22% off the Jan ATH $5,595; CB bid floors it', chip: 'src', src: 'LBMA fix · live spot paywalled', tier: 'T1' },
];

const read30 = [
  'The live question is never <b>“is the dollar finished”</b> — it’s <b>which channel meets global dollar demand, and whether that channel forces or relieves Treasury selling.</b>',
  'The dollar is firm because the US offers <b>both legs of the “dollar smile” at once</b> — high real carry (real 10y +2.16%) <i>and</i> a haven premium on the oil shock. It has become a partial funding <i>destination</i>, not a funding source.',
  '<b>Gold is off its January record</b> (~$4,365 vs the $5,595 all-time high) after a real-yield-driven correction — but a price-inelastic central-bank bid (~29t/month) is the structural floor.',
  'Stress shows in the <b>plumbing first</b>: the cross-currency basis and the Fed’s backstop spread lead; who is a <b>forced seller</b> of dollars (and therefore Treasuries) is the whole game.',
  'De-dollarization is <b>real but glacial</b> — the dollar’s reserve share is at a 25-year low (56.77%, Q4-2025), yet no alternative has Treasuries’ depth. The Gulf shock raises the temperature; it does not break the order.',
];
const falsifiers = [
  'The dollar-firm read is wrong if the broad dollar (DXY) sustains <b>below ~100 into de-escalation</b>, rate-cut odds return, and foreign-official Treasury buying resumes.',
  'The gold-decoupling read snaps back if <b>real yields rise faster than the geopolitical risk premium</b> — gold’s rate sensitivity reasserts.',
  'The forced-seller thesis is falsified if a country’s <b>diaspora-deposit drive succeeds and reserves stabilize</b> — substitution replaces UST sales.',
  'The de-dollarization-is-glacial read breaks if <b>Gulf oil starts pricing in non-dollars</b> and official gold-buying accelerates past a steady ~29t/month.',
];

// ── attribution buckets ──
const drivers = [
  { d: 'Real-rate differential', b: 'primary', n: 'US real 10y +2.16% vs a slower-cutting world — the engine of the firm dollar' },
  { d: 'Safe-haven / geopolitical', b: 'material', n: 'The Hormuz oil shock routes haven flow to the dollar and the gold bid' },
  { d: 'Dollar-funding / plumbing', b: 'material', n: 'Cross-currency basis, FIMA/swaps, forced-seller mechanics — the transmission belt' },
  { d: 'Carry / positioning', b: 'secondary', n: 'Crowded funding-currency shorts; unwind risk can dominate for days' },
  { d: 'Active catalyst (Iran–Hormuz)', b: 'secondary', n: 'Overlay on the durable frame — see §Catalysts' },
  { d: 'Residual / unexplained', b: 'uncertain', n: 'Named, never assumed zero' },
];

// ── spine topic specs (§1–§4) ──
const T = {
  regime: {
    eye: '§1', q: 'How strong is the dollar, and why now?', h: 'The Dollar Regime & the “Smile”', fresh: 'daily · FRED', chart: 'smile',
    lead: `The broad dollar (DTWEXBGS ~120, Jan-2006=100) is <b>firm but not euphoric</b> — about 5% below its 2025 peak, and a different gauge from the six-currency ICE DXY near 99.8 — because the US offers <i>both</i> legs of the ${gl('Dollar smile', 'dollar smile')} at once: a <b>high real-rate bid</b> (${gl('Real yield', 'real 10y')} +2.16%, the most restrictive in years) and a <b>safe-haven bid</b> (a net-energy-exporter routing the oil shock toward the dollar). At a restrictive real rate the dollar has become a partial funding <i>destination</i> — pulling marginal carry capital away from emerging markets rather than financing it.`,
    kpi: [
      [gl('Broad dollar', 'Broad dollar') + ' (DTWEXBGS)', '~120', 'live', 'medium'],
      [gl('Real yield', 'Real 10y'), '+2.16%', 'live', 'high'],
      ['Fed funds (effective)', '3.62%', 'live', 'high'],
      ['2026 cut odds priced', '~0', 'src', 'medium'],
    ],
    track: [
      [gl('Real yield', 'Real-yield differential') + ' (US vs G10/EM)', 'M'],
      ['Fed-path expectations (hike vs cut odds)', 'M'],
      ['Which smile quadrant is active (haven vs carry vs benign)', 'M'],
      ['Oil → CPI → Fed transmission (the live driver)', 'M'],
      ['DXY level vs its ~100 psychological line (a separate 6-ccy gauge)', 'N'],
    ],
    lv: ['Real-yield differential leads the dollar level', 'The dollar prices the regime in real time; a sustained break of the DXY ~100 line tends to lead cross-asset stress (DXY ~99.8 today, versus its 164.72 Plaza-era high in 1985 and the 114.78 wrecking-ball peak of Sep-2022). Above 100 with a hawkish Fed = continued EM dollar stress; below 100 = pressure eases.'],
    src: 'FRED DTWEXBGS, DFII10, DFF · CME FedWatch (Fed path)', tier: 'T1/T4',
    feed: [['Broad dollar (DXY proxy)', 'FRED DTWEXBGS — official ICE DXY paywalled'], ['Real 10y / Fed funds', 'FRED DFII10 / DFF'], ['Fed-path odds', 'CME FedWatch / Atlanta Fed Mkt-Prob Tracker (no FRED real-time)']],
  },
  structure: {
    eye: '§2', q: 'Is the strength broad — and who is the haven?', h: 'Haven Hierarchy & Breadth', fresh: 'daily · monthly TIC', chart: 'ladder',
    lead: `The haven hierarchy this cycle runs <b>USD &gt; CHF &gt; gold &gt; JPY</b> — an inversion of the 1979/1990 template where gold led and the yen was a refuge. The dollar took the primary bid (net-energy-exporter advantage); the franc took the neutral-haven flow; gold led the <i>monetary</i> haven before its correction; and the yen — now the carry funding leg — is no longer a refuge but the largest concentrated tail. Beneath the surface, dollar strength is an <b>official-sector-selling, private-sector-absorbing</b> story (see the breadth read). The dispersion shows in the gauges: the all-partners index (DTWEXBGS 120.08) sits ~7 points above the advanced-economy cut (DTWEXAFEGS 112.68), with the EM cut (DTWEXEMEGS 129.38) heaviest — and the advanced-economy dollar is up YTD while the EM dollar is flat-to-down, so the 2026 shock is concentrated on <b>energy importers</b>, not EM broadly.`,
    kpi: [
      ['VIX (stress gauge)', '—', 'src', null],
      ['Foreign-official UST, y/y', '−$21.2bn', 'pub', 'high'],
      ['CHF — G10 haven rank', '#2', 'src', 'medium'],
      ['Gold vs USD haven rank', 'contested', 'src', 'medium'],
    ],
    track: [
      ['The haven ladder (USD / CHF / gold / JPY) and any re-rank', 'M'],
      ['Breadth: official-sector selling vs private/custody absorption', 'M'],
      [gl('TIC', 'TIC') + ' foreign-official subtotal trend', 'M'],
      ['Carry-unwind haven behavior (funding currencies bid back)', 'N'],
      ['Historical crisis-template analogue (see table)', 'N'],
    ],
    lv: ['VIX spike leads the haven re-rank by 0–3 days', 'In a flight-to-quality the funding-currency havens (CHF, JPY) appreciate violently as leverage is covered; TIC confirms the breadth read but lags ~2 months.'],
    src: 'CBOE VIX · Treasury TIC (monthly, ~2-mo lag) · BIS crisis studies', tier: 'T1/T2',
    feed: [['VIX', 'CBOE (no FRED real-time; delayed)'], ['Foreign-official UST', 'Treasury TIC MFH (monthly)'], ['Haven ranks', 'VegaReady-derived from bilateral FRED series']],
  },
  valuation: {
    eye: '§3', q: 'Is the dollar rich — and why did gold decouple?', h: 'Valuation: REER & Gold vs Real Yields', fresh: 'daily · monthly REER', chart: 'goldpath',
    lead: `Two valuation questions sit on this desk. The <b>dollar is rich on most ${gl('REER', 'REER')} measures</b> — a medium-term headwind masked by the haven bid; reversion is a direction, not a timing signal, with the DXY ~100 line the practical tell. And <b>gold’s textbook inverse to ${gl('Real yield', 'real yields')} is regime-dependent, not dead</b>: it ran to an all-time high, corrected hard when real yields spiked, then found a central-bank floor — the decoupling is a risk-premium overlay on a real-rate anchor, not a repeal of it.`,
    kpi: [
      [gl('Real yield', 'Real 10y'), '+2.16%', 'live', 'high'],
      ['Gold (LBMA)', '~$4,365', 'src', 'medium'],
      ['Gold vs Jan ATH', '−22%', 'src', 'medium'],
      ['Dollar REER vs fair value', 'rich', 'pub', 'medium'],
    ],
    track: [
      [gl('REER', 'Dollar REER') + ' over/undervaluation', 'M'],
      ['Gold vs real-yield gap (the decoupling signal)', 'M'],
      ['The doom-loop tell: gold rising <i>with</i> real yields', 'M'],
      ['Major-cross PPP fair value', 'N'],
      ['Gold’s rate-sensitivity snap-back risk', 'N'],
    ],
    lv: ['Real yields normally lead gold; in 2026 the geopolitical premium decouples them', 'When gold rises <i>simultaneously</i> with real yields it signals a loss of confidence in the fiat anchor — the highest-information regime, and the one to watch.'],
    src: 'FRED DFII10 · LBMA gold fix · BIS REER (monthly)', tier: 'T1/T2',
    feed: [['Real 10y', 'FRED DFII10 (daily)'], ['Gold', 'LBMA AM/PM fix — live spot paywalled'], ['Dollar REER', 'BIS REER indices (monthly)']],
  },
  fundamentals: {
    eye: '§4', q: 'What is the slow anchor under the dollar?', h: 'Fundamentals: Rates, Deficits & Privilege', fresh: 'daily rates · monthly flows', chart: null,
    lead: `The dollar’s engine is <b>real rate differentials</b> (US +2.16% real vs a slower-normalizing world), offset over the medium term by the <b>twin deficits</b> ($1.9tn, ~5.8% of GDP) and a rich ${gl('REER', 'REER')}. A <b>positive, model-agnostic term premium</b> (ACM ~0.67%, Kim–Wright ~0.80%, converged within ~13bp) is the structural pressure under the dollar’s Treasury anchor — the extra yield foreign buyers now demand to keep funding the deficit. The deeper anchor is the ${gl('Triffin', 'Triffin')} bargain — the world’s need for dollars (reserves, trade invoicing, and now private stablecoins) sustains Treasury demand even amid de-dollarization headlines, the very “exorbitant privilege” that lets the US fund twin deficits cheaply.`,
    kpi: [
      ['US real 10y', '+2.16%', 'live', 'high'],
      ['Term premium (10y)', '+0.67–0.80%', 'pub', 'medium'],
      ['Federal deficit (CBO)', '$1.9tn · 5.8%', 'pub', 'medium'],
      ['Foreign-held UST share', '~25%', 'pub', 'high'],
    ],
    track: [
      ['US-vs-world real rate differentials', 'M'],
      ['Twin deficits / net Treasury supply', 'M'],
      ['Terms of trade (oil shock → exporter vs importer split)', 'M'],
      ['Foreign-held share of Treasuries (the “privilege” gauge)', 'N'],
      [gl('Triffin', 'Triffin') + ' tension: reserve demand vs fiscal credibility', 'N'],
    ],
    lv: ['Rate differentials lead daily; the deficit/REER anchor binds slowly', 'Two misconceptions to retire: foreigners hold only ~25% of Treasuries (not “all”); and if China sold its holdings the threat is to market <i>stability</i>, not US solvency — the US borrows in its own currency. Foreign holdings total ~$9.5tn (+6% y/y) — growing in absolute terms even as the official sector turns net-soft, which is why de-dollarization reads as glacial.'],
    src: 'FRED (DFII10) · CBO projections · Treasury TIC · IMF COFER', tier: 'T1',
    feed: [['Real-rate differentials', 'FRED + foreign central-bank policy rates'], ['Deficit / supply', 'CBO (free, periodic)'], ['Foreign-held share', 'Treasury TIC vs total outstanding']],
  },
};
const topicOrder = ['regime', 'structure', 'valuation', 'fundamentals'];

// ── illustrative inline SVGs (schematic, re-skin via CSS vars) ──
const charts = {
  smile: { title: 'The dollar smile', svg: `<svg viewBox="0 0 340 130" role="img" aria-label="The dollar is bid in both global panic and global boom, weak in the benign middle, with today on the panic side"><path d="M18,42 C78,118 262,118 322,42" fill="none" stroke="var(--data)" stroke-width="2"/><text x="8" y="32" fill="var(--muted)" font-size="8" font-family="Lora,serif">panic (haven)</text><text x="262" y="32" fill="var(--muted)" font-size="8" font-family="Lora,serif">boom (rates)</text><text x="138" y="126" fill="var(--muted)" font-size="8" font-family="Lora,serif">benign middle</text><circle cx="44" cy="80" r="4" fill="var(--eyeb)"/><text x="34" y="102" fill="var(--eyeb)" font-size="8" font-family="Fraunces,serif">today</text></svg>` },
  ladder: { title: 'The haven ladder', svg: `<svg viewBox="0 0 340 130" role="img" aria-label="Haven hierarchy this cycle: dollar first, Swiss franc second, gold third, yen fourth"><g font-family="Fraunces,serif" font-size="10"><rect x="20" y="20" width="150" height="20" rx="3" fill="var(--eyeb)" opacity="0.85"/><text x="26" y="34" fill="#16130A">1 · USD</text><rect x="20" y="46" width="125" height="20" rx="3" fill="var(--data)" opacity="0.7"/><text x="26" y="60" fill="var(--ink)">2 · CHF</text><rect x="20" y="72" width="100" height="20" rx="3" fill="var(--bench)" opacity="0.6"/><text x="26" y="86" fill="var(--ink)">3 · Gold</text><rect x="20" y="98" width="72" height="20" rx="3" fill="var(--neg)" opacity="0.5"/><text x="26" y="112" fill="var(--ink)">4 · JPY</text></g><text x="180" y="34" fill="var(--muted)" font-size="8" font-family="Lora,serif">primary bid</text><text x="180" y="112" fill="var(--muted)" font-size="8" font-family="Lora,serif">funding leg, not a refuge</text></svg>` },
  goldpath: { title: 'Gold’s 2026 path', svg: `<svg viewBox="0 0 340 130" role="img" aria-label="Gold rose to a January record near 5595, corrected about 19 percent into March, then based around 4300 to 4540"><polyline points="0,92 70,44 112,30 178,90 240,98 340,86" fill="none" stroke="var(--eyeb)" stroke-width="2"/><circle cx="112" cy="30" r="3.5" fill="var(--eyeb)"/><text x="70" y="24" fill="var(--eyeb)" font-size="8" font-family="Fraunces,serif">$5,595 ATH (Jan)</text><circle cx="200" cy="96" r="3" fill="var(--neg)"/><text x="158" y="114" fill="var(--neg)" font-size="8" font-family="Lora,serif">−19% (Mar floor)</text><text x="288" y="78" fill="var(--muted)" font-size="8" font-family="Lora,serif">~$4,365</text></svg>` },
};

// ── historical haven/crisis templates (§2) ──
const havenTemplates = [
  ['1990', 'Gulf War', 'Gold spiked on the oil shock as equities plunged — the live 2026 analogue for a geopolitical gold bid', 'T3'],
  ['1994', '“Bond massacre”', 'Fed 3.0%→5.5%; the Mexican peso broke that December with a ~10-month lag — tightening transmits to EM late', 'T1'],
  ['1998', 'LTCM / Russia default', 'Yen +15–20% in days; 10y UST troughed 4.16% (flight-to-quality won); VIX peaked 49.53 — systemic in under two weeks', 'T1'],
  ['2008', 'GFC / yen-carry unwind', 'Yen +15%, Swiss franc +9% over the 10 months to Apr 2008; AUD/JPY −7.7% in a single day (Aug 2007)', 'T1'],
  ['2020', 'COVID dash-for-cash', 'Fed dollar-swap lines peaked ~$450bn (May 2020) — the backstop that capped the offshore-dollar squeeze', 'T1'],
  ['2022', 'Global tightening', 'Japan’s MOF intervened ~$62bn (Sep–Oct); China had spent ~$1tn of reserves defending the yuan in 2015–16', 'T1'],
  ['Aug 2024', 'Yen-carry unwind (most instructive)', 'BoJ hike + weak US payrolls → 5 Aug: TOPIX −12%, VIX intraday 65.73; only 10–15% of the yen book unwound, ~$4tn left intact', 'T2'],
];

// ── §5 cohort sensitivity matrix (sortable) ──
const cohortMatrix = [
  { s: 'USD/JPY', rate: ['High', 5, 'hi'], carry: ['Funding leg', 5, 'hi'], usd: ['Low', 1, 'lo'] },
  { s: 'USD/CNY', rate: ['Mod', 3, 'mid'], carry: ['Funding leg', 4, 'hi'], usd: ['High', 4, 'hi'] },
  { s: 'USD/CHF', rate: ['Mod', 3, 'mid'], carry: ['Funding leg', 5, 'hi'], usd: ['Low', 1, 'lo'] },
  { s: 'EUR/USD', rate: ['High', 4, 'hi'], carry: ['Funding leg', 3, 'mid'], usd: ['Mod', 3, 'mid'] },
  { s: 'EM importers', rate: ['Very high', 5, 'hi'], carry: ['Recipient', 4, 'hi'], usd: ['Very high', 5, 'hi'] },
  { s: 'EM exporters', rate: ['High', 4, 'hi'], carry: ['Recipient', 5, 'hi'], usd: ['Mod', 3, 'mid'] },
  { s: 'Gold', rate: ['High (inverse)', 4, 'hi'], carry: ['n/a', 1, 'lo'], usd: ['Mod (inverse)', 3, 'mid'] },
];

// ── §5 cohort library (dcard profiles) ──
const crossCohorts = [
  { s: 'USD/JPY — the tail', p: 'JPY · ¥-funding leg', dr: 'The yen is the single largest concentrated tail: Japan is both the biggest official Treasury holder (~$1.19tn) and the dominant carry funding currency. A break below ~140 is the trigger to watch for violent repatriation.', sens: 'Rate-diff High · Carry funding leg · USD-vuln Low', kpis: 'USD/JPY level · MOF intervention CSV · 10y JGB · CFTC net-short yen', leads: 'BoJ hawkish signal · USD/JPY < 140 · MOF op disclosure', risks: 'Carry unwind → ¥ surge → UST repatriation; intervention whipsaw', ll: 'Funding-CB signal leads by days; intervention is reactive (lags the move)' },
  { s: 'USD/CNY — the pressure point', p: 'CNY/CNH · PBOC fix', dr: 'The structural slow-seller. PBOC manages the daily fix and intervenes via state banks — flows that do not show in TIC or BIS data. China is diversifying via reserve drawdown, gold, and local-currency bonds rather than a fire-sale.', sens: 'Rate-diff Mod · Carry funding leg · USD-vuln High', kpis: 'PBOC daily fix · CNH basis · China TIC holdings · official gold adds', leads: 'Fix cuts · widening CNH-CNY gap · state-bank dollar selling', risks: '2015-style devaluation shock; opaque intervention (no free feed)', ll: 'Fix is the policy lead; TIC confirms the structural decline with a lag' },
  { s: 'USD/CHF — the clean haven', p: 'CHF · funding leg', dr: 'The franc is the cleanest non-dollar haven — the G10 outperformer this cycle and a classic funding-currency that appreciates violently in carry unwinds (+9% over the 10 months to Apr 2008). SNB tolerates strength when imported inflation is the worry.', sens: 'Rate-diff Mod · Carry funding leg · USD-vuln Low', kpis: 'USD/CHF · SNB policy rate (0.0%) · sight deposits · CFTC CHF', leads: 'Risk-off spikes · SNB rhetoric on the franc', risks: 'SNB intervention to cap strength; negative-rate return', ll: 'Coincident haven; leads other funding legs in a squeeze' },
  { s: 'EUR/USD — the anti-dollar', p: 'EUR · ECB ~2.4%', dr: 'The dollar’s mirror and the deepest liquid alternative. A funding leg whose simultaneous hike with the BoJ is the carry-compression tail; soft while the ECB lags a hawkish Fed.', sens: 'Rate-diff High · Carry mixed · USD-vuln Mod', kpis: 'EUR/USD · ECB rate path · Bund-UST spread · EUR basis', leads: 'ECB-vs-Fed differential · euro-area data surprises', risks: 'Synchronized ECB+BoJ hike compresses carry at three legs at once', ll: 'Rate-differential leads; positioning amplifies' },
