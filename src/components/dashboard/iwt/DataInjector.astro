---
/**
 * DataInjector — Reads IWT JSON data at build time and injects it as
 * window.__IWT_DATA__ so the React data-loader.js can access it synchronously.
 *
 * This replaces both:
 *   - Express server's runtime injection (serve-public.js)
 *   - bake-data.js build-time injection
 *
 * For Astro, we read the JSON files during the server-side render phase
 * and output a <script> tag with the data inline.
 */
import fs from 'node:fs';
import path from 'node:path';

// In the Astro build, we need to locate the IWT data files.
// They'll be copied into the vegaready project at build time via a script,
// or fetched from the IWT Cloudflare Worker API.
// For now, use the data baked into a static JSON bundle.

let dataPayload = '{}';

try {
  // Try to read from a pre-built data bundle (created by the build script)
  const bundlePath = path.resolve('./src/data/iwt-bundle.json');
  if (fs.existsSync(bundlePath)) {
    dataPayload = fs.readFileSync(bundlePath, 'utf8');
  }
} catch (e) {
  console.warn('[DataInjector] Could not load data bundle:', e.message);
}
---

<script is:inline set:html={`window.__IWT_DATA__ = ${dataPayload};`}></script>
