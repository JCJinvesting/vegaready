---
/**
 * DataInjector — Reads IWT JSON data at build time and injects it as
 * window.__IWT_DATA__ so the React data-loader.js can access it synchronously.
 *
 * This replaces both:
 *   - Express server's runtime injection (serve-public.js)
 *   - bake-data.js build-time injection
 *
 * For Astro, we read the JSON files during the server-side render phase
 * and output a <script> tag with the data inline.
 */
// Embed the IWT data bundle via a build-time JSON import. Vite parses and
// inlines it into the compiled output, so window.__IWT_DATA__ is populated in
// BOTH static prerender and Cloudflare Workers SSR.
//
// Previously this used fs.readFileSync('./src/data/iwt-bundle.json'), which
// silently returned '{}' under the Workers runtime introduced by the
// "Astro 6 + @astrojs/cloudflare 13" upgrade — node:fs can't read a src/ file
// that isn't shipped inside the Worker bundle — which left every dashboard
// scope (War Room, Gulf, Casualties, Iran, US, Israel, Analytics, Sources…)
// blank even though the data was still committed to the repo.
import iwtData from '../../../data/iwt-bundle.json';

const dataPayload = JSON.stringify(iwtData);
---

<script is:inline set:html={`window.__IWT_DATA__ = ${dataPayload};`}></script>
