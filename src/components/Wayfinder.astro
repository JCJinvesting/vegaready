---
// Wayfinder (Brand Kit §4e/§4f): crumb trail + always-visible sibling rail.
// Backward-looking: the trail says where you are. Forward-looking: the rail shows
// every lateral/forward move from here, one click away, no dropdowns, no JS required.
//   trail: [{ label, href? }]      — last item = current location (omit href)
//   rail:  [{ label, href, current?, tag? }] — siblings/children; tag for honesty ('in build')
//   deck:  true on pages WITHOUT a secnav/laydeck (hub, landing, stubs) — the Wayfinder
//          then becomes the page's ONE frozen bar (kit §4f) and carries the ↑ Top chip.
const { trail = [], rail = [], deck = false } = Astro.props;
---
<nav class={`wayfinder${deck ? ' deck' : ''}`} aria-label="You are here">
  <div class="wrap wf-wrap">
    {deck && <a class="wf-top" href="#" aria-label="Back to top">↑ Top</a>}
    <span class="wf-trail">
      {trail.map((c, i) => (
        <span class="wf-seg">
          {c.href ? <a href={c.href}>{c.label}</a> : <b aria-current="location">{c.label}</b>}
          {i < trail.length - 1 && <span class="wf-sep" aria-hidden="true">▸</span>}
        </span>
      ))}
    </span>
    {rail.length > 0 && (
      <span class="wf-rail">
        {rail.map((s) => (
          <a class={`wf-pill${s.current ? ' on' : ''}`} href={s.href} aria-current={s.current ? 'page' : undefined}>
            {s.label}{s.tag && <span class="wf-tag">{s.tag}</span>}
          </a>
        ))}
      </span>
    )}
  </div>
</nav>
{deck && <script is:inline>(function(){var raf=null;function upd(){document.body.classList.toggle('scrolled',window.scrollY>480);}window.addEventListener('scroll',function(){if(raf)return;raf=requestAnimationFrame(function(){raf=null;upd();});},{passive:true});upd();})();</script>}
<style>
  .wayfinder{border-bottom:1px solid var(--cardline);background:color-mix(in srgb, var(--card) 55%, transparent)}
  .wayfinder.deck{position:sticky;top:0;z-index:50;background:color-mix(in srgb, #000 12%, var(--canvas));backdrop-filter:saturate(1.1) blur(6px)}
  .wf-wrap{display:flex;align-items:center;gap:18px;min-height:34px;padding-top:4px;padding-bottom:4px}
  .wf-top{flex:none;font-family:'Lora',serif;font-size:10px;font-weight:700;letter-spacing:.09em;text-transform:uppercase;color:var(--muted);text-decoration:none;border:1px solid var(--cardline);border-radius:999px;padding:3px 11px;margin-right:-6px;opacity:0;visibility:hidden;transition:opacity .2s ease-out,color .15s ease-out,border-color .15s ease-out}
  :global(body.scrolled) .wf-top{opacity:1;visibility:visible}
  .wf-top:hover{color:var(--ink);border-color:color-mix(in srgb, var(--eyeb) 38%, transparent)}
  .wf-trail{display:flex;align-items:center;gap:7px;flex:none;font-family:'Lora',serif;font-size:10.5px;font-weight:700;letter-spacing:.12em;text-transform:uppercase;white-space:nowrap}
  .wf-seg{display:inline-flex;align-items:center;gap:7px}
  .wf-trail a{color:var(--muted);text-decoration:none;transition:color .15s ease-out}
  .wf-trail a:hover{color:var(--ink)}
  .wf-trail b{color:var(--ink);font-weight:700}
  .wf-sep{color:var(--latent);font-size:9px}
  .wf-rail{display:flex;align-items:center;gap:4px;margin-left:auto;overflow-x:auto;scrollbar-width:none;-webkit-overflow-scrolling:touch}
  .wf-rail::-webkit-scrollbar{display:none}
  .wf-pill{flex:none;font-family:'Lora',serif;font-size:10px;font-weight:600;letter-spacing:.09em;text-transform:uppercase;color:var(--muted);text-decoration:none;padding:3px 11px;border:1px solid transparent;border-radius:999px;white-space:nowrap;transition:color .15s ease-out,border-color .15s ease-out}
  .wf-pill:hover{color:var(--ink);border-color:var(--cardline)}
  .wf-pill.on{color:var(--ink);border-color:color-mix(in srgb, var(--eyeb) 38%, transparent);background:color-mix(in srgb, var(--eyeb) 12%, transparent)}
  .wf-tag{font-size:7.5px;font-weight:700;letter-spacing:.1em;color:var(--latent);border:1px dashed color-mix(in srgb, var(--latent) 40%, transparent);border-radius:3px;padding:1px 4px;margin-left:6px;vertical-align:1px}
  @media(max-width:760px){
    .wf-wrap{gap:10px}
    .wf-trail{font-size:9.5px;letter-spacing:.09em}
    .wf-seg:first-child:not(:last-child):not(:nth-last-child(2)){display:none}
  }
</style>
