  { k: 'Central-bank swap lines / FIMA', w: 'Official USD-liquidity backstops that cap funding stress; activation is the key relief catalyst.', m: null, note: 'status: standing (not drawn)' },
  { k: 'IMF lending pipeline', w: 'Sovereign backstop; program news materially re-prices distressed sovereigns.', m: null, note: 'event-driven' },
