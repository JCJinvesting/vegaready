      <div class="track-side"><div class="lvbox"><div class="lv-h">Leading-indicator value</div><div class="lv-v">{t.lv[0]}</div><p>{t.lv[1]}</p></div><div class="srcline"><b>Sources</b> <span class="dconf" style="border-color:var(--cardline)">{t.tier}</span> {t.src}</div></div>
    </div>
