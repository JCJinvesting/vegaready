  { sc: 'Commodity shock', sov: 'Exporters benefit / importers hurt', corp: 'Energy & input-cost sectors diverge', ig: 'Sector-mix dependent', hy: 'Energy-heavy HY swings most' },
];

// ── sovereign / funding channel (Part D5) ── live where available
const fundingChannel = [
  { k: 'EM sovereign spreads (EMBI)', w: 'The price of EM sovereign risk — a lead for EM corporate & global risk-off.', m: byNo['2.1'], note: 'EMBI GD · EMB proxy' },
  { k: 'Gulf official UST recycling', w: 'Gulf official selling of Treasuries — the petrodollar-recycling channel reversing.', m: byNo['2.3'], note: 'TIC data' },
