// ── catalysts ──
const activeCats = CATALYSTS.filter(c => c.state === 'active');
const monCats = CATALYSTS.filter(c => c.state !== 'active');

const sources = [
  ['FRED ICE BofA OAS', 'fred.stlouisfed.org/series/BAMLC0A0CM'], ['FRED HY OAS', 'fred.stlouisfed.org/series/BAMLH0A0HYM2'],
  ['Moody’s default/transition', 'moodys.com'], ['S&P credit research', 'spglobal.com/ratings/en/research/credit-market-research'],
  ['Fitch transition & default', 'fitchratings.com'], ['ICI flows', 'ici.org/research/stats/flows'],
