---
import '../styles/desk.css';
import '../styles/desk-content.css';
import '../styles/desk-v2.css';
import '../styles/skin-brass.css';
import { cards, cascade, winnersLosers, takeaways } from '../data/analysis/credit.js';
import { metrics, lastUpdated } from '../data/analysis/watchmetrics.js';
import { CATALYSTS, STATE_LABEL } from '../data/catalysts';
import Wayfinder from './Wayfinder.astro';
import * as feed from '../data/feeds/credit.js';

const { mode = 'analyst' } = Astro.props;

// Wayfinder (kit §4e): trail = where you are; rail = every lateral move from here.
const wfTrail = mode === 'layman'
  ? [{ label: 'Layman', href: '/layman' }, { label: 'Markets', href: '/markets' }, { label: 'Credit' }]
  : [{ label: 'Markets', href: '/markets' }, { label: 'Credit' }];
const wfRail = mode === 'layman'
  ? [
      { label: 'Equities', href: '/layman/markets/equities' },
      { label: 'Credit', href: '/layman/markets/credit', current: true },
      { label: 'All editions', href: '/layman' },
    ]
  : [
      { label: 'Equities', href: '/markets/equities' },
      { label: 'Credit', href: '/markets/credit', current: true },
      { label: 'Dollar & FX', href: '/markets/gold-fx' },
      { label: 'Commodities', href: '/markets/energy' },
      { label: 'Crypto', href: '/markets/crypto' },
      { label: 'Cross-asset', href: '/markets/cross-asset' },
    ];

const byNo = {}; metrics.forEach(m => { if (m.signalNo) byNo[m.signalNo] = m; });
const fmt = (m) => (m ? `${m.value}${m.unit && m.unit !== 'count' ? ' ' + m.unit : ''}` : '—');
const wvc = (m) => (m && m.status === 'critical' ? 'neg' : m && m.status === 'alert' ? 'warn' : m && m.status === 'watch' ? 'latent' : '');
const confCls = (c) => { const u = (c || '').toUpperCase(); return u.startsWith('HIGH') ? 'high' : u.startsWith('LOW') ? 'low' : 'medium'; };
const roleCls = (r) => { const u = (r || '').toUpperCase(); return u.startsWith('BENEF') || u.startsWith('WINNER') ? 'win' : u.startsWith('LOSER') || u.startsWith('CASUAL') ? 'lose' : 'mix'; };
const dataThrough = lastUpdated || 'recent';
// ── live credit feed (CW2): compression headline + OAS chips ──
const comp = feed.compression();
const creg = feed.regime();
const chipHY = feed.chipFor(feed.tile('hyOas').state);

// live credit-regime instruments (registry §2 = credit/funding)
const eq = [{ k: 'EM sovereign · EMBI', m: byNo['2.1'] }, { k: 'Flight-to-quality cash', m: byNo['2.2'] }, { k: 'Gulf UST recycling', m: byNo['2.3'] }];

// ── glossary ──
const gloss = [
  ['OAS', 'Option-Adjusted Spread — a bond’s extra yield over Treasuries after stripping out optionality; the market price of credit risk.'],
  ['IG', 'Investment Grade — higher-quality issuers (BBB– and above); spreads driven more by rates than default.'],
  ['HY', 'High Yield ("junk") — sub-investment-grade (BB+ and below); default-cycle sensitive.'],
  ['Distress ratio', 'Share of high-yield bonds trading at distressed spreads (conventionally ≥1,000 bps over Treasuries) — an early stress gauge.'],
  ['Fallen angel', 'A bond downgraded from Investment Grade into High Yield — a forced-seller, migration-risk event.'],
  ['Rising star', 'A bond upgraded from High Yield into Investment Grade — the benign opposite of a fallen angel.'],
  ['Spread duration', 'Sensitivity of a bond’s price to a move in its spread; DTS (duration × spread) is the standard risk budget.'],
  ['Recovery rate', 'How much creditors get back after a default; pairs with the default rate to set expected loss.'],
  ['Carry breakeven', 'How much the spread can widen before the carry cushion is wiped out over a horizon.'],
  ['EMBI', 'Emerging Markets Bond Index — the price of EM sovereign USD-debt risk; a lead for EM corporate and global risk-off.'],
  ['Cross-currency basis', 'The cost of swapping into dollars offshore; a deeply negative basis signals a dollar squeeze.'],
  ['MMF', 'Money-Market Fund — where cash hides in risk-off; surging MMF inflows are a funding-demand tell.'],
  ['CCC', 'The lowest high-yield rating band; distress-driven, illiquid, recovery-sensitive — the cycle’s sharp end.'],
];
const G = {}; gloss.forEach(([t, d]) => { G[t] = d; });
const gl = (term, label) => `<span class="gloss" data-def="${G[term]}">${label || term}</span>`;

// ── competing drivers (attribution buckets) ──
const drivers = [
  { d: 'Rates & duration', b: 'primary', n: 'IG is long-duration — rate moves dominate the high-grade spread' },
  { d: 'Default & leverage cycle', b: 'material', n: 'The slow anchor; coverage + the maturity wall lead defaults' },
  { d: 'Dollar-funding / liquidity', b: 'material', n: 'The sovereign/funding transmission belt — basis, MMF, swap lines' },
  { d: 'Positioning / flows', b: 'secondary', n: 'Technicals can drive spreads for weeks independent of fundamentals' },
  { d: 'Active catalyst (Iran–Gulf)', b: 'secondary', n: 'Overlay — see §Catalysts' },
  { d: 'Residual / unexplained', b: 'uncertain', n: 'Named, never assumed zero' },
];

const read30 = [
  'Spreads are <b>calm but stretched</b>: IG and HY OAS sit in the low percentiles of their own history — you’re not paid much extra for credit risk right now.',
  'Stress shows <b>inside the market first</b> — watch ratings migration, the distress ratio and CCC share before the headline spread moves.',
  'The Iran–Gulf catalyst is a <b>sovereign/funding story, not yet an IG/HY corporate one</b> — EMBI and dollar-funding reprice while US corporate spreads stay contained.',
  '<b>Dollar liquidity is the tell</b> — MMF inflows and the cross-currency basis lead; a swap-line activation would cap the stress.',
  '<b>Credit leads equities</b> — if HY OAS breaks wider, equities tend to follow. The durable frame below stands whether or not the catalyst is live.',
];
const falsifiers = [
  'HY OAS breaks out of its low percentile and the distress ratio climbs — the cycle is turning.',
  'Ratings migration flips — downgrades outrun upgrades and fallen-angel volume accelerates.',
  'The maturity wall + eroding interest coverage force refinancing stress at higher rates.',
  'The Gulf funding channel escalates — EMBI blows out, the basis turns deeply negative, and no swap-line relief arrives.',
];

// ── value types & source tiers (Part E) ──
const valueTypes = [
  ['Baseline', 'long-run norm / historical reference'], ['Current', 'latest observed print'],
  ['Nowcast', 'model estimate of the present from incomplete data'], ['Forecast', 'forward agency/consensus estimate'],
  ['Scenario', 'conditional “if-then” path'],
];
const sourceTiers = [
  ['T1', 'Primary / official', 'FRED ICE BofA OAS · CFTC · Fed swap lines · FINRA TRACE · SIFMA · ICI'],
  ['T2', 'Rating-agency / analytic', 'Moody’s · S&P Global · Fitch default/transition · Damodaran'],
  ['T3', 'Editorial / commentary', 'FT · Economist · sell-side credit strategy'],
  ['T4', 'Derived / VegaReady model', 'default-implied gap · net-effect attribution · residual'],
];

// ── durable topic specs (Part B) ──
const T = {
  regime: { eye: '§1', h: 'Spread Regime', q: 'Are spreads rich or cheap, and which way?', fresh: 'daily · close', chart: 'regime',
    lead: `Spreads are the price of credit risk; their <b>level-vs-history and direction</b> are the fastest read on the cycle. The level alone is <i>coincident</i> — it prices, it doesn’t predict; direction + percentile lead moderately.`,
    kpi: [['IG OAS', '—', 'feed pending', null], ['HY OAS', '—', 'feed pending', null], ['HY percentile vs 10y', '—', 'feed pending', null], [gl('EMBI', 'EM sovereign (EMBI)'), byNo['2.1'] ? fmt(byNo['2.1']) : '—', 'current', 'medium']],
    track: [['IG OAS (ICE BofA, FRED BAMLC0A0CM)', 'M'], [gl('HY', 'HY OAS') + ' (FRED BAMLH0A0HYM2)', 'M'], ['Percentile vs 1/3/5/10y history', 'M'], ['Realized vol of daily OAS changes', 'N'], ['IG–HY compression / decompression', 'N']],
    lv: ['Direction: moderate · Level: coincident', 'Widening from tight levels often precedes credit-event clusters; the level itself only prices risk.'],
    src: 'FRED ICE BofA OAS (daily, close) · EMBI (live registry)', tier: 'T1',
    feed: [['IG / HY OAS + percentile', 'FRED BAMLC0A0CM / BAMLH0A0HYM2'], ['Realized OAS vol', 'computed from FRED daily']] },
  structure: { eye: '§2', h: 'Internal Structure', q: 'Is a benign index masking stress inside?', fresh: 'daily · agency periodic', chart: 'structure',
    lead: `A calm headline spread can hide deterioration <b>inside</b> the market. Internal stress — rising downgrades, a climbing ${gl('Distress ratio', 'distress ratio')}, growing ${gl('CCC')} share — typically <b>leads</b> index-level widening. One of the strongest durable leading signals here.`,
    kpi: [['Downgrade / upgrade ratio', '—', 'feed pending', null], ['Distress ratio', '—', 'feed pending', null], ['CCC share of HY', '—', 'feed pending', null], [gl('Fallen angel', 'Fallen angels (par)'), '—', 'feed pending', null]],
    track: [['Upgrade vs downgrade ratio', 'M'], [gl('Distress ratio', 'Distress ratio') + ' (≥1,000 bps)', 'M'], [gl('CCC') + '-and-below share of HY', 'M'], [gl('Fallen angel', 'Fallen-angel') + ' / ' + gl('Rising star', 'rising-star') + ' volume', 'N'], ['Full ratings transition matrix', 'N']],
    lv: ['High (leading)', 'Internal deterioration leads index-level widening and default upturns — stress shows inside before it reaches the headline.'],
    src: 'FRED sub-index OAS (daily) · Moody’s / S&P / Fitch transition & default studies (annual + interim)', tier: 'T1/T2',
    feed: [['Migration / distress / CCC share', 'Moody’s · S&P · Fitch'], ['BBB/BB/CCC OAS', 'FRED BAMLC0A4CBBB / BAMLH0A1HYBB / BAMLH0A3HYC']] },
  valuation: { eye: '§3', h: 'Valuation & Fair Value', q: 'Am I paid for the risk I’m taking?', fresh: 'daily OAS · periodic assumptions', chart: 'valuation',
    lead: `The gap between <b>market OAS</b> and a <b>default-implied</b> spread — expected default × (1 − ${gl('Recovery rate', 'recovery')}) — plus ${gl('Carry breakeven', 'carry breakevens')}. Extreme readings signal <i>asymmetry, not timing</i>: this is a margin-of-safety gauge, explicitly valuation, not a catalyst.`,
    kpi: [['OAS vs default-implied', '—', 'feed pending', null], ['Spread per turn of leverage', '—', 'feed pending', null], ['Carry breakeven (1y)', '—', 'feed pending', null], ['Implied default rate', '—', 'feed pending', null]],
    track: [['Market OAS − default-implied (breakeven) spread', 'M'], ['Carry breakeven = OAS ÷ spread-duration', 'M'], ['Spread-per-turn-of-net-leverage by cohort', 'N'], ['Recovery-rate sensitivity', 'N']],
    lv: ['Moderate, mean-reverting', 'Extreme rich/cheap flags asymmetry; not a timing signal. Assumptions (recovery, horizon) shown inline.'],
    src: 'FRED OAS (daily) · Moody’s/S&P/Fitch default & recovery · Damodaran default spreads', tier: 'T2/T4',
    feed: [['Default-implied spread', 'agency default × (1−recovery)'], ['Spread-per-turn-of-leverage', 'issuer fundamentals feed']] },
  fundamentals: { eye: '§4', h: 'Fundamental Drivers', q: 'What’s the slow anchor under spreads?', fresh: 'agency periodic · SIFMA monthly', chart: 'fundamentals',
    lead: `The slow-moving anchor: default & recovery, net leverage, interest coverage, the <b>maturity wall</b>, and the earnings → credit link. <b>Coverage and the maturity wall lead</b> (refinancing pressure builds first); the <b>realized default rate lags</b> (it confirms the cycle). This is where “default rate is rising so sell” reasoning fails.`,
    kpi: [['HY default rate (TTM)', '—', 'feed pending', null], ['Forecast default rate', '—', 'feed pending', null], ['Interest coverage', '—', 'feed pending', null], ['Near-term maturity wall', '—', 'feed pending', null]],
    track: [['Trailing + forecast HY default rate', 'M'], ['Interest coverage (EBIT/EBITDA-to-interest)', 'M'], ['Maturity wall by year × rating', 'M'], ['Net debt/EBITDA', 'N'], [gl('Recovery rate', 'Recovery') + ' by seniority', 'N']],
    lv: ['Coverage & wall lead · default rate lags', 'Refinancing pressure builds ahead of defaults; the realized rate confirms, it doesn’t predict.'],
    src: 'Moody’s / S&P / Fitch default & recovery (annual + interim) · SIFMA issuance/maturity (monthly)', tier: 'T2/T1',
    feed: [['Default rate (trailing + forecast)', 'Moody’s / S&P / Fitch'], ['Maturity wall', 'SIFMA US corporate statistics']] },
  factors: { eye: '§6', h: 'Credit Factors', q: 'What style is being rewarded — and where’s the risk?', fresh: 'structural · weekly perf', chart: null,
    lead: `Decomposes credit into <b>carry</b> (harvesting spread), <b>quality</b> (up vs down in quality) and <b>${gl('Spread duration', 'spread-duration')}</b> (DTS). Low value as a forecaster; high value as a <b>risk-budget</b> lens — a DTS spike flags where the book is most exposed before a spread move, not whether one is coming.`,
    kpi: [['Carry (OAS − expected loss)', '—', 'feed pending', null], ['Quality factor (IG−HY)', '—', 'feed pending', null], ['Book DTS', '—', 'feed pending', null], ['Factor drawdown', '—', 'feed pending', null]],
    track: [['Carry = OAS net of expected losses', 'M'], [gl('Spread duration', 'Spread-duration / DTS') + ' of the book', 'M'], ['Quality factor (IG-vs-HY or BB-vs-CCC)', 'N'], ['Factor momentum / drawdowns', 'N']],
    lv: ['Risk-budgeting, not forecasting', 'DTS shows where exposure is concentrated; it doesn’t time the move.'],
    src: 'FRED OAS (daily) · ETF duration/spread analytics (LQD/HYG/JNK issuer pages)', tier: 'T1',
    feed: [['Carry / DTS / factor payoff', 'FRED OAS + ETF analytics']] },
  positioning: { eye: '§7', h: 'Positioning & Flows', q: 'Can technicals override the fundamentals?', fresh: 'weekly', chart: 'positioning',
    lead: `Demand/supply technicals — fund & ETF flows, ${gl('MMF')} cash, CDS positioning, primary issuance, dealer inventories. <b>High value over short horizons</b>: flows can drive spreads for weeks independent of fundamentals, and crowded positioning sets up sharp reversals. The page’s main “technical overrides fundamental” warning.`,
    kpi: [['IG bond-fund flows', '—', 'feed pending', null], ['HY bond-fund flows', '—', 'feed pending', null], [gl('MMF', 'Flight-to-quality cash'), byNo['2.2'] ? fmt(byNo['2.2']) : '—', 'current', 'medium'], ['Primary issuance', '—', 'feed pending', null]],
    track: [['ICI bond-fund flows (IG vs HY)', 'M'], ['Primary issuance volume + oversubscription', 'M'], ['Dealer inventory / TRACE volume & breadth', 'N'], ['CFTC CDS-index positioning', 'N']],
    lv: ['High (short horizon)', 'Flows/positioning can move spreads for weeks; crowding precedes reversals.'],
    src: 'ICI flows (weekly) · CFTC COT (Tue→Fri) · SIFMA issuance (monthly) · FINRA TRACE', tier: 'T1',
    feed: [['IG/HY fund flows', 'ICI (weekly, estimated)'], ['Issuance / TRACE', 'SIFMA · FINRA']] },
  crossasset: { eye: '§8', h: 'Cross-Asset Linkages', q: 'Does the rest of the macro complex confirm credit?', fresh: 'daily', chart: null,
    lead: `How credit co-moves with the macro complex — equities (HY ~ equity stress), rates and the curve, the dollar (funding channel). <b>Caveat:</b> these correlations are <i>regime-dependent and not causal</i> — they spike toward 1 in stress, exactly when diversification is assumed. We show the rolling correlation so the regime dependence is visible.`,
    kpi: [['US Dollar (DXY)', byNo['1.2'] ? fmt(byNo['1.2']) : '—', 'current', 'medium'], ['Stock–bond correlation', byNo['9.2'] ? fmt(byNo['9.2']) : '—', 'current', 'medium'], ['EM equity vol (VXEEM)', byNo['9.3'] ? fmt(byNo['9.3']) : '—', 'current', 'medium'], ['MOVE (rate vol)', '—', 'feed pending', null]],
    track: [['HY OAS vs equity volatility + rolling correlation', 'M'], ['OAS vs Treasury level & 2s10s curve', 'M'], ['MOVE (rate-vol) regime', 'N'], ['OAS vs broad USD', 'N']],
    lv: ['Moderate, unstable', 'Cross-asset divergences can lead; correlations converge to 1 in stress — never asserted as causal.'],
    src: 'FRED HY/IG OAS (daily) · ICE MOVE · live registry (DXY, corr, VXEEM)', tier: 'T1' },
};
const chartCap = { regime: 'Spread regime — OAS vs its percentile band', structure: 'Internal stress — distress ratio vs threshold', valuation: 'Valuation — market OAS vs default-implied', fundamentals: 'Default rate — trailing + forecast', positioning: 'Flows — net fund flows, IG vs HY' };

// ── cohort library (Part C) ──
const ratingsBuckets = [
  { s: 'IG (overall)', p: 'LQD · CDX IG', dr: 'High-quality issuers, capital-markets access, low default base rate; spread is rate & macro beta, not idiosyncratic default', sens: 'Rates High · Cycle Mod · Commod Low–Mod · USD Low', kpis: 'IG OAS + percentile · interest coverage · net leverage · downgrade/upgrade ratio', leads: 'Downgrade ratio rising · BBB share of IG · coverage erosion', risks: 'Rate shock · large fallen-angel migration · mega-issuer event', ll: 'Lags the cycle; leads via rate sensitivity in rate-driven episodes' },
  { s: 'BBB', p: 'LQD (heavy) · CDX IG', dr: 'Lowest IG rung; the fallen-angel frontier; large share of the IG index; refinancing-sensitive', sens: 'Rates High · Cycle High (migration) · Commod sector-dep · USD Low–Mod', kpis: 'BBB OAS · BBB share of IG · downgrade-to-HY pipeline · coverage', leads: 'Fallen-angel watch / negative outlooks · coverage near covenant', risks: 'Downgrade to HY (forced sellers) · cliff risk', ll: 'Leads HY stress via migration; lags pure rate moves' },
  { s: 'BB', p: 'HYG/JNK · CDX HY', dr: 'Top of HY; crossover buyers; better access than lower HY; compression beneficiary in risk-on', sens: 'Rates Mod · Cycle High · Commod sector-dep · USD Mod', kpis: 'BB OAS · rising-star pipeline · HY default rate · coverage', leads: 'Rising-star upgrades · BB–CCC compression · primary access', risks: 'Re-entry to IG fails · sentiment gap risk', ll: 'Coincident-to-leading in risk-on; leads compression' },
  { s: 'B', p: 'HYG/JNK · CDX HY', dr: 'Core HY; default-cycle sensitive; refinancing-dependent; earnings-leverage exposed', sens: 'Rates Mod · Cycle High · Commod sector-dep · USD Mod', kpis: 'B OAS · HY default rate (trailing+forecast) · coverage · maturity-wall share', leads: 'Maturity-wall pressure · coverage deterioration · primary-market closure', risks: 'Refinancing wall · margin compression · liquidity gaps', ll: 'Coincident with the cycle; the maturity wall leads defaults' },
  { s: 'CCC', p: 'JNK/HYG tail · CDX HY', dr: 'Deepest HY; distress-driven; idiosyncratic; recovery-rate sensitive; thin liquidity', sens: 'Rates Low · Cycle Very High · Commod sector-dep · USD High (EM-linked)', kpis: 'CCC OAS · distress ratio · CCC share of HY · recovery rate · default rate', leads: 'Distress-ratio climb · CCC-share rise · access shutdown', risks: 'Default & low recovery · liquidity evaporation · forced selling', ll: 'Leads the default cycle (distress precedes default); price lags fundamentals when illiquid' },
];
const sectors = [
  { s: 'Banks / Financials', p: 'LQD · CDX IG', dr: 'Funding cost, net interest margin, asset quality, capital ratios; systemic linkage; deposit stability', sens: 'Rates High · Cycle High · Commod Low · USD Mod', kpis: 'Credit-loss provisioning · capital ratios · funding spreads · sector OAS', leads: 'Funding-spread widening · deposit outflows · cross-currency basis stress', risks: 'Deposit run / funding freeze · rate-mismatch losses · contagion', ll: 'Leads broad credit in funding-stress episodes — the transmission node' },
  { s: 'Energy', p: 'HYG/JNK · CDX HY', dr: 'Commodity-price-driven cash flow; capex cyclicality; reserve coverage; high HY weight historically', sens: 'Rates Low–Mod · Cycle High · Commod Very High · USD Mod', kpis: 'Oil/gas price · sector OAS · FCF/coverage · sector default rate', leads: 'Commodity-price moves · rig/capex signals · hedging roll-offs', risks: 'Commodity collapse → default cluster · stranded-asset risk', ll: 'Leads HY default cycles when commodity-driven; lags when shock is exogenous' },
  { s: 'Real Estate', p: 'LQD · HYG', dr: 'Property income, cap rates, refinancing reliance, rate-sensitivity of valuations; CRE vs residential', sens: 'Rates Very High · Cycle High · Commod Low · USD Low–Mod', kpis: 'Sector OAS · refi/maturity wall · occupancy/NOI · coverage', leads: 'Refi-wall pressure · cap-rate moves · vacancy/NOI · lender pullback', risks: 'Refinancing at higher rates · valuation markdowns · lender withdrawal', ll: 'Leads when rate-driven (refi stress precedes defaults); lags broad cycle otherwise' },
  { s: 'Leveraged Tech / Telecom', p: 'HYG/JNK · CDX HY', dr: 'High leverage, large maturity towers, M&A/LBO history, capex intensity, disruption risk', sens: 'Rates Mod–High · Cycle High · Commod Low · USD Mod', kpis: 'Net leverage · maturity wall · coverage · sector OAS · FCF', leads: 'Maturity-wall concentration · coverage erosion · primary access · disruption', risks: 'Refinancing wall on heavy debt · disruption · aggressive financial policy', ll: 'Leads HY stress via concentrated maturity walls; idiosyncratic-event driven' },
  { s: 'Retail', p: 'HYG/JNK · CDX HY', dr: 'Consumer-spend dependent, thin margins, lease/inventory obligations, e-commerce disruption', sens: 'Rates Low–Mod · Cycle Very High · Commod Mod · USD Low–Mod', kpis: 'Same-store/consumer-spend · sector OAS · coverage · sector default rate', leads: 'Consumer-spending data · margin compression · holiday signals · vendor-financing stress', risks: 'Demand shock · secular disruption · vendor/liquidity squeeze', ll: 'Coincident-to-leading on the consumer cycle; early margin compression leads defaults' },
  { s: 'EM Sovereign / Quasi-sovereign', p: 'EMB · EMBI GD', dr: 'External funding reliance, USD-debt burden, reserves, IMF backstop, commodity-export dependence', sens: 'Rates High · Cycle High · Commod High · USD Very High', kpis: gl('EMBI', 'EMBI') + ' spread + percentile · FX reserves · current account · sovereign rating/CDS', leads: 'USD strength · cross-currency basis · reserve drawdown · IMF program news', risks: 'Dollar squeeze · capital flight · default/restructuring', ll: 'Leads corporate EM and global risk-off when USD-funding-driven' },
];
// sortable sensitivity matrix (durable)
const cohortMatrix = [
  { s: 'IG', rate: ['High', 5, 'hi'], cyc: ['Moderate', 2, 'mid'], usd: ['Low', 1, 'lo'] },
  { s: 'BBB', rate: ['High', 5, 'hi'], cyc: ['High', 4, 'hi'], usd: ['Low–Mod', 2, 'mid'] },
  { s: 'BB', rate: ['Moderate', 3, 'mid'], cyc: ['High', 4, 'hi'], usd: ['Moderate', 3, 'mid'] },
  { s: 'B', rate: ['Moderate', 3, 'mid'], cyc: ['High', 4, 'hi'], usd: ['Moderate', 3, 'mid'] },
