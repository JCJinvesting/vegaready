</div></section>

<!-- §1–§4 durable spine -->
{topicOrder.map((id) => { const t = T[id]; return (
  <section class="dsec" id={id}><div class="wrap">
    <div class="sec-head"><div><div class="eyebrow">{t.eye} · {t.q}</div><h2>{t.h}.</h2></div><span class="fresh-tag">{t.fresh}</span></div>
