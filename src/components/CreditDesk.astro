  { s: 'EM sovereign', rate: ['High', 5, 'hi'], cyc: ['High', 4, 'hi'], usd: ['Very high', 5, 'hi'] },
];

// ── scenario matrix (Part D2) ──
const scenRows = [
  { sc: 'Risk-off / flight-to-quality', sov: 'EM sovereign spreads widen (USD-funding); DM benefits', corp: 'Spreads widen broadly; quality outperforms', ig: 'Relatively resilient (rate-beta can help)', hy: 'Underperforms; CCC/distress most exposed' },
  { sc: 'Rate shock higher', sov: 'EM with USD debt pressured; DM rate-sensitive', corp: 'Refinancing-sensitive issuers pressured', ig: 'Most exposed (long duration)', hy: 'Less rate-sensitive but refi wall bites' },
