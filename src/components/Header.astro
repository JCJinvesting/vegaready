---
const navItems = [
  { href: '/', label: 'Home' },
  { href: '/dashboard', label: 'Dashboard' },
  { href: '/markets', label: 'Markets' },
  { href: '/transmission', label: 'Transmission' },
  { href: '/exposure', label: 'Exposure' },
  { href: '/outlook', label: 'Outlook' },
  { href: '/connections', label: 'Connections' },
  { href: '/profits', label: 'Who Profits' },
  { href: '/briefings', label: 'Briefings' },
  { href: '/about', label: 'About' },
];
const currentPath = Astro.url.pathname;
---

<header>
  <div class="gradient-bar"></div>
  <nav>
    <a href="/" class="logo">
      <span class="logo-mark">V</span>
      <span class="logo-text">VegaReady</span>
    </a>
    <div class="nav-links">
      {navItems.map(item => (
        <a
          href={item.href}
          class:list={['nav-link', { active: currentPath === item.href || (item.href !== '/' && currentPath.startsWith(item.href)) }]}
        >
          {item.label}
        </a>
      ))}
    </div>
    <a href="/dashboard" class="nav-cta">
      <span class="cta-dot"></span>
      Live Dashboard
    </a>
  </nav>
</header>

<style>
  .gradient-bar {
    height: 2px;
    background: var(--gradient-bar);
  }
  header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(6, 10, 18, 0.85);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-bottom: 1px solid var(--border);
  }
  nav {
    max-width: var(--max-width);
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 2rem;
    height: 56px;
  }
  .logo {
    display: flex;
    align-items: center;
    gap: 10px;
    color: var(--text);
    font-weight: 700;
  }
  .logo:hover { opacity: 1; }
  .logo-mark {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    background: var(--cyan);
    color: var(--bg);
    font-family: var(--font-mono);
    font-weight: 800;
    font-size: 14px;
    border-radius: 6px;
    letter-spacing: -0.5px;
  }
  .logo-text {
    font-family: var(--font-mono);
    font-size: 15px;
    font-weight: 700;
    letter-spacing: -0.3px;
  }
  .nav-links {
    display: flex;
    gap: 4px;
  }
  .nav-link {
    color: var(--text-muted);
    font-size: 13px;
    font-weight: 500;
    padding: 6px 14px;
    border-radius: 6px;
    transition: all 0.2s;
  }
  .nav-link:hover {
    color: var(--text);
    background: rgba(255,255,255,0.05);
    opacity: 1;
  }
  .nav-link.active {
    color: var(--cyan);
    background: var(--cyan-muted);
  }
  .nav-cta {
    display: flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: 600;
    color: var(--cyan);
    padding: 6px 14px;
    border: 1px solid rgba(34, 211, 238, 0.3);
    border-radius: 6px;
    transition: all 0.2s;
  }
  .nav-cta:hover {
    background: var(--cyan-muted);
    border-color: var(--cyan);
    opacity: 1;
  }
  .cta-dot {
    width: 6px;
    height: 6px;
    background: var(--green);
    border-radius: 50%;
    animation: pulse-dot 2s ease-in-out infinite;
  }
  @keyframes pulse-dot {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }
  @media (max-width: 720px) {
    nav { padding: 0 1rem; }
    .nav-links { display: none; }
  }
</style>
