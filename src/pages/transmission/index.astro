---
import AnalysisLayout from "../../layouts/AnalysisLayout.astro";

const scenarios = [
  { key: 'hormuz', label: 'Hormuz closure', color: '#ef4444' },
  { key: 'strike', label: 'Oil infrastructure strike', color: '#f59e0b' },
  { key: 'cable', label: 'Cable severance', color: '#6366f1' },
  { key: 'ceasefire', label: 'Ceasefire', color: '#10b981' },
];

const sectors = [
  {
    id: 'energy-downstream', title: 'Energy Downstream', icon: '01',
    summary: 'Refining margins, electricity generation, and fuel substitution. With ~20% of global LNG and 20% of crude transiting Hormuz, a chokepoint shock flows to pump prices in 1-3 weeks and to gas-indexed power within days. Prices rocket up on shock, feather down on ceasefire.',
    trigger: 'Crude oil (refinery feedstock) and natural gas/LNG (marginal price-setter for electricity in Europe and much of Asia).',
    mechanism: '+$10/bbl crude adds ~$0.24-0.25/gal to retail gasoline. Wholesale fuel reprices in hours-days; retail pump lags crude 1-3 weeks with documented asymmetric "rockets-and-feathers" pass-through. In gas-indexed power markets, gas-fired plants set the clearing price, so a gas spike flows to electricity within days.',
    hormuz: 'Brent $120-130 near-term, tail >$150 (JPMorgan). +$50/bbl implies ~+$1.20/gal gasoline. EU power could re-approach 2022-style >€300/MWh peaks on Qatari LNG loss.',
    strike: 'Abqaiq template: 5.7M b/d outage drove Brent +19% intraday. Partial strikes ~+$8-20/bbl.',
    cable: 'Negligible. <1% price impact.',
    ceasefire: 'Risk premium unwinds ~$10/bbl (~10-13%). June 2025: Brent $79 to ~$68 (-14%).',
    fills: 'OPEC+ spare ~3-4M b/d (trapped behind Hormuz under closure). US SPR ~350M+ bbl. Coal redispatch in hours-days.',
    closes: 'Risk premium evaporates within days. If OPEC+ over-released, oversupply pushes Brent toward $60s. Permanent: accelerated bypass pipeline buildout.',
    precedent: '1990: Brent ~$17 to ~$36 (>100%). 2019 Abqaiq: +19% intraday, retraced in ~3 weeks. 2022 EU: power +121%, TTF gas peaked >€300-345/MWh.',
    timeline: 'Crude: hours-days. Retail pump: 1-3 weeks. Electricity: days. SPR: weeks-months. Renewables: months-years.',
    confidence: 'high',
  },
  {
    id: 'petrochemicals', title: 'Petrochemicals', icon: '02',
    summary: '~$600B global industry running on naphtha and ethane. ~12.5% of global ethylene capacity sits in the Gulf. Hormuz closure spikes polymer prices 20-40% while US shale-ethane crackers see margins expand — a rare winner.',
    trigger: 'Naphtha (crude-linked) and ethane (gas-linked). ~12.5% of global ethylene capacity (~29 of ~232 Mt) is in the Gulf zone.',
    mechanism: 'Crude spike pulls naphtha up near-lockstep. Ethane stays near gas prices, so ethane crackers (US Gulf Coast) see margins EXPAND as polymer prices rise while ethane stays flat.',
    hormuz: 'Ethylene/polyethylene spot +20-40%. Severe Asian plastics shortage. US ethane crackers gain margin.',
    strike: 'Naphtha tracks crude ~+15%; polymers +10-20%; ethane crackers relatively insulated.',
    cable: 'Negligible. <2%.',
    ceasefire: 'Naphtha/polymers retrace ~-10-15%; Gulf export normalization re-floods market.',
    fills: 'US Gulf Coast ethane crackers (capacity-limited, new crackers take 3-5 years). Asian buyers pay 15-35% premiums. China coal-to-olefins is a high-cost backstop.',
    closes: 'Gulf product floods back; polymer prices fall fast; high-cost naphtha/CTO margins collapse. US shale-ethane crackers gain durable share.',
    precedent: '2008: ethylene surged with $147 crude, fell 50%+ in H2. 2021 Winter Storm Uri: US polyethylene up 50-100%+ globally.',
    timeline: 'Spot: days. Polymer contracts: weeks. Downstream plastics: weeks-months. New capacity: 3-5 years.',
    confidence: 'medium',
  },
  {
    id: 'fertilizer', title: 'Fertilizer & Ammonia', icon: '03',
    summary: 'The cleanest gas-to-food transmission path. ~70-72% of global ammonia is gas-based. Gulf = 36% of world urea, 29% of ammonia exports (IFPRI). Hormuz disruption drives urea +30-70%+, food-price hit lands 6-18 months later. 2026 data in-market: urea >$850/MT in April, +80% since Feb.',
    trigger: '~70-72% of global ammonia uses natural gas. Gulf exports 36% of global urea, 29% of ammonia. Iran alone ~10% of global urea exports.',
    mechanism: 'Gas spike → ammonia production uneconomic → plants idle → ammonia tightens → urea/DAP rise → crop input costs rise → food prices shift (6-9 month lag). 2022: ~70% of European ammonia capacity reduced/shut by Oct.',
    hormuz: 'Loss of ~36% of global urea exports. Urea >$850/MT in April 2026 (+80% since Feb). Sustained: +30-70%+.',
    strike: 'Observed Feb-Apr 2026: urea +47-80%, DAP ~+35%. Qatar suspended urea/ammonia/sulfur output.',
    cable: 'Negligible. <2%.',
    ceasefire: 'Prices retrace over weeks-months. BUT food-price relief lags by a full growing season.',
    fills: 'US Gulf Coast (CF Industries), Trinidad, Russia (16% but sanctions-constrained), North Africa. European plants restart if gas affordable. Green ammonia: years away, 2-4x costlier.',
    closes: 'Gulf returns → prices normalize → high-cost projects lose competitiveness. Food prices sticky: missed fertilizer season permanently lowers that year\'s harvest.',
    precedent: '2022: urea peaked ~$925/tonne (vs ~$500 pre-crisis), DAP +36%, MOP +53%. Russia = ~16% of global urea.',
    timeline: 'Spot: days-weeks. Farm input: one season. Food prices: 6-18 months. Green ammonia: 3-10 years.',
    confidence: 'high',
  },
  {
    id: 'agriculture', title: 'Agriculture & Food Prices', icon: '04',
    summary: 'Where the cascade bites households. Synthetic nitrogen underpins ~48% of global food production. Fertilizer-to-food lag is ~6-9 months and persists past ceasefire because the under-fertilized crop is locked in. Most exposed: maize, wheat, rice. Most vulnerable: Egypt, Pakistan, Bangladesh.',
    trigger: 'Synthetic nitrogen (Haber-Bosch) underpins ~48% of global food production. Without it, output meets only ~50% of demand.',
    mechanism: 'Gulf gas disruption → ammonia/urea curtailed → urea FOB >$850/MT → shipping strands tonnage (double hit) → farmers cut application → FAO warns reduced output within 6-9 months.',
    hormuz: 'Gulf urea/ammonia exports halted + LNG choked. Urea could exceed 2022 record (~$925/MT). Pro Farmer: potentially "worse than the 2022 spike."',
    strike: 'Severe but narrower. Observed Feb-Apr 2026: urea +47-80%.',
    cable: 'Low. Degrades commodity-trading coordination and ag-fintech in MENA/South Asia.',
    ceasefire: 'Urea mean-reverts. But 2026-27 crop already under-fertilized — food prices stay elevated 6-12 months after.',
    fills: 'Russia, Egypt, Algeria, Trinidad, US, Indonesia. Potash harder (Russia+Belarus = 40%). Ramp: months. Premium: +30-80%.',
    closes: 'Gulf restarts → stranded cargoes hit market → oversupply risk. Missed fertilizer season = permanent harvest loss for that year.',
    precedent: '2007-08: FAO Food Price Index +63%; rice +166%; 30+ countries imposed export bans. 2022: Russia+Ukraine ~30% of global wheat.',
    timeline: 'Hours: futures spike. Weeks: shipping reroutes. 3-6 months: reduced application. 6-9 months: food prices hit FAO index.',
    confidence: 'high',
  },
  {
    id: 'aviation', title: 'Aviation & Transportation', icon: '05',
    summary: 'Jet fuel was 31% of airline opex in 2024 ($291B, IATA). A $40-60/bbl spike pushes fuel toward 40%+ — a level that triggered 25 airline failures in H1 2008. Carriers cut thin routes first. Bunker spikes feed container-rate surcharges into last-mile delivery.',
    trigger: 'Crude spike +$40-60/bbl. Jet fuel ~31% of airline opex (IATA). Bunker fuel drives container-shipping costs.',
    mechanism: 'Crude +$40-60 → fuel share jumps from ~31% toward 40-45% → airlines can\'t fully pass through → margins collapse → thin routes cut first. Bunker: VLSFO spike → BAF surcharges → container rates → last-mile.',
    hormuz: 'Crude $120-150+. Fuel share 40%+ of opex; rapid thin-route cuts; air-freight spikes. MENA tourism collapses.',
    strike: '+$40-60/bbl; airfares +up to 10% (Khaleej Times); selective route cuts.',
    cable: 'Indirect. Booking systems, ATC data degraded. Major for digital logistics.',
    ceasefire: 'Crude mean-reverts. But capacity discipline and surcharges are sticky — fares lag fuel down.',
    fills: 'Non-Gulf jet-fuel reroutes in weeks. Airlines impose immediate surcharges. Air-cargo rates can double.',
    closes: 'Crude collapses fast (2008: -70% in months). Over-hedged airlines book losses. Permanent: fleet renewal accelerates; consolidation (2008 → ~4 US majors).',
    precedent: '2008: crude to $147.27; 25 airlines ceased ops. 2022: VLSFO >$1,000/MT, all-time high $1,125.50/MT.',
    timeline: 'Hours: surcharges. Days-weeks: route suspensions. Weeks-months: airline failures. 1-2 years: consolidation.',
    confidence: 'high',
  },
  {
    id: 'manufacturing', title: 'Manufacturing', icon: '06',
    summary: 'Energy-intensive industries — aluminum (~40% of cost), cement (30-40%), steel, glass, paper — curtail first. 2022 EU gas crisis idled ~1.4Mt aluminum, pushing Western European output to century low. Much never restarted: ceasefire relief is partial, some loss permanent.',
    trigger: 'Gas/oil disruption spikes European/Asian power prices. Aluminum smelting ~40% energy cost; cement ~30-40%; steel ~15-20%.',
    mechanism: 'Gulf disruption → LNG/gas tightens → TTF/power spikes → marginal producers go cash-negative → curtail/idle → import substitution → permanent capacity loss.',
    hormuz: 'Worst for Asia and Europe. Power spike idles aluminum/zinc smelters. Most Gulf-energy-dependent: India, Pakistan, Bangladesh, Japan, South Korea.',
    strike: 'Severe energy-price spike mirroring 2022 EU dynamics.',
    cable: 'Low direct. Disrupts industrial IoT/ERP coordination.',
    ceasefire: 'Gas/power fall but idled smelters restart slowly (months). Cold-start potline risk = some permanently lost.',
    fills: 'Aluminum: China, Kazakhstan, Turkey, Russia replace EU output. Smelter restart = months with permanent-loss risk.',
    closes: 'Uneven recovery. Some EU smelters never reopened. Europe\'s deindustrialization risk crystallizes.',
    precedent: '2022: TTF €90 to €345/MWh. Europe idled ~1.4Mt aluminum (~2% global). All 9 EU zinc smelters cut/stopped.',
    timeline: 'Hours: margins negative. Weeks: curtailment. Months: PMI decline. 6-12 mo: permanent closures. Years: capacity migration.',
    confidence: 'medium',
  },
  {
    id: 'financial', title: 'Financial Markets', icon: '07',
    summary: 'The cascade\'s transmission hub. Oil shock → importer current accounts → FX → sovereign spreads → war-risk premiums → central bank policy. Red Sea 2024: war-risk 0.05% → 1.0% hull value, Suez traffic halved, Egypt canal revenue -60% ($10.25B → $3.99B). Gulf SWFs (~$3.5T) are both shock-absorbers and forced sellers.',
    trigger: 'Oil shock transmits to importer fiscal accounts, marine insurance, Gulf SWF values, importer FX, and central bank policy.',
    mechanism: 'Oil +$X → importer current accounts deteriorate → FX depreciates → inflation imported → central bank tightens or draws reserves → sovereign spreads widen → rating pressure. War-risk: 0.05% → 1.0% of hull ($50K → $1M per $100M hull transit).',
    hormuz: '1973 comparator: oil +300%. Full closure removes ~20M b/d. Energy-importer sovereigns face acute external stress.',
    strike: 'Abqaiq: Brent ~+15% intraday. Gulf-wide strike scales 2-4x.',
    cable: 'Limited direct but adds settlement/latency risk to FX and rates desks.',
    ceasefire: 'Risk premia compress, war-risk falls to 0.05-0.1% baseline, SWF selling reverses.',
    fills: 'US SPR + IEA release; OPEC spare ~1.5-2M b/d. Insurance migrates to Lloyd\'s war syndicates at punitive rates. FX/sovereign: IMF programs, GCC bilateral deposits.',
    closes: 'Post-shock demand destruction + delayed supply → price overshoot then slump (1974, 2008, 2014). Gulf SWFs rotate domestic, reducing foreign recycling. Red Sea premiums stayed elevated >12 months.',
    precedent: '1973: oil +300%; US CPI >9%; GDP -0.5%. Red Sea 2024: war-risk 0.05% → 1.0%; Suez -50%; Egypt revenue -60%.',
    timeline: '0-72h: gap, war-risk re-rating. 1-4 wks: SPR releases. 1-3 mo: central bank responses, IMF. 3-12 mo: structural repricing.',
    confidence: 'high',
  },
  {
    id: 'technology', title: 'Technology & Digital', icon: '08',
    summary: 'Primary blast radius of cable severance. Feb 2024: ~25% of Asia-Europe traffic degraded (up to 70% some routes), 5-month repair due to war-zone permits. Hyperscalers reroute in minutes but thin-routed telcos and centralized crypto exchanges see hard liquidity hits.',
    trigger: 'Severance of Red Sea/Gulf submarine cables (~16-17 systems in the corridor).',
    mechanism: 'Feb 2024: 3 cables cut, ~25% traffic affected, up to 70% on some routes, 100M+ people impacted. AAE-1 repair took ~5 months. Azure reported elevated latency.',
    hormuz: 'Indirect: DC energy-cost spike. Reports of AWS ME data centers damaged by Iranian strikes.',
    strike: 'Indirect via DC energy costs and regional risk premium.',
    cable: 'Primary. ~25% traffic degraded, multi-month repair tail. Crypto: connectivity loss widens spreads, breaks algo execution.',
    ceasefire: 'Repair vessels gain access; latency normalizes over weeks-months.',
    fills: 'Rerouting onto surviving systems (2Africa, PEACE) and LEO satellite. ~60 cable ships worldwide; weeks to mobilize, months in conflict zones.',
    closes: 'Accelerated route diversification. Thin single-path telcos structurally disadvantaged. Data centre routing may permanently shift toward India.',
    precedent: 'Feb 2024: 3 cables, 100M+ users, 5-month repair. CrowdStrike outage: TradFi stalled but Bitcoin/Ethereum base layers unaffected.',
    timeline: '0-24h: latency spikes. 1-7d: backup congestion. 1-4 wks: repair mobilization. 1-5 mo: full restoration.',
    confidence: 'medium',
  },
  {
    id: 'pharma', title: 'Pharmaceuticals', icon: '09',
    summary: '~99% of pharmaceutical feedstocks are petrochemical-derived and the JIT generic supply chain runs through Gulf/Red Sea lanes. COVID analog: pharma transport costs +224% (peak +413%). Concentrated API sourcing + freight shock = multi-month shortages of thin-margin generics.',
    trigger: 'Dual hit: petroleum feedstock cost spike AND Gulf/Red Sea shipping disruption for APIs and finished drugs.',
    mechanism: '~99% of pharma feedstocks are petrochemical-derived. Red Sea diversion adds ~2 weeks / ~4,000 miles; shipping costs +100%. Indian generic exporters (JIT model) hit hardest.',
    hormuz: 'Worst feedstock case — Gulf is petrochemical heartland. Benzene/toluene/xylene tighten, compounding shipping hit.',
    strike: 'Feedstock cost spike flows into ~99% of pharma inputs.',
    cable: 'Limited. Ordering/logistics latency only.',
    ceasefire: 'Shipping reverts to Suez (saves ~2 wks / ~$200-400/TEU).',
    fills: 'Non-Gulf-routed API suppliers; ramp = months-years (regulatory barriers). Air-freight for cold chain at sharply higher cost.',
    closes: 'Freight reverts on ceasefire. Permanent: accelerated API reshoring; strategic stockpiling of critical-drug APIs.',
    precedent: 'COVID: pharma shipping +224% avg (peak +413%); India restricted 26 APIs. Red Sea 2024: +2 wks, freight +100%.',
    timeline: '0-2 wks: freight reroute. 2-8 wks: spot shortages. 2-6 mo: feedstock pass-through. 6 mo+: reshoring.',
    confidence: 'medium',
  },
  {
    id: 'construction', title: 'Construction & Materials', icon: '10',
    summary: 'Four petroleum-linked inputs: bitumen (+$30-50/tonne per $10/bbl), cement (energy 30-40% of cost), steel, and freight. The Gulf is also the demand epicentre — UAE $590B project pipeline and NEOM (up to $8.8T) face both cost inflation and physical risk.',
    trigger: 'Oil/energy spike transmits via bitumen (refining residue), steel, cement (most energy-intensive manufacturing), and freight.',
    mechanism: 'Bitumen: +$10/bbl = +$30-50/tonne. Cement: energy 30-40% of cost. Shanghai-Europe freight rose 256% Dec 2023-Feb 2024.',
    hormuz: 'Brent $120-150 → bitumen +$150-250/tonne; cement +15-25%; steel +10-20%; freight +250%+. Gulf megaprojects face dual risk.',
    strike: 'Abqaiq: Brent +19.5%. Bitumen +$100-200/tonne; cement/steel +8-15%.',
    cable: 'Limited. <5%. Project management/payment disruption.',
    ceasefire: 'Materials give back most conflict premium within 1-2 quarters.',
    fills: 'Bitumen: non-Gulf refiners in weeks-months. Cement barely tradable (too heavy). Steel: local producers pass through costs. No quick substitute — only demand destruction.',
    closes: 'Asphalt normalizes with crude. Freight premium collapses 2-4 quarters after route normalization. Prolonged high energy favors gas-advantaged producers.',
    precedent: '1973: oil quadrupled; construction collapsed. Saudi flew cement by helicopter into Jeddah. 2023-24: container spot +256%.',
    timeline: '0-2 wks: bitumen/freight spike. 1-3 mo: cement/steel passthrough. 3-9 mo: megaproject deferrals. 9-24 mo: normalization.',
    confidence: 'medium',
  },
  {
    id: 'defense', title: 'Defense & Security', icon: '11',
    summary: 'Conflict accelerates a record arms cycle: global spend hit $2.718T in 2024 (+9.4% real, largest jump since Cold War, SIPRI). US-Saudi $142B deal (May 2025). Cyber: $193B to $213B (2025). Budgets are structurally sticky — ceasefire slows pace but rarely reverses level.',
    trigger: 'Acute conflict accelerates procurement, budget realignment, private security, and cybersecurity. Baseline: $2.718T in 2024, +9.4% real (SIPRI).',
    mechanism: 'NATO: 18/32 members at >=2.0% GDP (up from 11 in 2023). GCC reprices into emergency procurement. Each escalation drives cyber spend.',
    hormuz: 'Maximal. GCC emergency buys, naval surge costs, cyber hardening. Saudi ~$70B surge; UAE $18.7B → $23.9B (2021-2025).',
    strike: 'Strong air-defense/counter-drone demand. Patriot/THAAD restocks.',
    cable: 'Pivots to cybersecurity, subsea-cable protection, naval ISR. Infosec: $193B → $213B (+15%).',
    ceasefire: 'Pace moderates but budgets sticky. NATO 2%+ and GCC modernization persist.',
    fills: 'US-Saudi $142B deal (May 2025). F-35 sale approved Nov 2025. France, UK, Italy supplement. Domestic: EDGE (UAE), SAMI (Saudi). FMS deliveries: 2-5+ years.',
    closes: 'Defense spending rarely closes. Multi-year contracts = sticky. GCC localization, NATO 2%-to-3%+ trajectory, cyber/counter-drone become permanent.',
    precedent: 'Post-Crimea: NATO 2% pledge → 18/32 by 2024. Germany €100B Zeitenwende. 2019 Abqaiq → Patriot/THAAD/counter-UAS waves.',
    timeline: '0-4 wks: emergency resupply. 1-6 mo: FMS signings. 6-24 mo: budget-law increases. 2-5+ yrs: platform deliveries.',
    confidence: 'high',
  },
  {
    id: 'tourism-services', title: 'Tourism & Services', icon: '12',
    summary: 'Dubai drew 18.72M visitors in 2024 (+9%), tourism ~12% of GDP; leisure travel (77% of visitors) is highly elastic to safety perception. Airspace closures force $6,000-10,000/hr reroute costs and war-risk premium spikes. The deeper exposure is the Gulf remittance corridor: India $129.1B, Philippines $40B, Pakistan $33B (2024), much of it sourced from Gulf migrant labor.',
    trigger: 'Gulf conflict hits inbound tourism (Dubai/UAE), airspace and aviation economics, war-risk insurance, business travel, and the remittance corridor from Gulf migrant workers to South/Southeast Asia and Egypt.',
    mechanism: 'Dubai tourism 18.72M visitors in 2024 (+9%, India top source at 2.2M); tourism ~12% of Dubai GDP. Aviation rerouting adds 300-800 nm and 45 min-2 hrs per flight, costing ~$6,000-10,000 per added flight hour (~$60,000 on a 10-hr sector). War-risk premiums spike near Iran/Iraq airspace; cumulative industry cost could exceed $1B if the conflict extends.',
    hormuz: 'Severe. Gulf airspace/airport risk disrupts Dubai/Doha/Abu Dhabi hubs; Emirates/Qatar/Etihad reroute fleets; war-risk premiums surge; inbound tourism drops sharply (leisure 77% of visitors, highly elastic). Remittance corridor stressed by worker-repatriation risk.',
    strike: 'Moderate-high aviation fuel spike (jet fuel tracks crude); airfares +up to 10%; insurance repricing; tourism dip on headline risk.',
    cable: 'Hits business and financial services, payment and booking systems, and digital remittance rails; aviation less direct. Transfers face transaction friction.',
    ceasefire: 'Rapid rebound: risk premiums unwind, airspace reopens, war-risk insurance renormalizes, tourism and business travel recover within 1-2 quarters.',
    fills: 'Aviation: airlines reroute via longer corridors (Cape/Central Asia/Pacific) at $6,000-10,000/hr premium; alternative hubs (Istanbul, European) capture diverted connecting traffic. Tourism: substitute destinations (Europe, SE Asia) capture displaced demand. Insurance: London and specialty war-risk markets reprice sharply higher.',
    closes: 'Aviation premium collapses on airspace reopening (weeks). Tourism: pent-up demand drives a sharp rebound, no permanent share loss unless the conflict is prolonged. Remittances are structurally resilient, but a Gulf labor-demand contraction (construction slowdown) would permanently reduce flows.',
    precedent: '2024-25 Red Sea: reroute templates (added ~$1M fuel + 10 days/voyage). 2020 COVID: Dubai tourism collapsed then rebounded to a record 18.72M by 2024. Remittance resilience: 2024 global remittances to LMICs ~$685B (greater than FDI + ODA combined), proven countercyclical (World Bank).',
    timeline: '0-2 weeks: airspace closures, war-risk premium spikes, airfares +up to 10%, bookings soften. 1-3 months: sustained rerouting costs, business-travel cuts, remittance-corridor stress. 3-9 months: tourism demand destruction if Hormuz stays closed. Post-ceasefire: sharp tourism/aviation rebound; remittances resilient.',
    confidence: 'medium',
  },
];
---

<AnalysisLayout area="transmission"
  title="Sector Transmission — VegaReady Scenario Analysis"
  description="How geopolitical disruption transmits through 12 global sectors. Each sector analyzed across 4 scenarios with quantified impact, historical precedent, gap dynamics, and time horizons."
  section="Sector Transmission"
>

  <section class="hero">
    <div class="label">Sector transmission</div>
    <h1>How disruption flows<br/>through every sector.</h1>
    <p class="lead">12 sectors analyzed across 4 scenarios. Each maps the upstream trigger, transmission mechanism, quantified impact, who fills the gap, what happens when it reopens, and historical precedent. Click any sector to expand.</p>
    <div class="callout">
      <div class="callout-title">Key insight</div>
      <div class="callout-text">The fertilizer-to-food lag (~6-9 months) is the most tradeable asymmetry in the cascade: the input spikes in hours but the food-price move lands two-to-three quarters later and persists past any ceasefire.</div>
    </div>
  </section>

  <div class="sector-list">
    {sectors.map((s) => (
      <details class="sector-detail">
        <summary class="sector-summary">
          <div class="sector-left">
            <span class="sector-num">{s.icon}</span>
            <div>
              <div class="sector-title">{s.title}</div>
              <div class="sector-blurb">{s.summary}</div>
            </div>
          </div>
          <span class={`conf conf-${s.confidence}`}>{s.confidence}</span>
        </summary>
        <div class="sector-body">
          <div class="ds"><div class="dl">Upstream trigger</div><p>{s.trigger}</p></div>
          <div class="ds"><div class="dl">Transmission mechanism</div><p>{s.mechanism}</p></div>
          <div class="ds">
            <div class="dl">Scenario impact</div>
            <div class="sg">
              <div class="si"><span class="sd" style="background:#ef4444"></span><span class="sn">Hormuz closure</span><div class="sv">{s.hormuz}</div></div>
              <div class="si"><span class="sd" style="background:#f59e0b"></span><span class="sn">Oil strike</span><div class="sv">{s.strike}</div></div>
              <div class="si"><span class="sd" style="background:#6366f1"></span><span class="sn">Cable severance</span><div class="sv">{s.cable}</div></div>
              <div class="si"><span class="sd" style="background:#10b981"></span><span class="sn">Ceasefire</span><div class="sv">{s.ceasefire}</div></div>
            </div>
          </div>
          <div class="dr">
            <div class="ds"><div class="dl">Who fills the gap</div><p>{s.fills}</p></div>
            <div class="ds"><div class="dl">When the gap closes</div><p>{s.closes}</p></div>
          </div>
          <div class="dr">
            <div class="ds"><div class="dl">Historical precedent</div><p>{s.precedent}</p></div>
            <div class="ds"><div class="dl">Time horizon</div><p>{s.timeline}</p></div>
          </div>
        </div>
      </details>
    ))}
  </div>

  <div class="winners">
    <div class="dl">Identifiable winners across disruptions</div>
    <p>US shale-ethane crackers (petrochemicals), US/Trinidad fertilizer producers, Russia (energy revenue), defense and cybersecurity primes, Lloyd's war-risk syndicates, substitute tourism hubs (Istanbul), India data centers, Cape-route port operators, Brazilian agriculture, Australian LNG.</p>
  </div>

</AnalysisLayout>

<style>
  .hero{margin-bottom:3rem;padding-bottom:2rem;border-bottom:1px solid var(--border)}
  .label{font-family:var(--font-mono);font-size:11px;color:var(--cyan);letter-spacing:3px;text-transform:uppercase;margin-bottom:16px}
  .hero h1{font-family:var(--font-display);font-size:clamp(1.8rem,3.5vw,2.4rem);font-weight:400;color:var(--text);line-height:1.15;margin-bottom:1rem}
  .lead{font-size:15px;color:var(--text-muted);line-height:1.7;max-width:640px;margin-bottom:1.5rem}
  .callout{background:var(--bg-surface);border:1px solid var(--border);border-left:3px solid var(--cyan);border-radius:8px;padding:14px 18px;max-width:640px}
  .callout-title{font-family:var(--font-mono);font-size:10px;font-weight:700;color:var(--cyan);text-transform:uppercase;letter-spacing:1.5px;margin-bottom:4px}
  .callout-text{font-size:13px;color:var(--text-muted);line-height:1.6}
  .sector-list{display:flex;flex-direction:column;gap:8px;margin-bottom:3rem}
  .sector-detail{background:var(--bg-surface);border:1px solid var(--border);border-radius:10px;overflow:hidden}
  .sector-detail[open]{border-color:var(--border-light)}
  .sector-detail[open] .sector-summary{border-bottom:1px solid var(--border)}
