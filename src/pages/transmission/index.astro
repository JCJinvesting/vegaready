---
import AnalysisLayout from "../../layouts/AnalysisLayout.astro";
import { scenarios, sectors } from '../../data/analysis/transmission.js';
---

<AnalysisLayout area="transmission"
  title="Sector Transmission — VegaReady Scenario Analysis"
  description="How geopolitical disruption transmits through 12 global sectors. Each sector analyzed across 4 scenarios with quantified impact, historical precedent, gap dynamics, and time horizons."
  section="Sector Transmission"
>

  <section class="hero">
    <div class="label">Sector transmission</div>
    <h1>How disruption flows<br/>through every sector.</h1>
    <p class="lead">12 sectors analyzed across 4 scenarios. Each maps the upstream trigger, transmission mechanism, quantified impact, who fills the gap, what happens when it reopens, and historical precedent. Click any sector to expand.</p>
    <div class="callout">
      <div class="callout-title">Key insight</div>
      <div class="callout-text">The fertilizer-to-food lag (~6-9 months) is the most tradeable asymmetry in the cascade: the input spikes in hours but the food-price move lands two-to-three quarters later and persists past any ceasefire.</div>
    </div>
  </section>

  <div class="sector-list">
    {sectors.map((s) => (
      <details class="sector-detail">
        <summary class="sector-summary">
          <div class="sector-left">
            <span class="sector-num">{s.icon}</span>
            <div>
              <div class="sector-title">{s.title}</div>
              <div class="sector-blurb">{s.summary}</div>
            </div>
          </div>
          <span class={`conf conf-${s.confidence}`}>{s.confidence}</span>
        </summary>
        <div class="sector-body">
          <div class="ds"><div class="dl">Upstream trigger</div><p>{s.trigger}</p></div>
          <div class="ds"><div class="dl">Transmission mechanism</div><p>{s.mechanism}</p></div>
          <div class="ds">
            <div class="dl">Scenario impact</div>
            <div class="sg">
              <div class="si"><span class="sd" style="background:#ef4444"></span><span class="sn">Hormuz closure</span><div class="sv">{s.hormuz}</div></div>
              <div class="si"><span class="sd" style="background:#f59e0b"></span><span class="sn">Oil strike</span><div class="sv">{s.strike}</div></div>
              <div class="si"><span class="sd" style="background:#6366f1"></span><span class="sn">Cable severance</span><div class="sv">{s.cable}</div></div>
              <div class="si"><span class="sd" style="background:#10b981"></span><span class="sn">Ceasefire</span><div class="sv">{s.ceasefire}</div></div>
            </div>
          </div>
          <div class="dr">
            <div class="ds"><div class="dl">Who fills the gap</div><p>{s.fills}</p></div>
            <div class="ds"><div class="dl">When the gap closes</div><p>{s.closes}</p></div>
          </div>
          <div class="dr">
            <div class="ds"><div class="dl">Historical precedent</div><p>{s.precedent}</p></div>
            <div class="ds"><div class="dl">Time horizon</div><p>{s.timeline}</p></div>
          </div>
          <div class="ds"><div class="dl">Sources</div><p>{s.sources.map((u, i) => (<a href={u} target="_blank" rel="noopener" style="color:#60a5fa;margin-right:10px;font-size:13px;text-decoration:none">[{i + 1}]</a>))}</p></div>
        </div>
      </details>
    ))}
  </div>

  <div class="winners">
    <div class="dl">Identifiable winners across disruptions</div>
    <p>US shale-ethane crackers (petrochemicals), US/Trinidad fertilizer producers, Russia (energy revenue), defense and cybersecurity primes, Lloyd's war-risk syndicates, substitute tourism hubs (Istanbul), India data centers, Cape-route port operators, Brazilian agriculture, Australian LNG.</p>
  </div>

</AnalysisLayout>

<style>
  .hero{margin-bottom:3rem;padding-bottom:2rem;border-bottom:1px solid var(--border)}
  .label{font-family:var(--font-mono);font-size:11px;color:var(--cyan);letter-spacing:3px;text-transform:uppercase;margin-bottom:16px}
  .hero h1{font-family:var(--font-display);font-size:clamp(1.8rem,3.5vw,2.4rem);font-weight:400;color:var(--text);line-height:1.15;margin-bottom:1rem}
  .lead{font-size:15px;color:var(--text-muted);line-height:1.7;max-width:640px;margin-bottom:1.5rem}
  .callout{background:var(--bg-surface);border:1px solid var(--border);border-left:3px solid var(--cyan);border-radius:8px;padding:14px 18px;max-width:640px}
  .callout-title{font-family:var(--font-mono);font-size:10px;font-weight:700;color:var(--cyan);text-transform:uppercase;letter-spacing:1.5px;margin-bottom:4px}
  .callout-text{font-size:13px;color:var(--text-muted);line-height:1.6}
  .sector-list{display:flex;flex-direction:column;gap:8px;margin-bottom:3rem}
  .sector-detail{background:var(--bg-surface);border:1px solid var(--border);border-radius:10px;overflow:hidden}
  .sector-detail[open]{border-color:var(--border-light)}
  .sector-detail[open] .sector-summary{border-bottom:1px solid var(--border)}
  .sector-summary{display:flex;justify-content:space-between;align-items:flex-start;padding:16px 20px;cursor:pointer;list-style:none;gap:12px}
  .sector-summary::-webkit-details-marker{display:none}
  .sector-summary::marker{display:none;content:''}
  .sector-summary:hover{background:rgba(255,255,255,0.02)}
  .sector-left{display:flex;gap:14px;flex:1;min-width:0}
  .sector-num{font-family:var(--font-mono);font-size:12px;font-weight:700;color:var(--cyan);min-width:22px;padding-top:2px}
  .sector-title{font-size:15px;font-weight:700;color:var(--text);margin-bottom:4px}
  .sector-blurb{font-size:12px;color:var(--text-dim);line-height:1.5;display:-webkit-box;-webkit-line-clamp:3;-webkit-box-orient:vertical;overflow:hidden}
  .conf{font-family:var(--font-mono);font-size:10px;font-weight:700;padding:2px 8px;border-radius:4px;white-space:nowrap;flex-shrink:0;margin-top:2px}
  .conf-high{color:#10b981;background:rgba(16,185,129,0.1)}
  .conf-medium{color:#f59e0b;background:rgba(245,158,11,0.1)}
  .sector-body{padding:16px 20px 20px}
  .ds{margin-bottom:16px}
  .dl{font-family:var(--font-mono);font-size:10px;font-weight:700;color:var(--cyan);text-transform:uppercase;letter-spacing:1.5px;margin-bottom:6px}
  .ds p{font-size:13px;color:var(--text-muted);line-height:1.6;margin:0}
  .dr{display:grid;grid-template-columns:1fr 1fr;gap:16px}
  .sg{display:grid;grid-template-columns:1fr 1fr;gap:8px}
  .si{padding:10px 14px;background:var(--bg-card);border-radius:6px;border:1px solid var(--border)}
  .sd{width:6px;height:6px;border-radius:50%;display:inline-block;margin-right:6px;vertical-align:middle}
  .sn{font-family:var(--font-mono);font-size:11px;font-weight:700;color:var(--text)}
  .sv{font-size:12px;color:var(--text-dim);line-height:1.5;margin-top:4px}
  .winners{background:var(--bg-surface);border:1px solid var(--border);border-left:3px solid #10b981;border-radius:8px;padding:16px 20px}
  .winners p{font-size:13px;color:var(--text-muted);line-height:1.6;margin:0}
  @media(max-width:720px){.dr{grid-template-columns:1fr}.sg{grid-template-columns:1fr}.sector-blurb{display:none}}
</style>
