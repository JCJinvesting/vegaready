---
import AnalysisLayout from "../../layouts/AnalysisLayout.astro";
import { countries, winnerLosers } from '../../data/analysis/exposure.js';
---

<AnalysisLayout area="exposure"
  title="Regional Impact — VegaReady Scenario Analysis"
  description="Country-by-country exposure analysis for 12 major economies under four conflict scenarios. Energy, food, trade, financial exposure with quantified impact projections."
  section="Regional Impact"
>
  <section class="hero">
    <div class="label">Regional impact</div>
    <h1>Every economy has a<br/>different exposure.</h1>
    <p class="lead">12 economies analyzed across energy, food, trade, and financial channels. Some benefit from disruption. Some face existential pressure. Understanding the asymmetry is where the macro edge lives.</p>
  </section>

  <section class="summary-section">
    <div class="summary-grid">
      <div class="summary-card" style="border-left:3px solid #10b981"><div class="summary-label">Net winners</div><div class="summary-list">United States, Russia, Saudi Arabia</div></div>
      <div class="summary-card" style="border-left:3px solid #ef4444"><div class="summary-label">Net losers</div><div class="summary-list">China, EU, Japan, India, South Korea, Egypt, Pakistan</div></div>
      <div class="summary-card" style="border-left:3px solid #f59e0b"><div class="summary-label">Mixed</div><div class="summary-list">UAE (Fujairah bypass vs non-relocatable hub), Brazil (oil/ag winner offset by fertilizer-import cost)</div></div>
    </div>
    <div class="callout"><strong>Key asymmetry:</strong> Saudi Arabia is the only economy net-long a Hormuz closure. Egypt is the largest ceasefire-beneficiary. Pakistan carries unique double-Hormuz risk: its energy supplier and ~$38B remittance lifeline are the same region.</div>
  </section>

  <section class="matrix-section">
    <div class="dl">Scenario impact matrix</div>
    <div style="overflow-x:auto">
      <table class="matrix">
        <thead><tr><th>Economy</th><th style="color:#ef4444">Hormuz</th><th style="color:#f59e0b">Strike</th><th style="color:#6366f1">Cable</th><th style="color:#10b981">Ceasefire</th><th>Net</th></tr></thead>
        <tbody>{winnerLosers.map(w=>(
          <tr><td class="mn">{w.name}</td><td>{w.hormuz}</td><td>{w.strike}</td><td>{w.cable}</td><td>{w.ceasefire}</td><td><span class="nt" style={`color:${w.color};border-color:${w.color}30;background:${w.color}10`}>{w.net}</span></td></tr>
        ))}</tbody>
      </table>
    </div>
  </section>

  <div class="country-list">
    {countries.map((c,i)=>(
      <details class="cd">
        <summary class="cs">
          <div class="cl">
            <span class="cn">{String(i+1).padStart(2,'0')}</span>
            <div>
              <div class="ch"><span class="ct">{c.title}</span><span class="cg">{c.gdp}</span><span class="tg" style={`color:${c.tagColor};border-color:${c.tagColor}30;background:${c.tagColor}10`}>{c.tag}</span></div>
              <div class="cb">{c.summary}</div>
            </div>
          </div>
          <span class={`cf cf-${c.confidence}`}>{c.confidence}</span>
        </summary>
        <div class="cy">
          <div class="ds"><div class="dl">Energy exposure</div><p>{c.energy}</p></div>
          <div class="ds"><div class="dl">Food security</div><p>{c.food}</p></div>
          <div class="dr"><div class="ds"><div class="dl">Trade exposure</div><p>{c.trade}</p></div><div class="ds"><div class="dl">Financial exposure</div><p>{c.financial}</p></div></div>
          <div class="ds"><div class="dl">Substitution capacity</div><p>{c.substitution}</p></div>
          <div class="ds"><div class="dl">Scenario impact</div>
            <div class="sg">
              <div class="si"><span class="sd" style="background:#ef4444"></span><span class="sn">Hormuz</span><div class="sv">{c.hormuz}</div></div>
              <div class="si"><span class="sd" style="background:#f59e0b"></span><span class="sn">Strike</span><div class="sv">{c.strike}</div></div>
              <div class="si"><span class="sd" style="background:#6366f1"></span><span class="sn">Cable</span><div class="sv">{c.cable}</div></div>
              <div class="si"><span class="sd" style="background:#10b981"></span><span class="sn">Ceasefire</span><div class="sv">{c.ceasefire}</div></div>
            </div>
          </div>
          <div class="dr"><div class="ds"><div class="dl">Historical behavior</div><p>{c.history}</p></div><div class="ds"><div class="dl">Key second-order effect</div><p class="so">{c.secondOrder}</p></div></div>
          <div class="ds"><div class="dl">Sources</div><p>{c.sources.map((u, i) => (<a href={u} target="_blank" rel="noopener" style="color:#60a5fa;margin-right:10px;font-size:13px;text-decoration:none">[{i + 1}]</a>))}</p></div>
        </div>
      </details>
    ))}
  </div>

  <div class="sn-box"><div class="dl">Sources & methodology</div><p>Data from EIA, IEA, IMF, World Bank, ECB, RBI, SBP, IEEJ, SIPRI, S&P Global, GIE AGSI+. 2026 conflict figures are provisional. Confidence: HIGH = primary institutional source; MEDIUM = reliable press/proxy; LOW = single source/estimate.</p></div>
</AnalysisLayout>

<style>
  .hero{margin-bottom:3rem;padding-bottom:2rem;border-bottom:1px solid var(--border)}
  .label{font-family:var(--font-mono);font-size:11px;color:var(--cyan);letter-spacing:3px;text-transform:uppercase;margin-bottom:16px}
  .hero h1{font-family:var(--font-display);font-size:clamp(1.8rem,3.5vw,2.4rem);font-weight:400;color:var(--text);line-height:1.15;margin-bottom:1rem}
  .lead{font-size:15px;color:var(--text-muted);line-height:1.7;max-width:640px}
  .summary-section{margin-bottom:2.5rem}
  .summary-grid{display:grid;grid-template-columns:1fr 1fr 1fr;gap:8px;margin-bottom:12px}
  .summary-card{background:var(--bg-surface);border:1px solid var(--border);border-radius:8px;padding:14px 16px}
  .summary-label{font-family:var(--font-mono);font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:1.5px;margin-bottom:6px;color:var(--text)}
  .summary-list{font-size:12px;color:var(--text-dim);line-height:1.5}
  .callout{font-size:13px;color:var(--text-muted);line-height:1.6;padding:12px 16px;background:var(--bg-surface);border:1px solid var(--border);border-left:3px solid var(--cyan);border-radius:8px}
  .callout strong{color:var(--cyan);font-family:var(--font-mono);font-size:11px;text-transform:uppercase;letter-spacing:1px}
  .matrix-section{margin-bottom:2.5rem}
  .matrix{width:100%;border-collapse:collapse;font-size:11px}
  .matrix th{padding:8px 10px;text-align:left;border-bottom:2px solid var(--border);font-family:var(--font-mono);font-size:10px;font-weight:700;letter-spacing:1px;text-transform:uppercase;color:var(--text-dim);white-space:nowrap}
  .matrix td{padding:6px 10px;border-bottom:1px solid var(--border);color:var(--text-dim);font-size:11px}
  .mn{font-weight:700;color:var(--text);white-space:nowrap}
  .nt{font-family:var(--font-mono);font-size:10px;font-weight:700;padding:2px 8px;border-radius:4px;border:1px solid;white-space:nowrap}
  .country-list{display:flex;flex-direction:column;gap:8px;margin-bottom:2rem}
  .cd{background:var(--bg-surface);border:1px solid var(--border);border-radius:10px;overflow:hidden}
  .cd[open]{border-color:var(--border-light)}
  .cd[open] .cs{border-bottom:1px solid var(--border)}
  .cs{display:flex;justify-content:space-between;align-items:flex-start;padding:16px 20px;cursor:pointer;list-style:none;gap:12px}
  .cs::-webkit-details-marker{display:none}
  .cs::marker{display:none;content:''}
  .cs:hover{background:rgba(255,255,255,0.02)}
  .cl{display:flex;gap:14px;flex:1;min-width:0}
  .cn{font-family:var(--font-mono);font-size:12px;font-weight:700;color:var(--cyan);min-width:22px;padding-top:2px}
  .ch{display:flex;align-items:center;gap:8px;flex-wrap:wrap;margin-bottom:4px}
  .ct{font-size:15px;font-weight:700;color:var(--text)}
  .cg{font-family:var(--font-mono);font-size:11px;color:var(--text-dim)}
  .tg{font-family:var(--font-mono);font-size:10px;font-weight:700;padding:2px 8px;border-radius:4px;border:1px solid;text-transform:uppercase;letter-spacing:0.5px}
  .cb{font-size:12px;color:var(--text-dim);line-height:1.5;display:-webkit-box;-webkit-line-clamp:3;-webkit-box-orient:vertical;overflow:hidden}
  .cf{font-family:var(--font-mono);font-size:10px;font-weight:700;padding:2px 8px;border-radius:4px;white-space:nowrap;flex-shrink:0;margin-top:2px}
  .cf-high{color:#10b981;background:rgba(16,185,129,0.1)}
  .cf-medium{color:#f59e0b;background:rgba(245,158,11,0.1)}
  .cy{padding:16px 20px 20px}
  .ds{margin-bottom:16px}
  .dl{font-family:var(--font-mono);font-size:10px;font-weight:700;color:var(--cyan);text-transform:uppercase;letter-spacing:1.5px;margin-bottom:6px}
  .ds p{font-size:13px;color:var(--text-muted);line-height:1.6;margin:0}
  .dr{display:grid;grid-template-columns:1fr 1fr;gap:16px}
  .sg{display:grid;grid-template-columns:1fr 1fr;gap:8px}
  .si{padding:10px 14px;background:var(--bg-card);border-radius:6px;border:1px solid var(--border)}
  .sd{width:6px;height:6px;border-radius:50%;display:inline-block;margin-right:6px;vertical-align:middle}
  .sn{font-family:var(--font-mono);font-size:11px;font-weight:700;color:var(--text)}
  .sv{font-size:12px;color:var(--text-dim);line-height:1.5;margin-top:4px}
  .so{color:var(--text);font-weight:500;border-left:2px solid var(--cyan);padding-left:12px}
  .sn-box{background:var(--bg-surface);border:1px solid var(--border);border-radius:8px;padding:16px 20px}
  .sn-box p{font-size:12px;color:var(--text-dim);line-height:1.6;margin:0}
  @media(max-width:720px){.dr{grid-template-columns:1fr}.sg{grid-template-columns:1fr}.cb{display:none}.summary-grid{grid-template-columns:1fr}.matrix{font-size:10px}}
</style>
