---
import AnalysisLayout from "../../layouts/AnalysisLayout.astro";
import { flows, crossFlow } from '../../data/analysis/outlook.js';
---

<AnalysisLayout area="outlook"
  title="Gap Dynamics — VegaReady Scenario Analysis"
  description="Supply disruption → substitution → oversupply cycles for 6 critical flows: crude oil, LNG, fertilizer, shipping, internet bandwidth, and refined products."
  section="Gap Dynamics"
>
  <section class="hero">
    <div class="label">Gap dynamics</div>
    <h1>What fills the gap.<br/>What happens when it reopens.</h1>
    <p class="lead">6 critical flows analyzed through the full disruption cycle: the gap, who fills it, how fast, contract structure, what happens on return, and historical precedent. Each flow has a structural gap that cannot be fully filled — understanding the residual is where the edge lives.</p>
    <div class="callout"><strong>Compounding insight:</strong> Hormuz closure is the only scenario that hits all six flows at once. The defining structural feature: Gulf swing/spare capacity is itself Hormuz-trapped (unlike 1990), so there is no clean producer offset. Cable severance is near-orthogonal to physical commodities. Fertilizer carries the longest tail (6-9 month food-price lag).</div>
  </section>

  <!-- Cross-flow summary -->
  <section class="cross-section">
    <div class="dl">Cross-flow impact by scenario</div>
    <div class="cross-grid">
      <div class="cross-card" style="border-left:3px solid #ef4444"><div class="cross-label" style="color:#ef4444">Hormuz closure</div><div class="cross-text">{crossFlow.hormuz}</div></div>
      <div class="cross-card" style="border-left:3px solid #f59e0b"><div class="cross-label" style="color:#f59e0b">Oil strike</div><div class="cross-text">{crossFlow.strike}</div></div>
      <div class="cross-card" style="border-left:3px solid #6366f1"><div class="cross-label" style="color:#6366f1">Cable severance</div><div class="cross-text">{crossFlow.cable}</div></div>
      <div class="cross-card" style="border-left:3px solid #10b981"><div class="cross-label" style="color:#10b981">Ceasefire</div><div class="cross-text">{crossFlow.ceasefire}</div></div>
    </div>
  </section>

  <!-- Flow cards -->
  <div class="flow-list">
    {flows.map((f) => (
      <details class="fd">
        <summary class="fs">
          <div class="fl">
            <span class="fn">{f.icon}</span>
            <div>
              <div class="ft">{f.title}</div>
              <div class="fb">{f.summary}</div>
            </div>
          </div>
          <span class={`cf cf-${f.confidence}`}>{f.confidence}</span>
        </summary>
        <div class="fy">
          <div class="ds"><div class="dl">The gap</div><p>{f.gap}</p></div>
          <div class="ds"><div class="dl">Who fills it</div><p>{f.fills}</p></div>
          <div class="ds"><div class="dl">Ramp timeline</div><p>{f.ramp}</p></div>
          <div class="dr">
            <div class="ds"><div class="dl">Contract structure</div><p>{f.contracts}</p></div>
            <div class="ds"><div class="dl">What happens on return</div><p>{f.onReturn}</p></div>
          </div>
          <div class="dr">
            <div class="ds"><div class="dl">Historical precedent</div><p>{f.precedent}</p></div>
            <div class="ds"><div class="dl">Investment implications</div><p class="inv">{f.investment}</p></div>
          </div>
        </div>
      </details>
    ))}
  </div>

  <div class="sn-box">
    <div class="dl">Sources & methodology</div>
    <p>T1 official (EIA, IEA, GIIGNL, IFPRI, TeleGeography, ICPC, NDSU): primary evidence. T2 press/proprietary (Reuters, Bloomberg, S&P Global, Kpler, Wood Mackenzie, Drewry): directionally reliable. T3 model (Goldman Sachs, Rapidan Energy): flagged as estimates. Wikipedia, LinkedIn, Facebook excluded from primary evidence. 2026 conflict data provisional. Per-flow confidence reflects weakest link in each chain.</p>
  </div>
</AnalysisLayout>

<style>
  .hero{margin-bottom:3rem;padding-bottom:2rem;border-bottom:1px solid var(--border)}
  .label{font-family:var(--font-mono);font-size:11px;color:var(--cyan);letter-spacing:3px;text-transform:uppercase;margin-bottom:16px}
  .hero h1{font-family:var(--font-display);font-size:clamp(1.8rem,3.5vw,2.4rem);font-weight:400;color:var(--text);line-height:1.15;margin-bottom:1rem}
  .lead{font-size:15px;color:var(--text-muted);line-height:1.7;max-width:640px;margin-bottom:1.5rem}
  .callout{font-size:13px;color:var(--text-muted);line-height:1.6;padding:12px 16px;background:var(--bg-surface);border:1px solid var(--border);border-left:3px solid var(--cyan);border-radius:8px;max-width:640px}
  .callout strong{color:var(--cyan);font-family:var(--font-mono);font-size:11px;text-transform:uppercase;letter-spacing:1px}
  .cross-section{margin-bottom:2.5rem}
  .cross-grid{display:grid;grid-template-columns:1fr 1fr;gap:8px}
  .cross-card{background:var(--bg-surface);border:1px solid var(--border);border-radius:8px;padding:12px 16px}
  .cross-label{font-family:var(--font-mono);font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:1.5px;margin-bottom:4px}
  .cross-text{font-size:11px;color:var(--text-dim);line-height:1.5}
  .flow-list{display:flex;flex-direction:column;gap:8px;margin-bottom:2rem}
  .fd{background:var(--bg-surface);border:1px solid var(--border);border-radius:10px;overflow:hidden}
  .fd[open]{border-color:var(--border-light)}
  .fd[open] .fs{border-bottom:1px solid var(--border)}
  .fs{display:flex;justify-content:space-between;align-items:flex-start;padding:16px 20px;cursor:pointer;list-style:none;gap:12px}
  .fs::-webkit-details-marker{display:none}
  .fs::marker{display:none;content:''}
  .fs:hover{background:rgba(255,255,255,0.02)}
  .fl{display:flex;gap:14px;flex:1;min-width:0}
  .fn{font-family:var(--font-mono);font-size:12px;font-weight:700;color:var(--cyan);min-width:22px;padding-top:2px}
  .ft{font-size:15px;font-weight:700;color:var(--text);margin-bottom:4px}
  .fb{font-size:12px;color:var(--text-dim);line-height:1.5}
  .cf{font-family:var(--font-mono);font-size:10px;font-weight:700;padding:2px 8px;border-radius:4px;white-space:nowrap;flex-shrink:0;margin-top:2px}
  .cf-high{color:#10b981;background:rgba(16,185,129,0.1)}
  .cf-medium{color:#f59e0b;background:rgba(245,158,11,0.1)}
  .fy{padding:16px 20px 20px}
  .ds{margin-bottom:16px}
  .dl{font-family:var(--font-mono);font-size:10px;font-weight:700;color:var(--cyan);text-transform:uppercase;letter-spacing:1.5px;margin-bottom:6px}
  .ds p{font-size:13px;color:var(--text-muted);line-height:1.6;margin:0}
  .dr{display:grid;grid-template-columns:1fr 1fr;gap:16px}
  .inv{color:var(--text);font-weight:500;border-left:2px solid var(--cyan);padding-left:12px}
  .sn-box{background:var(--bg-surface);border:1px solid var(--border);border-radius:8px;padding:16px 20px}
  .sn-box p{font-size:12px;color:var(--text-dim);line-height:1.6;margin:0}
  @media(max-width:720px){.dr{grid-template-columns:1fr}.fb{display:none}.cross-grid{grid-template-columns:1fr}}
</style>
