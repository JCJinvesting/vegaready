---
import AnalysisLayout from '../layouts/AnalysisLayout.astro';
import { intro, themes, causalIntro, causalLinks, attributionLegend, driverRegistry, scenarioAttribution, causalUmbrella } from '../data/analysis/connections.js';
const tone = { red:'#ef4444', amber:'#f59e0b', green:'#10b981', cyan:'#22d3ee', violet:'#8b5cf6' };
const mat = (m) => m === 'built' ? '#22d3ee' : '#f59e0b';
const strCol = { primary:'#22d3ee', partial:'#f59e0b', marginal:'#8892a4' };
const acCol = { high:'#10b981', medium:'#f59e0b', low:'#8892a4' };
const sc = { hormuz_closure:'#ef4444', oil_strike:'#f59e0b', cable_severance:'#22d3ee', ceasefire:'#10b981' };
const scenLabel = (k) => k.replace('_',' ');
const scenarioKeys = ['hormuz_closure','oil_strike','cable_severance','ceasefire'];
const dcMap = { high:0, medium:1, low:2 };
const edgesByShare = [...causalLinks].sort((a,b)=>(a.shareRank||9)-(b.shareRank||9));
---
<AnalysisLayout
  title="Connections — VegaReady"
  description="The cascade as a network of weighted, multi-causal edges: each thread links a sector to the countries exposed, the commodity flow, and who profits — with named competing drivers and explicit attribution discipline."
  section="Connections"
  area="connections"
>
  <section class="hero">
    <div class="label">Connections</div>
    <h1>The cascade is a network,<br/>not three lists.</h1>
    <p class="lead">{intro}</p>
  </section>

  <div class="theme-list">
    {themes.map(t => (
      <div class="theme" style={`border-left:3px solid ${tone[t.tone]}`}>
        <div class="tn" style={`color:${tone[t.tone]}`}>{t.name}</div>
        <p class="thesis">{t.thesis}</p>
        <div class="links">
          <div class="lg"><span class="lgl">Sectors</span><div class="chips">{t.sectors.map(x => (<a class="chip" href={x.page}>{x.name}</a>))}</div></div>
          <div class="lg"><span class="lgl">Countries</span><div class="chips">{t.countries.map(x => (<a class="chip" href={x.page}>{x.name}</a>))}</div></div>
          <div class="lg"><span class="lgl">Flows</span><div class="chips">{t.flows.map(x => (<a class="chip" href={x.page}>{x.name}</a>))}</div></div>
        </div>
        <div class="profits"><span class="pl">Who profits</span>{t.profits.join('  ·  ')}</div>
      </div>
    ))}
  </div>

  <section class="fof">
    <div class="dl">Field of forces — driver registry</div>
    <p class="fof-intro">{driverRegistry.intro}</p>
    <div class="fof-grid">
      <div class="fof-col">
        <span class="fof-h fof-on">Populated · 1</span>
        {driverRegistry.populated.map(d => (<span class="drv drv-on">{d.id}<span class="drv-cls">{d.class} · {d.status}</span></span>))}
      </div>
      <div class="fof-col">
        <span class="fof-h fof-off">Registered, awaiting research · {driverRegistry.registered.length}</span>
        <div class="drv-wrap">{driverRegistry.registered.map(d => (<span class="drv drv-off">{d.id}<span class="drv-cls">{d.class}</span></span>))}</div>
      </div>
    </div>
    <p class="fof-foot">{driverRegistry.foot}</p>
  </section>

  <section class="causal">
    <div class="dl">Cross-section causal map — weighted, multi-causal edges</div>
    <p class="causal-intro">{causalIntro}</p>
    <p class="umbrella">{causalUmbrella}</p>

    <div class="legend">
      <div class="lg-row"><b>Data</b> — {attributionLegend.dataConfidence}</div>
      <div class="lg-row"><b>Conflict share</b> — {attributionLegend.attributionStrength}</div>
      <div class="lg-row"><b>Attribution conf.</b> — {attributionLegend.attributionConfidence}</div>
      <div class="lg-row lg-note">{attributionLegend.note}</div>
    </div>

    <div class="reg-head">
      <div class="dl">Edge registry — auditable, sortable</div>
      <div class="reg-sort"><span class="reg-sortlabel">Sort</span><button class="rbtn active" data-sort="share">Conflict share</button><button class="rbtn" data-sort="status">Status</button><button class="rbtn" data-sort="data">Data conf</button><button class="rbtn" data-sort="attrib">Attribution conf</button></div>
    </div>
    <div style="overflow-x:auto"><table class="reg-tbl">
      <thead><tr><th>Edge</th><th>Status</th><th>Conflict share</th><th>Data</th><th>Attrib</th><th>Activates when</th><th>Invalidated if</th></tr></thead>
      <tbody id="reg-body">
        {edgesByShare.map(c => (
          <tr data-share={c.shareRank} data-status={c.maturity==='built'?0:1} data-data={dcMap[c.confidence] ?? 3} data-attrib={dcMap[c.attribution.confidence] ?? 3}>
            <td class="reg-edge"><a href={c.fromPage}>{c.from}</a> <span class="reg-arr">→</span> <a href={c.toPage}>{c.to}</a>{c.contrarian && (<span class="reg-ct">contrarian</span>)}</td>
            <td><span class="reg-badge" style={`color:${mat(c.maturity)};border-color:${mat(c.maturity)}66`}>{c.maturity==='built'?'Tracked':'Proposed'}</span></td>
            <td><span class="reg-share" style={`color:${strCol[c.attribution.strength]};border-color:${strCol[c.attribution.strength]}66`}>{c.attribution.strength}</span></td>
            <td><span class="reg-cc" style={`color:${acCol[c.confidence]}`}>{c.confidence}</span></td>
            <td><span class="reg-cc" style={`color:${acCol[c.attribution.confidence]}`}>{c.attribution.confidence}</span></td>
            <td class="reg-txt">{c.activation}</td>
            <td class="reg-txt reg-inv">{c.invalidation}</td>
          </tr>
        ))}
      </tbody>
    </table></div>
    <p class="reg-foot">Every edge is a hypothesis (see above). <b>Activates when</b> = the trigger that turns the edge on; <b>Invalidated if</b> = what would falsify it. Conflict share is a bucket, not a measured coefficient — sort to rank how much the Gulf conflict plausibly owns. The detailed cards below carry the full mechanism, indicator, competing drivers and residual.</p>

    <div class="filters">
      <span class="flabel">Filter by scenario</span>
      <button class="fbtn active" data-scen="all">All</button>
      {scenarioKeys.map(k => (<button class="fbtn" data-scen={k} style={`--sc:${sc[k]}`}>{scenLabel(k)}</button>))}
    </div>

    <div class="cl-list">
      {causalLinks.map(c => (
        <div class="cl" data-scenarios={c.scenarios.join(' ')} style={`border-left:3px solid ${mat(c.maturity)}`}>
          <div class="cl-head">
            <span class="cl-chain"><a href={c.fromPage}>{c.from}</a> <span class="cl-arrow">→</span> <a href={c.toPage}>{c.to}</a></span>
            <span class="cl-badge" style={`color:${mat(c.maturity)};border-color:${mat(c.maturity)}`}>{c.maturity === 'built' ? 'Tracked' : 'Proposed'}</span>{c.contrarian && (<span class="cl-tag">contrarian</span>)}
          </div>
          <p class="cl-why">{c.why}</p>
          <div class="cl-ind"><span class="cl-k">Indicator</span><span>{c.indicator}</span></div>
          <div class="attrib">
            <span class="ab" style={`color:${strCol[c.attribution.strength]};border-color:${strCol[c.attribution.strength]}66`}>conflict share: {c.attribution.strength}</span>
            <span class="ab" style={`color:${acCol[c.attribution.confidence]};border-color:${acCol[c.attribution.confidence]}66`}>attribution conf: {c.attribution.confidence}</span>
            <span class="ab" style={`color:${acCol[c.confidence]};border-color:${acCol[c.confidence]}66`}>data: {c.confidence}</span>
          </div>
          <div class="cd"><span class="cd-k">Competing drivers</span><div class="cd-chips">{c.competingDrivers.map(d => (<span class="cd-chip" title={d.note}>{d.driver}<span class="cd-cls">{d.cls}</span></span>))}</div></div>
          <p class="resid"><span class="resid-k">Residual</span>{c.residual}</p>
          <div class="cl-meta">{c.scenarios.map(scn => (<span class="sc-chip" style={`color:${sc[scn]};border-color:${sc[scn]}55`}>{scenLabel(scn)}</span>))}</div>
        </div>
      ))}
    </div>
    <p class="causal-foot">Each edge is a weighted hypothesis, not an asserted single cause. <b>Conflict share</b> marks how much of the effect the Gulf conflict plausibly owns; several edges (minerals, tariffs, gold) are <b>marginal</b> — dominated by other registered drivers above. Proposed edges await external primary data to graduate from proposed to tracked — see the Phase-3 research brief. They are flagged, never anchored.</p>
  </section>

  <section class="scen">
    <div class="dl">Scenario field matrix — beneficiaries, horizon &amp; attribution</div>
    <div style="overflow-x:auto"><table class="stbl">
      <thead><tr><th>Scenario</th><th>Beneficiaries</th><th>Horizon</th><th>Competing / confounding drivers</th><th>Attribution confidence</th></tr></thead>
      <tbody>
        {scenarioAttribution.map(s => (
          <tr>
            <td><span class="scn-tag" style={`color:${s.tone};border-color:${s.tone}66`}>{s.label}</span></td>
            <td>{s.beneficiaries}</td>
            <td class="hz">{s.horizon}</td>
            <td class="cf">{s.competingDrivers}</td>
            <td class="ac">{s.attributionConfidence}</td>
          </tr>
        ))}
      </tbody>
    </table></div>
    <p class="scen-foot">Horizon is time-to-impact; the attribution column is the honest counterweight to the beneficiaries column — who wins, but also how much of it the conflict actually drives versus the macro regime around it.</p>
  </section>

  <div class="sn-box"><div class="dl">How to read this</div><p>Each thread is one shock viewed across all three analysis pages; chips link to the relevant section. The causal map below adds the horizontal edges between sections — every edge names its competing drivers and carries an explicit residual, because correlation is not causation. This is a prototype for a multi-driver platform: the conflict is one force in the field above, not the only one.</p></div>
</AnalysisLayout>

<script>
  const btns = document.querySelectorAll('.fbtn');
  const rows = document.querySelectorAll('.cl-list .cl');
  btns.forEach((b) => b.addEventListener('click', () => {
    btns.forEach((x) => x.classList.remove('active'));
    b.classList.add('active');
    const s = b.getAttribute('data-scen');
    rows.forEach((r) => {
      const sm = (r.getAttribute('data-scenarios') || '').split(' ');
      r.style.display = (s === 'all' || sm.includes(s)) ? '' : 'none';
    });
  }));

  const rbtns = document.querySelectorAll('.rbtn');
  const regBody = document.getElementById('reg-body');
  if (regBody) rbtns.forEach((b) => b.addEventListener('click', () => {
    rbtns.forEach((x) => x.classList.remove('active'));
    b.classList.add('active');
    const attr = 'data-' + b.getAttribute('data-sort');
    Array.from(regBody.querySelectorAll('tr'))
      .sort((x, y) => (parseFloat(x.getAttribute(attr)) || 9) - (parseFloat(y.getAttribute(attr)) || 9))
      .forEach((r) => regBody.appendChild(r));
  }));
</script>

<style>
  .hero{margin-bottom:2.5rem;padding-bottom:2rem;border-bottom:1px solid var(--border)}
  .label{font-family:var(--font-mono);font-size:11px;color:var(--cyan);letter-spacing:3px;text-transform:uppercase;margin-bottom:16px}
  .hero h1{font-family:var(--font-display);font-size:clamp(1.8rem,3.5vw,2.4rem);font-weight:400;color:var(--text);line-height:1.15;margin-bottom:1rem}
  .lead{font-size:15px;color:var(--text-muted);line-height:1.7;max-width:680px}
  .theme-list{display:flex;flex-direction:column;gap:12px;margin-bottom:2rem}
  .theme{background:var(--bg-surface);border:1px solid var(--border);border-radius:10px;padding:18px 20px}
  .tn{font-size:15px;font-weight:700;margin-bottom:8px}
  .thesis{font-size:13px;color:var(--text-muted);line-height:1.65;margin:0 0 14px}
  .links{display:grid;grid-template-columns:1fr 1fr 1fr;gap:14px;margin-bottom:14px}
  .lgl{font-family:var(--font-mono);font-size:10px;font-weight:700;color:var(--cyan);text-transform:uppercase;letter-spacing:1.5px;display:block;margin-bottom:6px}
  .chips{display:flex;flex-wrap:wrap;gap:5px}
  .chip{font-family:var(--font-mono);font-size:11px;color:var(--text-dim);background:var(--bg-card,#0d1117);border:1px solid var(--border);border-radius:5px;padding:3px 8px;text-decoration:none;white-space:nowrap}
  .chip:hover{color:var(--text);border-color:var(--cyan)}
  .profits{font-size:12px;color:var(--text);line-height:1.6;border-top:1px solid var(--border);padding-top:12px}
  .pl{font-family:var(--font-mono);font-size:10px;font-weight:700;color:var(--text-dim);text-transform:uppercase;letter-spacing:1.5px;margin-right:10px}
  .sn-box{background:var(--bg-surface);border:1px solid var(--border);border-radius:8px;padding:16px 20px;margin-top:2rem}
  .dl{font-family:var(--font-mono);font-size:10px;font-weight:700;color:var(--cyan);text-transform:uppercase;letter-spacing:1.5px;margin-bottom:6px}
  .sn-box p{font-size:12px;color:var(--text-dim);line-height:1.6;margin:0}
  @media(max-width:720px){.links{grid-template-columns:1fr}}
  /* field of forces */
  .fof{margin:0 0 2rem;background:var(--bg-surface);border:1px solid var(--border);border-radius:10px;padding:16px 20px}
  .fof-intro{font-size:12.5px;color:var(--text-muted);line-height:1.6;margin:6px 0 14px;max-width:880px}
  .fof-grid{display:grid;grid-template-columns:1fr 2fr;gap:18px}
  .fof-h{font-family:var(--font-mono);font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:1px;display:block;margin-bottom:8px}
  .fof-on{color:#22d3ee}.fof-off{color:var(--text-dim)}
  .drv{display:inline-flex;flex-direction:column;font-family:var(--font-mono);font-size:11px;border:1px solid;border-radius:6px;padding:5px 9px;margin:0 6px 6px 0}
  .drv-on{color:#22d3ee;border-color:#22d3ee66;background:rgba(34,211,238,.06)}
  .drv-off{color:var(--text-muted);border-color:var(--border)}
  .drv-cls{font-size:9px;color:var(--text-dim);margin-top:2px}
  .drv-wrap{display:flex;flex-wrap:wrap}
  .fof-foot{font-size:11px;color:var(--text-dim);line-height:1.5;margin-top:10px}
  @media(max-width:720px){.fof-grid{grid-template-columns:1fr}}
  /* legend */
  .legend{background:var(--bg-card,#0d1117);border:1px solid var(--border);border-radius:8px;padding:10px 14px;margin-bottom:14px}
  .lg-row{font-size:11.5px;color:var(--text-muted);line-height:1.55}
  .lg-row b{color:var(--text);font-family:var(--font-mono);font-size:10px;text-transform:uppercase;letter-spacing:.5px}
  .lg-note{color:var(--text-dim);font-style:italic;margin-top:5px;border-top:1px dashed var(--border);padding-top:6px}
  /* filters */
  .filters{display:flex;flex-wrap:wrap;align-items:center;gap:7px;margin-bottom:14px}
  .flabel{font-family:var(--font-mono);font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:1px;color:var(--text-dim);margin-right:4px}
  .fbtn{font-family:var(--font-mono);font-size:11px;color:var(--text-muted);background:var(--bg-card,#0d1117);border:1px solid var(--border);border-radius:6px;padding:4px 10px;cursor:pointer;text-transform:capitalize;transition:all .15s}
  .fbtn:hover{color:var(--text);border-color:var(--sc,var(--border-light))}
  .fbtn.active{color:var(--cyan);border-color:var(--cyan);background:var(--cyan-muted)}
  .causal{margin:0 0 2rem}
  .causal-intro{font-size:13px;color:var(--text-muted);line-height:1.65;max-width:880px;margin:0 0 16px}
  .cl-list{display:flex;flex-direction:column;gap:10px}
  .cl{background:var(--bg-surface);border:1px solid var(--border);border-radius:10px;padding:14px 18px}
  .cl-head{display:flex;justify-content:space-between;align-items:flex-start;gap:12px;margin-bottom:8px;flex-wrap:wrap}
  .cl-chain{font-size:14px;font-weight:700;color:var(--text)}
  .cl-chain a{color:var(--text);text-decoration:none;border-bottom:1px dotted var(--text-dim)}
  .cl-chain a:hover{color:var(--cyan);border-color:var(--cyan)}
  .cl-arrow{color:var(--text-dim);margin:0 4px}
  .cl-badge{font-family:var(--font-mono);font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:1px;padding:2px 8px;border:1px solid;border-radius:4px;white-space:nowrap}
  .cl-why{font-size:12.5px;color:var(--text-muted);line-height:1.6;margin:0 0 10px;max-width:860px}
  .cl-ind{display:grid;grid-template-columns:90px 1fr;gap:10px;align-items:baseline;background:var(--bg-card,#0d1117);border:1px solid var(--border);border-radius:6px;padding:8px 12px}
  .cl-k{font-family:var(--font-mono);font-size:9px;font-weight:700;color:var(--cyan);text-transform:uppercase;letter-spacing:1px}
  .cl-ind span:last-child{font-family:var(--font-mono);font-size:11px;color:var(--text-muted);line-height:1.5}
  .attrib{display:flex;flex-wrap:wrap;gap:6px;margin-top:10px}
  .ab{font-family:var(--font-mono);font-size:9.5px;font-weight:700;text-transform:uppercase;letter-spacing:.5px;border:1px solid;border-radius:4px;padding:2px 8px}
  .cd{margin-top:10px}
  .cd-k{font-family:var(--font-mono);font-size:9px;font-weight:700;color:var(--text-dim);text-transform:uppercase;letter-spacing:1px;display:block;margin-bottom:5px}
  .cd-chips{display:flex;flex-wrap:wrap;gap:5px}
  .cd-chip{display:inline-flex;flex-direction:column;font-size:11px;color:var(--text-muted);background:var(--bg-card,#0d1117);border:1px solid var(--border);border-radius:5px;padding:3px 8px;cursor:help}
  .cd-cls{font-family:var(--font-mono);font-size:8.5px;color:var(--text-dim);margin-top:1px}
  .resid{font-size:11.5px;color:var(--text-dim);line-height:1.55;margin:10px 0 0;font-style:italic}
  .resid-k{font-family:var(--font-mono);font-size:9px;font-weight:700;color:var(--text-dim);text-transform:uppercase;letter-spacing:1px;margin-right:8px;font-style:normal}
  .cl-meta{display:flex;align-items:center;gap:6px;margin-top:10px;flex-wrap:wrap}
  .sc-chip{font-family:var(--font-mono);font-size:9px;border:1px solid;border-radius:4px;padding:2px 7px;text-transform:capitalize}
  .causal-foot{font-size:11px;color:var(--text-dim);line-height:1.55;margin-top:12px;max-width:880px}
  .causal-foot b{color:var(--text-muted)}
  /* scenario matrix */
  .scen{margin:0 0 1rem}
  .stbl{width:100%;border-collapse:collapse;font-size:12px}
  .stbl th{font-family:var(--font-mono);font-size:9px;text-transform:uppercase;letter-spacing:.5px;color:var(--text-dim);text-align:left;padding:8px 10px;border-bottom:1px solid var(--border-light);white-space:nowrap}
  .stbl td{padding:10px;border-bottom:1px solid var(--border);vertical-align:top;color:var(--text-muted);line-height:1.5}
  .scn-tag{font-family:var(--font-mono);font-size:10px;font-weight:700;border:1px solid;border-radius:4px;padding:2px 8px;white-space:nowrap}
  .stbl .hz{font-size:11.5px;color:var(--text-dim)}
  .stbl .cf{font-size:11.5px;color:var(--text-dim)}
  .stbl .ac{font-size:11px;color:var(--text-muted)}
  .scen-foot{font-size:11px;color:var(--text-dim);line-height:1.55;margin-top:10px;max-width:880px}
  @media(max-width:720px){.cl-ind{grid-template-columns:1fr;gap:3px}}
  .umbrella{font-size:12px;color:var(--text);line-height:1.6;margin:0 0 16px;padding:10px 14px;border-left:3px solid var(--cyan);background:var(--cyan-muted);border-radius:0 6px 6px 0;max-width:880px}
  .cl-tag{font-family:var(--font-mono);font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:1px;color:#8b5cf6;border:1px solid #8b5cf666;border-radius:4px;padding:2px 8px;white-space:nowrap;margin-left:6px}
  .reg-head{display:flex;flex-wrap:wrap;align-items:center;justify-content:space-between;gap:10px;margin:1.5rem 0 10px}
  .reg-sort{display:flex;flex-wrap:wrap;gap:5px;align-items:center}
  .reg-sortlabel{font-family:var(--font-mono);font-size:10px;text-transform:uppercase;letter-spacing:1px;color:var(--text-dim);margin-right:3px}
  .rbtn{font-family:var(--font-mono);font-size:10px;color:var(--text-muted);background:var(--bg-card,#0d1117);border:1px solid var(--border);border-radius:5px;padding:3px 9px;cursor:pointer;transition:all .15s}
  .rbtn:hover{color:var(--text);border-color:var(--border-light)}
  .rbtn.active{color:var(--cyan);border-color:var(--cyan);background:var(--cyan-muted)}
  .reg-tbl{width:100%;border-collapse:collapse;font-size:11.5px}
  .reg-tbl th{font-family:var(--font-mono);font-size:9px;text-transform:uppercase;letter-spacing:.5px;color:var(--text-dim);text-align:left;padding:7px 8px;border-bottom:1px solid var(--border-light);white-space:nowrap}
  .reg-tbl td{padding:8px;border-bottom:1px solid var(--border);vertical-align:top;line-height:1.45}
  .reg-tbl tr:hover td{background:rgba(255,255,255,.02)}
  .reg-edge{min-width:190px;font-weight:600;color:var(--text)}
  .reg-edge a{color:var(--text);border-bottom:1px dotted var(--text-dim)}
  .reg-edge a:hover{color:var(--cyan);border-color:var(--cyan)}
  .reg-arr{color:var(--text-dim);margin:0 3px}
  .reg-ct{font-family:var(--font-mono);font-size:8px;text-transform:uppercase;letter-spacing:.5px;color:#8b5cf6;border:1px solid #8b5cf655;border-radius:3px;padding:0 5px;margin-left:6px;white-space:nowrap}
  .reg-badge{font-family:var(--font-mono);font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:.5px;border:1px solid;border-radius:4px;padding:1px 6px;white-space:nowrap}
