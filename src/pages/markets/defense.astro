---
import AnalysisLayout from '../../layouts/AnalysisLayout.astro';
import SignalPanel from '../../components/SignalPanel.astro';
import { cards, thesis, drawdownTable, drawdownNote, scaleupTable, spendingNote, scenarioMatrix, investmentImplications, resilience, sourceResolution, dataQuality, relatedSectors } from '../../data/analysis/defense.js';
import { positioning, hedgingPlaybook } from '../../data/analysis/crossasset.js';
const ca_def = positioning.find(p => p.channel.startsWith('Defense'));
const ca_hpb = hedgingPlaybook.find(h => h.scenario === 'hormuz_closure');
---

<AnalysisLayout
  title="Defense & Security — VegaReady"
  description="The arsenal drawdown and procurement supercycle: CSIS Last Rounds (~50% Patriot, >50% THAAD expended), replenishment to 2029–2030, the production scale-up, $2.887tn global spending, and the new subsea-cable and mine-clearing chokepoints."
  section="Defense"
  area="markets"
>
  <section class="hero">
    <div class="label">Markets · Defense &amp; Security</div>
    <h1>The arsenal ran<br/>low. The order book didn't.</h1>
    <p class="lead">The 39-day campaign structurally drew down the US and allied arsenal and opened a multi-year procurement supercycle a ceasefire does not close. CSIS found ~50% of Patriot and &gt;50% of THAAD expended; replenishment runs to 2029–2030. The investable edge is durability — order books are ceasefire-insensitive — tempered by a caveat that some defense equities ran ahead of confirmed demand.</p>
  </section>

  <SignalPanel page="/markets/defense" />

  <div class="thesis">
    <div class="thesis-label">The structural finding</div>
    <p>{thesis}</p>
  </div>

  <section class="prec">
    <div class="dl">Arsenal drawdown &amp; replenishment — CSIS Last Rounds</div>
    <div style="overflow-x:auto"><table class="prec-table">
      <thead><tr><th>System</th><th>Drawdown / usage</th><th>Replenishment</th></tr></thead>
      <tbody>{drawdownTable.map((r) => (<tr><td class="prec-name">{r.system}</td><td class="mig-hi">{r.drawdown}</td><td>{r.replenish}</td></tr>))}</tbody>
    </table></div>
    <p class="prec-note">{drawdownNote}</p>
  </section>

  <section class="prec">
    <div class="dl">Production scale-up — framework contracts</div>
    <div style="overflow-x:auto"><table class="prec-table">
      <thead><tr><th>Program</th><th>Capacity change</th><th>Detail</th></tr></thead>
      <tbody>{scaleupTable.map((r) => (<tr><td class="prec-name">{r.program}</td><td class="mig-hi">{r.change}</td><td>{r.detail}</td></tr>))}</tbody>
    </table></div>
  </section>

  <div class="callout">
    <div class="callout-label">Spending macro</div>
    <p>{spendingNote}</p>
  </div>

  <div class="ev-list">
    {cards.map((c) => (
      <details class="ev">
        <summary class="es">
          <div class="el"><span class="en">{c.icon}</span><div>
            <div class="et">{c.title}<span class="cat">{c.category}</span></div>
            <div class="eb">{c.summary}</div>
          </div></div>
          <span class={`conf conf-${c.confidence}`}>{c.confidence}</span>
        </summary>
        <div class="ey">
          <div class="mgrid">{c.metrics.map((mm) => (<div class="metric"><div class="ml">{mm.label}</div><div class="mv">{mm.value}</div></div>))}</div>
          {c.sources.length > 0 && <div class="ds"><div class="dl">Sources</div><p class="srctext">{c.sources.map((u, i) => (<a href={u.url} target="_blank" rel="noopener" style="color:#60a5fa;margin-right:10px;font-size:13px;text-decoration:none">[{i + 1}]</a>))}</p></div>}
        </div>
      </details>
    ))}
  </div>

  <section class="scen">
    <div class="dl">Scenario impact — procurement</div>
    {scenarioMatrix.map((s) => (
      <div class="scen-block" style={`border-left:3px solid ${s.tone}`}>
        <div class="scen-name" style={`color:${s.tone}`}>{s.scenario} — {s.label}</div>
        <p class="scen-impact">{s.impact}</p>
      </div>
    ))}
  </section>

  <section class="inv">
    <div class="dl">Investment implications</div>
    {investmentImplications.map((it) => (<div class="inv-block"><div class="inv-name">{it.stakeholder}</div><p>{it.text}</p></div>))}
  </section>

  <section class="res">
    <div class="dl">Reconstruction &amp; resilience premium</div>
    <p class="res-thesis">{resilience.thesis}</p>
    <div class="res-grid">{resilience.winners.map((w) => (<div class="res-block"><div class="res-name">{w.area}</div><p>{w.text}</p></div>))}</div>
    <p class="prec-note"><strong style="color:var(--text)">Timeline:</strong> {resilience.timeline} &nbsp;·&nbsp; <a href="/outlook/infrastructure" style="color:var(--cyan)">Full infrastructure resilience &rarr;</a></p>
  </section>

  <section class="sres">
    <div class="dl">Source-conflict resolution</div>
    {sourceResolution.map((r) => (<div class="sres-block"><span class="sres-item">{r.item}</span><span class="sres-res">{r.resolution}</span></div>))}
  </section>

  <section class="mdr">
    <div class="mdr-h">Market-derivative read <span>· Cross-Asset</span></div>
    <div class="mdr-rows">
      <div class="mdr-row"><span class="mdr-k">Defense-equity flows</span><span class="mdr-v">{ca_def.data}</span></div>
      <div class="mdr-row"><span class="mdr-k">As a hedge</span><span class="mdr-v">Long-defense was among the most reliable conflict hedges; order books are backlogged to 2029–2030, making demand ceasefire-insensitive</span></div>
      <div class="mdr-row"><span class="mdr-k">Failure mode</span><span class="mdr-v">Ceasefire-whipsaw — energy/defense unwind fast on de-escalation (the cyclical component)</span></div>
      <div class="mdr-row"><span class="mdr-k">Upstream (equities)</span><span class="mdr-v">A §8 sector winner: PPA +37.8% / ITA +38.3% / SHLD +47.8% (12-mo)</span></div>
    </div>
    <a href="/markets/cross-asset" class="mdr-link">Full cross-asset view →</a> <span style="color:var(--text-dim)">·</span> <a href="/markets/equities" class="mdr-link">Defense sector (equities) →</a>
  </section>

  <div class="foot-box">
    <div class="dl">Data quality &amp; methodology</div>
    <p><strong style="color:#10b981">HIGH</strong> — {dataQuality.high}</p>
    <p><strong style="color:#f59e0b">MODERATE</strong> — {dataQuality.moderate}</p>
    <p><strong style="color:var(--text-dim)">Quarantined (not anchored)</strong> — {dataQuality.quarantined}</p>
    <p class="next"><strong>Related:</strong> {relatedSectors} &nbsp;·&nbsp; <a href="/transmission" style="color:var(--cyan)">Defense &amp; Security cascade &rarr;</a></p>
  </div>
</AnalysisLayout>

<style>
  .hero{margin-bottom:3rem;padding-bottom:2rem;border-bottom:1px solid var(--border)}
  .label{font-family:var(--font-mono);font-size:11px;color:var(--cyan);letter-spacing:3px;text-transform:uppercase;margin-bottom:16px}
  .hero h1{font-family:var(--font-display);font-size:clamp(1.8rem,3.5vw,2.4rem);font-weight:400;color:var(--text);line-height:1.15;margin-bottom:1rem}
  .lead{font-size:15px;color:var(--text-muted);line-height:1.7;max-width:720px}
  .thesis{background:var(--bg-surface);border:1px solid var(--border);border-left:3px solid #22d3ee;border-radius:8px;padding:16px 20px;margin-bottom:2.5rem;max-width:820px}
  .thesis-label{font-family:var(--font-mono);font-size:10px;font-weight:700;color:#22d3ee;text-transform:uppercase;letter-spacing:1.5px;margin-bottom:8px}
  .thesis p{font-size:14px;color:var(--text-muted);line-height:1.7;margin:0}
  .callout{font-size:13px;color:var(--text-muted);line-height:1.65;padding:14px 18px;background:var(--bg-surface);border:1px solid var(--border);border-left:3px solid var(--cyan);border-radius:8px;max-width:820px;margin-bottom:3rem}
  .callout-label{font-family:var(--font-mono);font-size:10px;font-weight:700;color:var(--cyan);text-transform:uppercase;letter-spacing:1.5px;margin-bottom:8px}
  .callout p{margin:0}
  .prec{margin-bottom:3rem}
  .prec-table{width:100%;border-collapse:collapse;font-size:12px;margin-top:12px}
  .prec-table th{padding:8px 10px;text-align:left;border-bottom:2px solid var(--border);font-family:var(--font-mono);font-size:10px;font-weight:700;letter-spacing:1px;text-transform:uppercase;color:var(--text-dim);white-space:nowrap}
  .prec-table td{padding:7px 10px;border-bottom:1px solid var(--border);color:var(--text-dim);line-height:1.4;vertical-align:top;min-width:90px}
  .prec-name{font-weight:700;color:var(--text)}
  .mig-hi{color:#22d3ee;font-weight:700;font-family:var(--font-mono)}
  .prec-note{font-size:12px;color:var(--text-dim);line-height:1.6;margin-top:10px;max-width:820px}
  .ev-list{display:flex;flex-direction:column;gap:8px;margin-bottom:3rem}
  .ev{background:var(--bg-surface);border:1px solid var(--border);border-radius:10px;overflow:hidden}
  .ev[open]{border-color:var(--border-light)}
  .ev[open] .es{border-bottom:1px solid var(--border)}
  .es{display:flex;justify-content:space-between;align-items:flex-start;padding:16px 20px;cursor:pointer;list-style:none;gap:12px}
  .es::-webkit-details-marker{display:none}
  .es::marker{content:''}
  .es:hover{background:rgba(255,255,255,0.02)}
  .el{display:flex;gap:14px;flex:1;min-width:0}
  .en{font-family:var(--font-mono);font-size:12px;font-weight:700;color:var(--cyan);min-width:22px;padding-top:2px}
  .et{font-size:15px;font-weight:700;color:var(--text);margin-bottom:4px;display:flex;align-items:center;gap:8px;flex-wrap:wrap}
  .cat{font-family:var(--font-mono);font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:1px;padding:1px 7px;border:1px solid var(--border);border-radius:4px;color:var(--text-dim)}
  .eb{font-size:12px;color:var(--text-dim);line-height:1.5;display:-webkit-box;-webkit-line-clamp:3;-webkit-box-orient:vertical;overflow:hidden}
  .conf{font-family:var(--font-mono);font-size:10px;font-weight:700;padding:2px 8px;border-radius:4px;white-space:nowrap;flex-shrink:0;margin-top:2px}
  .conf-high{color:#10b981;background:rgba(16,185,129,0.1)}
  .conf-medium{color:#f59e0b;background:rgba(245,158,11,0.1)}
  .conf-low{color:#ef4444;background:rgba(239,68,68,0.1)}
  .ey{padding:16px 20px 20px}
  .mgrid{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:16px}
  .metric{padding:10px 14px;background:var(--bg-card);border:1px solid var(--border);border-radius:6px}
  .ml{font-family:var(--font-mono);font-size:9px;font-weight:700;color:var(--cyan);text-transform:uppercase;letter-spacing:1px;margin-bottom:4px}
  .mv{font-size:13px;color:var(--text-muted);line-height:1.45}
  .ds{margin-bottom:0}
  .dl{font-family:var(--font-mono);font-size:10px;font-weight:700;color:var(--cyan);text-transform:uppercase;letter-spacing:1.5px;margin-bottom:6px}
  .srctext{font-size:13px;color:var(--text-muted);line-height:1.6;margin:0}
  .scen{margin-bottom:3rem}
  .scen-block{background:var(--bg-surface);border:1px solid var(--border);border-radius:8px;padding:14px 18px;margin-top:10px}
  .scen-name{font-size:14px;font-weight:700;margin-bottom:6px}
  .scen-impact{font-size:13px;color:var(--text-muted);line-height:1.6;margin:0}
  .inv{margin-bottom:3rem}
  .inv-block{margin-top:14px}
  .inv-name{font-family:var(--font-mono);font-size:11px;font-weight:700;color:var(--cyan);text-transform:uppercase;letter-spacing:1px;margin-bottom:5px}
  .inv-block p{font-size:13px;color:var(--text-muted);line-height:1.6;margin:0}
  .res{margin-bottom:3rem}
  .res-thesis{font-size:13px;color:var(--text-muted);line-height:1.65;margin:0 0 14px;max-width:820px}
  .res-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px}
  .res-block{background:var(--bg-surface);border:1px solid var(--border);border-radius:8px;padding:12px 16px}
  .res-name{font-family:var(--font-mono);font-size:11px;font-weight:700;color:#22d3ee;margin-bottom:5px}
  .res-block p{font-size:12px;color:var(--text-dim);line-height:1.55;margin:0}
  .sres{margin-bottom:2rem}
  .sres-block{display:flex;gap:14px;padding:8px 0;border-bottom:1px solid var(--border)}
  .sres-item{font-size:12px;font-weight:700;color:var(--text);min-width:230px;flex-shrink:0}
  .sres-res{font-size:12px;color:var(--text-dim);line-height:1.5}
  .foot-box{background:var(--bg-surface);border:1px solid var(--border);border-radius:8px;padding:16px 20px;margin-bottom:1rem}
  .foot-box p{font-size:12px;color:var(--text-dim);line-height:1.6;margin:0 0 8px}
  .foot-box .next{margin:0}
  .foot-box strong{color:var(--cyan)}
  @media(max-width:720px){.mgrid{grid-template-columns:1fr}.res-grid{grid-template-columns:1fr}.eb{display:none}.sres-block{flex-direction:column;gap:4px}.sres-item{min-width:0}}
  .mdr{background:var(--bg-surface);border:1px solid var(--border);border-left:3px solid #818cf8;border-radius:8px;padding:14px 18px;margin:0 0 2rem;max-width:860px}
  .mdr-h{font-family:var(--font-mono);font-size:10px;font-weight:700;color:#818cf8;text-transform:uppercase;letter-spacing:1.5px;margin-bottom:10px}
  .mdr-h span{color:var(--text-dim)}
  .mdr-rows{display:flex;flex-direction:column;gap:7px;margin-bottom:10px}
  .mdr-row{display:grid;grid-template-columns:150px 1fr;gap:12px;align-items:baseline}
  .mdr-k{font-family:var(--font-mono);font-size:10px;font-weight:700;color:var(--cyan);text-transform:uppercase;letter-spacing:.5px}
  .mdr-v{font-size:12px;color:var(--text-muted);line-height:1.5}
  .mdr-note{font-size:11px;color:#f59e0b;margin:0 0 10px;line-height:1.4}
  .mdr-link{font-family:var(--font-mono);font-size:11px;font-weight:700;color:var(--cyan);text-decoration:none}
  @media(max-width:720px){.mdr-row{grid-template-columns:1fr;gap:2px}}
</style>
