---
import '../../../styles/desk.css';
import '../../../styles/desk-content.css';
import '../../../styles/desk-v2.css';
import '../../../styles/skin-steel.css';
const modules = [
  ['Live factor returns', 'Trailing 1m / 3m / 12m returns for value, size, momentum, quality and low-vol from the free Kenneth French daily files, with the funding-stress playbook overlaid.'],
  ['Crowding monitor', 'Factor-level crowding proxies — valuation spreads within factors, pairwise factor correlations, and the momentum-rising-into-stress tell from August 2007.'],
  ['Value−growth spread', 'The HML spread vs its own history, with the epicenter caveat: its crisis sign depends on whether financials/energy are the shock’s source or its beneficiary.'],
  ['Quality stress-test', 'RMW behaviour conditioned on shock type — the defends-except-dash-for-cash rule, tracked live against the stock–bond correlation regime.'],
];
---
<!doctype html>
<html lang="en" data-theme="t1" data-skin="steel" data-disc="deep">
<head>
  <meta charset="UTF-8" /><meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Factor Lab — Equities · VegaReady</title>
  <meta name="description" content="Live factor returns, crowding monitors and stress-conditioned factor behaviour for the equities desk. In build, from reproducible public data." />
  <meta name="robots" content="noindex" />
</head>
<body data-mode="analyst" data-disc="deep">
  <header class="masthead"><div class="wrap">
    <a class="wordmark" href="/today">VEGA<i>READY</i></a>
    <nav class="mast-right" aria-label="Primary"><a class="navlink" href="/today">Today</a><a class="navlink" href="/catalysts">Catalysts</a><a class="navlink on" href="/markets">Markets</a><a class="navlink" href="/structural/watch">Signals</a><a class="navlink" href="/about">About</a></nav>
  </div></header>
  <section class="dsec stubtop"><div class="wrap">
    <div class="eyebrow">Markets · Equities · Factor lab</div>
    <h1 class="stub-h1">The factor lab.</h1>
    <p class="lead stub-lead">Factors are how funding stress travels through the equity market — so they get their own instrument panel. This page is <b>in build</b>: the modules below are committed and wire in with the data layer. Until live, the main desk’s §7 carries the episode-tested playbook.</p>
    <div class="stubgrid">{modules.map((m) => (<div class="stub-card"><div class="st-h">{m[0]}</div><p>{m[1]}</p><span class="st-tag">in build · honest placeholder</span></div>))}</div>
    <p class="tnote">Primary inputs: Kenneth French Data Library (free dailies/monthlies) · MSCI/AQR investable proxies for orientation · the §2 episode table. No vendor positioning estimates will be republished here.</p>
    <a class="cta-frame cta-h stub-back" href="/markets/equities#factors">Back to the equities desk →</a>
  </div></section>
  <footer><div class="wrap"><div class="legal">© 2026 JCJ Investing LLC. Research and intelligence, not investment advice. Items marked "in build" are honest placeholders for committed modules.</div></div></footer>
  <style>
    .stubtop{padding-top:48px}
    .stub-h1{font-family:'Playfair Display',Georgia,serif;font-size:38px;font-weight:700;color:var(--ink);margin:8px 0 14px}
    .stub-lead{max-width:78ch}
    .stubgrid{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin:22px 0 16px}
    .stub-card{background:var(--card);border:1px solid var(--cardline);border-top:3px solid var(--eyeb);border-radius:11px;padding:15px 19px}
    .st-h{font-family:'Fraunces',serif;font-size:15.5px;font-weight:600;color:var(--ink);margin-bottom:7px}
    .stub-card p{font-size:14px;line-height:1.58;color:var(--body);margin:0 0 10px}
    .st-tag{font-family:'Lora',serif;font-size:8.5px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--latent);border:1px dashed color-mix(in srgb,var(--latent) 40%,transparent);border-radius:3px;padding:2px 7px}
    .stub-back{margin-top:10px}
    @media(max-width:760px){.stubgrid{grid-template-columns:1fr}.stub-h1{font-size:30px}}
  </style>
</body>
</html>
