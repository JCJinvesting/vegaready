---
import '../../../styles/desk.css';
import '../../../styles/desk-content.css';
import '../../../styles/desk-v2.css';
import '../../../styles/skin-steel.css';
import Wayfinder from '../../../components/Wayfinder.astro';
const modules = [
  ['Blackout heat-map', 'The buyback blackout calendar derived from public earnings dates (the “5 weeks before, 48h after” overlay + NASPP window stats), shown as share of index market cap in blackout — with the contested-effect caveat and the 10b5-1 nuance stated inline.'],
  ['Positioning proxies', 'CFTC TFF leveraged-fund net positioning and the OFR Hedge Fund Monitor’s index-futures exposure — the free weekly stack, charted with release-lag labels so cadence is never misread.'],
  ['0DTE & options activity', 'Cboe/OCC volume, share-of-volume and put-call series — the documented growth (>40% of SPX volume by mid-2023, ~56% by Feb 2025) tracked forward.'],
  ['GEX regime (qualitative)', 'A positive/negative gamma-regime flag with the dealer-positioning assumption flagged every time it renders. No flip-level lines — the level is a vendor model, not a fact.'],
];
---
<!doctype html>
<html lang="en" data-theme="t1" data-skin="steel" data-disc="deep">
<head>
  <meta charset="UTF-8" /><meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Plumbing Monitor — Equities · VegaReady</title>
  <meta name="description" content="Buyback blackout calendar, CFTC/OFR positioning proxies, 0DTE activity and a qualitative gamma regime — the equities desk's mechanical-flow monitor. In build." />
  <meta name="robots" content="noindex" />
</head>
<body data-mode="analyst" data-disc="deep">
  <header class="masthead"><div class="wrap">
    <a class="wordmark" href="/today">VEGA<i>READY</i></a>
    <nav class="mast-right" aria-label="Primary"><a class="navlink" href="/today">Today</a><a class="navlink" href="/catalysts">Catalysts</a><a class="navlink on" href="/markets">Markets</a><a class="navlink" href="/structural/watch">Signals</a><a class="navlink" href="/about">About</a></nav>
  </div></header>
  <Wayfinder
    trail={[{ label: 'Markets', href: '/markets' }, { label: 'Equities', href: '/markets/equities' }, { label: 'Plumbing monitor' }]}
    rail={[
      { label: 'Episodes', href: '/markets/equities/episodes', tag: 'in build' },
      { label: 'Factor lab', href: '/markets/equities/factor-lab', tag: 'in build' },
      { label: 'Plumbing', href: '/markets/equities/plumbing', current: true, tag: 'in build' },
    ]}
  />
  <section class="dsec stubtop"><div class="wrap">
    <div class="eyebrow">Markets · Equities · Plumbing monitor</div>
    <h1 class="stub-h1">The plumbing monitor.</h1>
    <p class="lead stub-lead">The mechanical flows that move the tape without a fundamental in sight — built <b>only</b> from free, reproducible sources, with every vendor-dependent estimate kept qualitative and assumption-flagged. This page is <b>in build</b>; the main desk’s §8 carries the free-vs-vendor doctrine until the feeds wire in.</p>
    <div class="stubgrid">{modules.map((m) => (<div class="stub-card"><div class="st-h">{m[0]}</div><p>{m[1]}</p><span class="st-tag">in build · honest placeholder</span></div>))}</div>
    <p class="tnote">Primary inputs: CFTC COT/TFF · OFR Hedge Fund Monitor · Cboe/OCC · public earnings calendars · NASPP/PwC blackout norms. Vendor de-grossing point estimates (Nomura, Goldman QIS, Deutsche, UBS, JPM) are named but never republished.</p>
    <a class="cta-frame cta-h stub-back" href="/markets/equities#plumbing">Back to the equities desk →</a>
  </div></section>
  <footer><div class="wrap"><div class="legal">© 2026 JCJ Investing LLC. Research and intelligence, not investment advice. Items marked "in build" are honest placeholders for committed modules.</div></div></footer>
  <style>
    .stubtop{padding-top:48px}
    .stub-h1{font-family:'Playfair Display',Georgia,serif;font-size:38px;font-weight:700;color:var(--ink);margin:8px 0 14px}
    .stub-lead{max-width:78ch}
    .stubgrid{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin:22px 0 16px}
    .stub-card{background:var(--card);border:1px solid var(--cardline);border-top:3px solid var(--eyeb);border-radius:11px;padding:15px 19px}
    .st-h{font-family:'Fraunces',serif;font-size:15.5px;font-weight:600;color:var(--ink);margin-bottom:7px}
    .stub-card p{font-size:14px;line-height:1.58;color:var(--body);margin:0 0 10px}
    .st-tag{font-family:'Lora',serif;font-size:8.5px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--latent);border:1px dashed color-mix(in srgb,var(--latent) 40%,transparent);border-radius:3px;padding:2px 7px}
    .stub-back{margin-top:10px}
    @media(max-width:760px){.stubgrid{grid-template-columns:1fr}.stub-h1{font-size:30px}}
  </style>
</body>
</html>
