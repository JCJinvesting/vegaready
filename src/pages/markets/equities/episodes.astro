---
import '../../../styles/desk.css';
import '../../../styles/desk-content.css';
import '../../../styles/desk-v2.css';
import '../../../styles/skin-steel.css';
import Wayfinder from '../../../components/Wayfinder.astro';
const modules = [
  ['Episode dossiers', 'One page per funding-stress window — 1998 LTCM · 2007 Quant Quake · 2008 GFC · 2011 euro sovereign · 2020 dash-for-cash · 2022 LDI · 2023 SVB — with full factor prints, the plumbing record, timeline, and the falsifier that ended each read.'],
  ['Factor-print explorer', 'Market / SMB / HML / RMW / CMA and defensive-vs-cyclical ETF spreads per episode, recomputed from the public Kenneth French dailies so every number is reproducible.'],
  ['Channel classification', 'Each episode tagged by collateral chain (unwind · flight-to-liquidity · dash-for-cash · localised) with the evidence for the tag and the desk’s confidence.'],
  ['Cross-episode screens', 'Same-axis comparisons — what always breaks (SMB), what sometimes breaks (HML), what broke once (RMW, March 2020).'],
];
---
<!doctype html>
<html lang="en" data-theme="t1" data-skin="steel" data-disc="deep">
<head>
  <meta charset="UTF-8" /><meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Episode Library — Equities · VegaReady</title>
  <meta name="description" content="Funding-stress episode case files for the equities desk — factor prints, plumbing records and channel classifications, all from reproducible public data. In build." />
  <meta name="robots" content="noindex" />
</head>
<body data-mode="analyst" data-disc="deep">
  <header class="masthead"><div class="wrap">
    <a class="wordmark" href="/today">VEGA<i>READY</i></a>
    <nav class="mast-right" aria-label="Primary"><a class="navlink" href="/today">Today</a><a class="navlink" href="/catalysts">Catalysts</a><a class="navlink on" href="/markets">Markets</a><a class="navlink" href="/structural/watch">Signals</a><a class="navlink" href="/about">About</a></nav>
  </div></header>
  <Wayfinder
    deck
    trail={[{ label: 'Markets', href: '/markets' }, { label: 'Equities', href: '/markets/equities' }, { label: 'Episode library' }]}
    rail={[
      { label: 'Episodes', href: '/markets/equities/episodes', current: true, tag: 'in build' },
      { label: 'Factor lab', href: '/markets/equities/factor-lab', tag: 'in build' },
      { label: 'Plumbing', href: '/markets/equities/plumbing', tag: 'in build' },
    ]}
  />
  <section class="dsec stubtop"><div class="wrap">
    <div class="eyebrow">Markets · Equities · Episode library</div>
    <h1 class="stub-h1">The case files.</h1>
    <p class="lead stub-lead">Every funding-stress window the desk’s framework is tested against — factor prints, plumbing records and channel classifications, built only from reproducible public data. This page is <b>in build</b>: the structure below is committed; the dossiers wire in with the data layer. Nothing here will ever be an invented number.</p>
    <div class="stubgrid">{modules.map((m) => (<div class="stub-card"><div class="st-h">{m[0]}</div><p>{m[1]}</p><span class="st-tag">in build · honest placeholder</span></div>))}</div>
    <p class="tnote">Primary inputs: Kenneth French Data Library · FRED · FSB · Bank of England · OFR · Khandani &amp; Lo (MIT). Methodology and confidence tags follow the main desk’s §13.</p>
    <a class="cta-frame cta-h stub-back" href="/markets/equities#channel">Back to the equities desk →</a>
  </div></section>
  <footer><div class="wrap"><div class="legal">© 2026 JCJ Investing LLC. Research and intelligence, not investment advice. Items marked "in build" are honest placeholders for committed modules.</div></div></footer>
  <style>
    .stubtop{padding-top:48px}
    .stub-h1{font-family:'Playfair Display',Georgia,serif;font-size:38px;font-weight:700;color:var(--ink);margin:8px 0 14px}
    .stub-lead{max-width:78ch}
    .stubgrid{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin:22px 0 16px}
    .stub-card{background:var(--card);border:1px solid var(--cardline);border-top:3px solid var(--eyeb);border-radius:11px;padding:15px 19px}
    .st-h{font-family:'Fraunces',serif;font-size:15.5px;font-weight:600;color:var(--ink);margin-bottom:7px}
    .stub-card p{font-size:14px;line-height:1.58;color:var(--body);margin:0 0 10px}
    .st-tag{font-family:'Lora',serif;font-size:8.5px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--latent);border:1px dashed color-mix(in srgb,var(--latent) 40%,transparent);border-radius:3px;padding:2px 7px}
    .stub-back{margin-top:10px}
    @media(max-width:760px){.stubgrid{grid-template-columns:1fr}.stub-h1{font-size:30px}}
  </style>
</body>
</html>
