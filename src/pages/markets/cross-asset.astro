---
import AnalysisLayout from '../../layouts/AnalysisLayout.astro';
import SignalPanel from '../../components/SignalPanel.astro';
import { cards, thesis, correlationMap, correlationNote, volRegime, volNote, termStructure, termNote, positioning, positioningVerdict, hedgingPlaybook, signalQuality, signalVerdict, volSurface, volSurfaceNote, termMap, dollarFunding, upgradedConfidence, proxyOnly, dataQuality, relatedSectors } from '../../data/analysis/crossasset.js';
const cverd = (v) => v.includes('Flipped') ? '#ef4444' : v.includes('Strengthened') ? '#22d3ee' : v.includes('Broke') ? '#f59e0b' : v.includes('Held') ? '#10b981' : '#94a3b8';
const vstate = (s) => s === 'elevated' ? '#ef4444' : '#10b981';
const normalized = volRegime.filter((v) => v.state === 'normalized');
const elevated = volRegime.filter((v) => v.state === 'elevated');
---

<AnalysisLayout
  title="Cross-Asset — Correlation & Volatility Regime — VegaReady"
  description="The market-derivative layer: how correlations, volatility, term structure, positioning and hedges re-priced. OVX 28→121, the bifurcated vol regime, record crude backwardation, and a hedging playbook by scenario."
  section="Cross-Asset"
  area="markets"
>
  <section class="hero">
    <div class="label">Markets · Cross-Asset</div>
    <h1>How it all moved<br/>together — and apart.</h1>
    <p class="lead">The market-derivative layer, downstream of the physical shock. An inflationary supply shock broke the diversification relationships of the 2010s: the dollar — not gold — took the safe-haven bid, and volatility bifurcated. This is the page that sits across all the others — correlation, vol regime, term structure, positioning, and the hedges that worked.</p>
  </section>

  <SignalPanel page="/markets/cross-asset" />

  <div class="thesis"><div class="thesis-label">The regime</div><p>{thesis}</p></div>

  <section class="sec">
    <div class="dl">Correlation regime map</div>
    <div style="overflow-x:auto"><table class="tbl">
      <thead><tr><th>Correlation pair</th><th>Normal / 2010s</th><th>Prior stress</th><th>2026 conflict</th><th>Verdict</th></tr></thead>
      <tbody>{correlationMap.map((r) => (<tr>
        <td class="nm">{r.pair}</td><td>{r.normal}</td><td>{r.stress}</td><td style="color:var(--text-muted)">{r.y2026}</td>
        <td style={`color:${cverd(r.verdict)};font-weight:700;white-space:nowrap`}>{r.verdict}</td>
      </tr>))}</tbody>
    </table></div>
    <p class="note">{correlationNote}</p>
  </section>

  <section class="sec">
    <div class="dl">Volatility regime <span style="color:var(--text-dim)">(CBOE via FRED — T1)</span></div>
    <div style="overflow-x:auto"><table class="tbl">
      <thead><tr><th>Index</th><th>Underlying</th><th>Baseline</th><th>Peak</th><th>May 28</th><th>Verdict</th></tr></thead>
      <tbody>{volRegime.map((r) => (<tr>
        <td class="nm">{r.index} <span class="vbadge" style={`background:${vstate(r.state)}22;color:${vstate(r.state)}`}>{r.state}</span></td>
        <td>{r.underlying}</td><td class="mono">{r.baseline}</td><td class="mono" style="color:#f59e0b">{r.peak}</td><td class="mono">{r.current}</td><td style="white-space:normal">{r.verdict}</td>
      </tr>))}</tbody>
    </table></div>
    <div class="bifur">
      <div class="bcol"><div class="bcol-h" style="color:#10b981">Normalized (false all-clear)</div>{normalized.map((v) => (<div class="bchip">{v.index} <span class="mono">{v.current}</span></div>))}</div>
      <div class="bcol"><div class="bcol-h" style="color:#ef4444">Still elevated (~2× — durable gauges)</div>{elevated.map((v) => (<div class="bchip">{v.index} <span class="mono">{v.current}</span></div>))}</div>
    </div>
    <p class="note">{volNote}</p>
  </section>
  <section class="sec">
    <div class="dl">Volatility-surface shock map — cross-asset</div>
    <div style="overflow-x:auto"><table class="tbl">
      <thead><tr><th>Surface dimension</th><th>W1 shock signature</th><th>W2 (May 28) state</th><th>Cross-asset read</th></tr></thead>
      <tbody>{volSurface.map((r) => (<tr><td class="nm">{r.dimension}</td><td>{r.w1}</td><td class="mono">{r.w2}</td><td style="color:var(--text-muted)">{r.read}</td></tr>))}</tbody>
    </table></div>
    <p class="note">{volSurfaceNote}</p>
  </section>

  <section class="sec">
    <div class="dl">Term structure &amp; physical-tightness signals</div>
    <div style="overflow-x:auto"><table class="tbl">
      <thead><tr><th>Curve</th><th>Signal</th><th>Detail</th></tr></thead>
      <tbody>{termStructure.map((r) => (<tr><td class="nm">{r.curve}</td><td style="color:#f59e0b;font-weight:600;white-space:nowrap">{r.signal}</td><td style="white-space:normal">{r.detail}</td></tr>))}</tbody>
    </table></div>
    <div class="callout"><div class="callout-label">False-comfort warning — Minneapolis Fed</div><p>{termNote}</p></div>
  </section>
  <section class="sec">
    <div class="dl">Term-structure signal map — cross-asset</div>
    <div style="overflow-x:auto"><table class="tbl">
      <thead><tr><th>Curve</th><th>Shape in W1</th><th>Duration read</th><th>Substitutability read</th></tr></thead>
      <tbody>{termMap.map((r) => (<tr><td class="nm">{r.curve}</td><td style="color:#f59e0b">{r.shape}</td><td>{r.duration}</td><td style="color:var(--text-muted)">{r.substitution}</td></tr>))}</tbody>
    </table></div>
  </section>

  <section class="sec">
    <div class="dl">Capital-flow &amp; positioning regime</div>
    <div style="overflow-x:auto"><table class="tbl">
      <thead><tr><th>Flow channel</th><th>2026 conflict data</th><th>Tier</th></tr></thead>
      <tbody>{positioning.map((r) => (<tr><td class="nm">{r.channel}</td><td style="white-space:normal">{r.data}</td><td class="mono">{r.tier}</td></tr>))}</tbody>
    </table></div>
    <p class="note"><strong style="color:var(--text)">Verdict:</strong> {positioningVerdict}</p>
  </section>
  <section class="sec">
    <div class="dl">EM stress &amp; dollar funding</div>
    <div class="callout" style="border-left-color:#818cf8"><div class="callout-label" style="color:#818cf8">The cross-asset transmission of the dollar bid</div><p>{dollarFunding}</p></div>
  </section>

  <section class="sec">
    <div class="dl">Hedging playbook by scenario</div>
    {hedgingPlaybook.map((p) => (
      <div class="pb" style={`border-left:3px solid ${p.tone}`}>
        <div class="pb-head" style={`color:${p.tone}`}>{p.scenario} — {p.label}</div>
        <div class="pb-grid">
          <div class="pb-row"><span class="pb-k" style="color:#10b981">Winners</span><p>{p.winners}</p></div>
          <div class="pb-row"><span class="pb-k" style="color:#ef4444">Losers</span><p>{p.losers}</p></div>
          <div class="pb-row"><span class="pb-k">Instruments</span><p>{p.instruments}</p></div>
          <div class="pb-row"><span class="pb-k">Horizon</span><p>{p.horizon}</p></div>
          <div class="pb-row"><span class="pb-k" style="color:#f59e0b">Failure modes</span><p>{p.failureModes}</p></div>
          <div class="pb-row"><span class="pb-k">Analog</span><p>{p.analog}</p></div>
        </div>
      </div>
    ))}
  </section>

  <section class="sec">
    <div class="dl">Signal quality &amp; false positives</div>
    <div style="overflow-x:auto"><table class="tbl">
      <thead><tr><th>Indicator</th><th>Lead / lag</th><th>Noise</th><th>2026 behaviour</th></tr></thead>
      <tbody>{signalQuality.map((r) => (<tr>
        <td class="nm">{r.indicator}</td><td style="white-space:normal">{r.leadlag}</td>
        <td class="mono" style={`color:${r.noise.includes('High') ? '#ef4444' : r.noise.includes('Low') ? '#10b981' : '#f59e0b'}`}>{r.noise}</td>
        <td style="white-space:normal">{r.behaviour}</td>
      </tr>))}</tbody>
    </table></div>
    <p class="note"><strong style="color:var(--text)">Net verdict:</strong> {signalVerdict}</p>
  </section>

  <div class="ev-list">
    {cards.map((c) => (
      <details class="ev"><summary class="es"><div class="el"><span class="en">{c.icon}</span><div>
        <div class="et">{c.title}<span class="cat">{c.category}</span></div><div class="eb">{c.summary}</div></div></div>
        <span class={`conf conf-${c.confidence}`}>{c.confidence}</span></summary>
        <div class="ey"><div class="mgrid">{c.metrics.map((mm) => (<div class="metric"><div class="ml">{mm.label}</div><div class="mv">{mm.value}</div></div>))}</div>
        {c.sources.length > 0 && <div><div class="dl">Sources</div><p class="srctext">{c.sources.map((u, i) => (<a href={u.url} target="_blank" rel="noopener" style="color:#60a5fa;margin-right:10px;font-size:13px;text-decoration:none">[{i + 1}]</a>))}</p></div>}</div>
      </details>
    ))}
  </div>

  <section class="sec">
    <details class="reg"><summary class="reg-s">Numbers upgraded to HIGH confidence ({upgradedConfidence.length})</summary>
    <ol class="reg-list">{upgradedConfidence.map((x) => (<li>{x}</li>))}</ol></details>
    <details class="reg"><summary class="reg-s">Could not verify / proxy only ({proxyOnly.length})</summary>
    <ol class="reg-list">{proxyOnly.map((x) => (<li>{x}</li>))}</ol></details>
  </section>

  <div class="foot-box">
    <div class="dl">Data quality &amp; methodology</div>
    <p><strong style="color:#10b981">HIGH</strong> — {dataQuality.high}</p>
    <p><strong style="color:#f59e0b">MODERATE</strong> — {dataQuality.moderate}</p>
    <p><strong style="color:var(--text-dim)">Quarantined</strong> — {dataQuality.quarantined}</p>
    <p class="next"><strong>Related:</strong> {relatedSectors}</p>
  </div>
</AnalysisLayout>

<style>
  .hero{margin-bottom:2.5rem;padding-bottom:2rem;border-bottom:1px solid var(--border)}
  .label{font-family:var(--font-mono);font-size:11px;color:var(--cyan);letter-spacing:3px;text-transform:uppercase;margin-bottom:16px}
  .hero h1{font-family:var(--font-display);font-size:clamp(1.8rem,3.5vw,2.4rem);font-weight:400;color:var(--text);line-height:1.15;margin-bottom:1rem}
  .lead{font-size:15px;color:var(--text-muted);line-height:1.7;max-width:760px}
  .thesis{background:var(--bg-surface);border:1px solid var(--border);border-left:3px solid #6366f1;border-radius:8px;padding:16px 20px;margin-bottom:2.5rem;max-width:860px}
  .thesis-label{font-family:var(--font-mono);font-size:10px;font-weight:700;color:#818cf8;text-transform:uppercase;letter-spacing:1.5px;margin-bottom:8px}
  .thesis p{font-size:14px;color:var(--text-muted);line-height:1.7;margin:0}
  .dl{font-family:var(--font-mono);font-size:10px;font-weight:700;color:var(--cyan);text-transform:uppercase;letter-spacing:1.5px;margin-bottom:8px}
  .sec{margin-bottom:3rem}
  .tbl{width:100%;border-collapse:collapse;font-size:12px;margin-top:8px}
  .tbl th{padding:8px 10px;text-align:left;border-bottom:2px solid var(--border);font-family:var(--font-mono);font-size:10px;font-weight:700;letter-spacing:1px;text-transform:uppercase;color:var(--text-dim);white-space:nowrap}
  .tbl td{padding:7px 10px;border-bottom:1px solid var(--border);color:var(--text-dim);line-height:1.45;vertical-align:top;min-width:70px}
  .nm{font-weight:700;color:var(--text)}
  .mono{font-family:var(--font-mono);font-size:11px;color:var(--text-muted);white-space:nowrap}
  .note{font-size:12px;color:var(--text-dim);line-height:1.6;margin-top:10px;max-width:860px}
  .vbadge{font-family:var(--font-mono);font-size:8px;font-weight:700;text-transform:uppercase;letter-spacing:1px;padding:1px 5px;border-radius:3px;vertical-align:middle}
  .bifur{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-top:14px}
  .bcol{background:var(--bg-surface);border:1px solid var(--border);border-radius:8px;padding:12px 14px}
  .bcol-h{font-family:var(--font-mono);font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:1px;margin-bottom:8px}
  .bchip{display:inline-block;font-size:12px;font-weight:700;color:var(--text);background:var(--bg-card);border:1px solid var(--border);border-radius:5px;padding:3px 9px;margin:3px 4px 0 0}
  .callout{font-size:13px;color:var(--text-muted);line-height:1.65;padding:14px 18px;background:var(--bg-surface);border:1px solid var(--border);border-left:3px solid #f59e0b;border-radius:8px;max-width:860px;margin-top:14px}
  .callout-label{font-family:var(--font-mono);font-size:10px;font-weight:700;color:#f59e0b;text-transform:uppercase;letter-spacing:1.5px;margin-bottom:8px}
  .callout p{margin:0}
  .pb{background:var(--bg-surface);border:1px solid var(--border);border-radius:8px;padding:14px 18px;margin-top:10px}
  .pb-head{font-family:var(--font-mono);font-size:13px;font-weight:800;margin-bottom:10px;letter-spacing:.3px}
  .pb-grid{display:grid;grid-template-columns:1fr 1fr;gap:8px 18px}
  .pb-k{font-family:var(--font-mono);font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:1px;color:var(--cyan);display:block;margin-bottom:2px}
  .pb-row p{font-size:12px;color:var(--text-muted);line-height:1.5;margin:0}
  .ev-list{display:flex;flex-direction:column;gap:8px;margin-bottom:3rem}
  .ev{background:var(--bg-surface);border:1px solid var(--border);border-radius:10px;overflow:hidden}
  .ev[open]{border-color:var(--border-light)}.ev[open] .es{border-bottom:1px solid var(--border)}
  .es{display:flex;justify-content:space-between;align-items:flex-start;padding:16px 20px;cursor:pointer;list-style:none;gap:12px}
  .es::-webkit-details-marker{display:none}.es::marker{content:''}
  .es:hover{background:rgba(255,255,255,0.02)}
  .el{display:flex;gap:14px;flex:1;min-width:0}
  .en{font-family:var(--font-mono);font-size:12px;font-weight:700;color:var(--cyan);min-width:22px;padding-top:2px}
  .et{font-size:15px;font-weight:700;color:var(--text);margin-bottom:4px;display:flex;align-items:center;gap:8px;flex-wrap:wrap}
  .cat{font-family:var(--font-mono);font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:1px;padding:1px 7px;border:1px solid var(--border);border-radius:4px;color:var(--text-dim)}
  .eb{font-size:12px;color:var(--text-dim);line-height:1.5;display:-webkit-box;-webkit-line-clamp:3;-webkit-box-orient:vertical;overflow:hidden}
  .conf{font-family:var(--font-mono);font-size:10px;font-weight:700;padding:2px 8px;border-radius:4px;white-space:nowrap;flex-shrink:0;margin-top:2px}
  .conf-high{color:#10b981;background:rgba(16,185,129,0.1)}.conf-medium{color:#f59e0b;background:rgba(245,158,11,0.1)}.conf-low{color:#ef4444;background:rgba(239,68,68,0.1)}
  .ey{padding:16px 20px 20px}
  .mgrid{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:16px}
  .metric{padding:10px 14px;background:var(--bg-card);border:1px solid var(--border);border-radius:6px}
  .ml{font-family:var(--font-mono);font-size:9px;font-weight:700;color:var(--cyan);text-transform:uppercase;letter-spacing:1px;margin-bottom:4px}
  .mv{font-size:13px;color:var(--text-muted);line-height:1.45}
  .srctext{font-size:13px;color:var(--text-muted);line-height:1.6;margin:0}
  .foot-box{background:var(--bg-surface);border:1px solid var(--border);border-radius:8px;padding:16px 20px;margin-bottom:1rem}
  .foot-box p{font-size:12px;color:var(--text-dim);line-height:1.6;margin:0 0 8px}
  .foot-box .next{margin:0}.foot-box strong{color:var(--cyan)}
  @media(max-width:720px){.bifur{grid-template-columns:1fr}.pb-grid{grid-template-columns:1fr}.mgrid{grid-template-columns:1fr}.eb{display:none}}
  .reg{background:var(--bg-surface);border:1px solid var(--border);border-radius:8px;margin-bottom:10px;overflow:hidden}
  .reg-s{padding:13px 18px;cursor:pointer;font-family:var(--font-mono);font-size:11px;font-weight:700;color:var(--cyan);text-transform:uppercase;letter-spacing:1px;list-style:none}
  .reg-s::-webkit-details-marker{display:none}
  .reg-list{margin:0;padding:0 20px 16px 38px}.reg-list li{font-size:12px;color:var(--text-dim);line-height:1.55;margin-bottom:6px}
</style>
