---
import ScenariosLayout from '../../layouts/ScenariosLayout.astro';
---

<ScenariosLayout
  title="Regional Impact — VegaReady Scenario Analysis"
  description="Country-by-country exposure analysis for 12 major economies. GDP impact, energy dependency, food security, currency risk, and substitution capacity."
  section="Regional Impact"
>
  <div class="label">Regional impact</div>
  <h1 style="font-family: var(--font-display); font-size: 2rem; font-weight: 400; color: var(--text); margin-bottom: 1rem;">Every economy<br/>has a different exposure.</h1>
  <p style="font-size: 15px; color: var(--text-muted); line-height: 1.7; max-width: 600px; margin-bottom: 3rem;">Some countries benefit from disruption. Some face existential pressure. Understanding the asymmetry across the world's largest economies and most vulnerable nations is where the macro edge lives.</p>

  <div style="text-align: center; padding: 4rem 2rem; background: var(--bg-surface); border: 1px solid var(--border); border-radius: 12px;">
    <div style="font-family: var(--font-display); font-style: italic; font-size: 28px; color: var(--text-dim); margin-bottom: 12px;">&nu;</div>
    <div style="font-family: var(--font-mono); font-size: 14px; font-weight: 700; color: var(--text); margin-bottom: 8px;">Regional profiles in development</div>
    <p style="font-size: 13px; color: var(--text-muted); max-width: 400px; margin: 0 auto 16px; line-height: 1.6;">12 country/region profiles with energy dependency, food security, currency exposure, and scenario-specific impact projections. Publishing progressively.</p>
    <a href="/scenarios" style="font-family: var(--font-mono); font-size: 12px; color: var(--cyan); font-weight: 600;">View cascade framework &rarr;</a>
  </div>
</ScenariosLayout>

<style>
  .label { font-family: var(--font-mono); font-size: 11px; color: var(--cyan); letter-spacing: 3px; text-transform: uppercase; margin-bottom: 16px; }
</style>
