  },
];

const winnerLosers = [
  {name:'United States',hormuz:'Modest winner',strike:'Modest winner',cable:'Moderate loser',ceasefire:'Neutral',net:'Mixed / modest winner',color:'#10b981'},
  {name:'China',hormuz:'Severe loser',strike:'Moderate loser',cable:'Moderate loser',ceasefire:'Strong winner',net:'Loser (best-hedged)',color:'#ef4444'},
  {name:'European Union',hormuz:'Severe loser',strike:'Moderate loser',cable:'Moderate loser',ceasefire:'Strong winner',net:'Loser (stagflation)',color:'#ef4444'},
  {name:'Japan',hormuz:'Catastrophic',strike:'Severe loser',cable:'Moderate loser',ceasefire:'Very strong winner',net:'Most exposed G7',color:'#ef4444'},
  {name:'India',hormuz:'Severe loser',strike:'Moderate loser',cable:'Moderate loser',ceasefire:'Strong winner',net:'Loser (triple hit)',color:'#ef4444'},
  {name:'Saudi Arabia',hormuz:'Price winner',strike:'Moderate loser',cable:'Moderate loser',ceasefire:'Modest loser',net:'Net-long closure',color:'#10b981'},
  {name:'UAE',hormuz:'Severe loser',strike:'Moderate loser',cable:'Severe loser',ceasefire:'Strong winner',net:'Hub model at risk',color:'#f59e0b'},
  {name:'Russia',hormuz:'Winner',strike:'Winner',cable:'Minimal',ceasefire:'Moderate loser',net:'Clearest winner',color:'#10b981'},
  {name:'South Korea',hormuz:'Severe loser',strike:'Moderate loser',cable:'Moderate loser',ceasefire:'Strong winner',net:'Loser (+shipbuilding)',color:'#ef4444'},
  {name:'Brazil',hormuz:'Strong winner',strike:'Moderate winner',cable:'Minimal',ceasefire:'Modest loser',net:'Structural winner',color:'#10b981'},
  {name:'Egypt',hormuz:'Catastrophic',strike:'Moderate loser',cable:'Moderate loser',ceasefire:'Very strong winner',net:'Severe loser',color:'#ef4444'},
  {name:'Pakistan',hormuz:'Catastrophic',strike:'Severe loser',cable:'Significant loser',ceasefire:'Very strong winner',net:'Most vulnerable',color:'#ef4444'},
];
---

<ScenariosLayout
  title="Regional Impact — VegaReady Scenario Analysis"
  description="Country-by-country exposure analysis for 12 major economies under four conflict scenarios. Energy, food, trade, financial exposure with quantified impact projections."
  section="Regional Impact"
>
  <section class="hero">
    <div class="label">Regional impact</div>
    <h1>Every economy has a<br/>different exposure.</h1>
    <p class="lead">12 economies analyzed across energy, food, trade, and financial channels. Some benefit from disruption. Some face existential pressure. Understanding the asymmetry is where the macro edge lives.</p>
  </section>

  <section class="summary-section">
    <div class="summary-grid">
      <div class="summary-card" style="border-left:3px solid #10b981"><div class="summary-label">Net winners</div><div class="summary-list">United States, Russia, Saudi Arabia, Brazil</div></div>
      <div class="summary-card" style="border-left:3px solid #ef4444"><div class="summary-label">Net losers</div><div class="summary-list">China, EU, Japan, India, South Korea, Egypt, Pakistan</div></div>
      <div class="summary-card" style="border-left:3px solid #f59e0b"><div class="summary-label">Mixed</div><div class="summary-list">UAE (Fujairah bypass vs non-relocatable hub)</div></div>
    </div>
    <div class="callout"><strong>Key asymmetry:</strong> Saudi Arabia is the only economy net-long a Hormuz closure. Egypt is the largest ceasefire-beneficiary. Pakistan carries unique double-Hormuz risk: its energy supplier and ~$38B remittance lifeline are the same region.</div>
  </section>

  <section class="matrix-section">
    <div class="dl">Scenario impact matrix</div>
    <div style="overflow-x:auto">
      <table class="matrix">
        <thead><tr><th>Economy</th><th style="color:#ef4444">Hormuz</th><th style="color:#f59e0b">Strike</th><th style="color:#6366f1">Cable</th><th style="color:#10b981">Ceasefire</th><th>Net</th></tr></thead>
        <tbody>{winnerLosers.map(w=>(
          <tr><td class="mn">{w.name}</td><td>{w.hormuz}</td><td>{w.strike}</td><td>{w.cable}</td><td>{w.ceasefire}</td><td><span class="nt" style={`color:${w.color};border-color:${w.color}30;background:${w.color}10`}>{w.net}</span></td></tr>
        ))}</tbody>
      </table>
    </div>
  </section>

  <div class="country-list">
    {countries.map((c,i)=>(
      <details class="cd">
        <summary class="cs">
          <div class="cl">
            <span class="cn">{String(i+1).padStart(2,'0')}</span>
            <div>
              <div class="ch"><span class="ct">{c.title}</span><span class="cg">{c.gdp}</span><span class="tg" style={`color:${c.tagColor};border-color:${c.tagColor}30;background:${c.tagColor}10`}>{c.tag}</span></div>
              <div class="cb">{c.summary}</div>
            </div>
          </div>
          <span class={`cf cf-${c.confidence}`}>{c.confidence}</span>
        </summary>
        <div class="cy">
          <div class="ds"><div class="dl">Energy exposure</div><p>{c.energy}</p></div>
          <div class="ds"><div class="dl">Food security</div><p>{c.food}</p></div>
          <div class="dr"><div class="ds"><div class="dl">Trade exposure</div><p>{c.trade}</p></div><div class="ds"><div class="dl">Financial exposure</div><p>{c.financial}</p></div></div>
