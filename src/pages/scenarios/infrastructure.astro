---
import ScenariosLayout from '../../layouts/ScenariosLayout.astro';
---

<ScenariosLayout
  title="Critical Infrastructure — VegaReady Scenario Analysis"
  description="Quantified vulnerability assessment of Persian Gulf critical infrastructure: Hormuz, Kharg Island, submarine cables, Ras Tanura, Abqaiq, and bypass pipelines."
  section="Infrastructure"
>
  <div class="label">Critical infrastructure</div>
  <h1 style="font-family: var(--font-display); font-size: 2rem; font-weight: 400; color: var(--text); margin-bottom: 1rem;">What's at risk and<br/>what it means.</h1>
  <p style="font-size: 15px; color: var(--text-muted); line-height: 1.7; max-width: 600px; margin-bottom: 3rem;">Quantified capacity at each critical node — what each side can credibly threaten, what the market impact would be, and what bypass capacity exists. Includes mine warfare capability assessment.</p>

  <div style="text-align: center; padding: 4rem 2rem; background: var(--bg-surface); border: 1px solid var(--border); border-radius: 12px;">
    <div style="font-family: var(--font-display); font-style: italic; font-size: 28px; color: var(--text-dim); margin-bottom: 12px;">&nu;</div>
    <div style="font-family: var(--font-mono); font-size: 14px; font-weight: 700; color: var(--text); margin-bottom: 8px;">Full infrastructure analysis migrating here</div>
    <p style="font-size: 13px; color: var(--text-muted); max-width: 400px; margin: 0 auto 16px; line-height: 1.6;">Infrastructure vulnerability data, mine warfare context, and scenario matrix currently available on the precedents page. Being expanded and reorganized.</p>
    <a href="/scenarios/precedents" style="font-family: var(--font-mono); font-size: 12px; color: var(--cyan); font-weight: 600;">View current data on precedents page &rarr;</a>
  </div>
</ScenariosLayout>

<style>
  .label { font-family: var(--font-mono); font-size: 11px; color: var(--cyan); letter-spacing: 3px; text-transform: uppercase; margin-bottom: 16px; }
</style>
