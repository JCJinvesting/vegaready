---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import DataInjector from '../../components/dashboard/iwt/DataInjector.astro';
import WarTracker from '../../components/dashboard/iwt/WarTracker.jsx';
---

<DashboardLayout
  title="Sources — VegaReady"
  description="Source catalogue, provenance matrix, confidence methodology."
  tab="Sources"
>
  <div slot="seo">
    <h1 style="font-family: var(--font-display); font-size: 1.5rem; font-weight: 400; color: var(--text); margin-bottom: 4px;">
      Sources
    </h1>
    <p style="font-size: 13px; color: var(--text-dim); margin: 0;">
      Source provenance, confidence ratings, feeder outlets.
    </p>
  </div>

  <DataInjector />
  <WarTracker initialTab="Sources" embedded={true} client:only="react" />
</DashboardLayout>
