---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import TrackerEmbed from '../../components/dashboard/TrackerEmbed.jsx';
---

<DashboardLayout
  title="Analytics — VegaReady"
  description="Analytical tools — threat mix analysis, intercept trends, defense stability modeling, scenario planning, and target type classification."
  tab="Analytics"
>
  <div slot="seo">
    <h1 style="font-family: var(--font-display); font-size: 1.5rem; font-weight: 400; color: var(--text); margin-bottom: 4px;">
      Analytics
    </h1>
    <p style="font-size: 13px; color: var(--text-dim); margin: 0;">
      Threat mix, intercept trends, defense stability, scenario modeller, and target classification analytics.
    </p>
  </div>

  <TrackerEmbed tab="Analytics" client:only="react" />
</DashboardLayout>
