---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import DataInjector from '../../components/dashboard/iwt/DataInjector.astro';
import WarTracker from '../../components/dashboard/iwt/WarTracker.jsx';
---

<DashboardLayout
  title="Analytics — VegaReady"
  description="Analytical tools — threat mix, intercept trends, defense stability, scenario planning."
  tab="Analytics"
>
  <div slot="seo">
    <h1 style="font-family: var(--font-display); font-size: 1.5rem; font-weight: 400; color: var(--text); margin-bottom: 4px;">
      Analytics
    </h1>
    <p style="font-size: 13px; color: var(--text-dim); margin: 0;">
      Threat mix, intercept trends, defense stability, scenario modeller.
    </p>
  </div>

  <DataInjector />
  <WarTracker initialTab="Analytics" embedded={true} client:only="react" />
</DashboardLayout>
