---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import DataInjector from '../../components/dashboard/iwt/DataInjector.astro';
import WarTracker from '../../components/dashboard/iwt/WarTracker.jsx';
---

<DashboardLayout
  title="Economics — VegaReady"
  description="Economic impact — oil prices, refinery shutdowns, force majeure, currency stress, and Hormuz risk premiums."
  tab="Economics"
>
  <div slot="seo">
    <h1 style="font-family: var(--font-display); font-size: 1.5rem; font-weight: 400; color: var(--text); margin-bottom: 4px;">
      Economics
    </h1>
    <p style="font-size: 13px; color: var(--text-dim); margin: 0;">
      Refinery shutdowns, force majeure, oil price trajectory, and economic transmission.
    </p>
  </div>

  <DataInjector />
  <WarTracker initialTab="Economics" embedded={true} client:only="react" />
</DashboardLayout>
