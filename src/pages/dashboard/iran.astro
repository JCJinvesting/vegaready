---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import DataInjector from '../../components/dashboard/iwt/DataInjector.astro';
import WarTracker from '../../components/dashboard/iwt/WarTracker.jsx';
---

<DashboardLayout
  title="Iran — Adversary Analysis — VegaReady"
  description="Iran and IRGC analysis — daily claims, weapon systems, disinformation, interceptor depletion."
  tab="Iran"
>
  <div slot="seo">
    <h1 style="font-family: var(--font-display); font-size: 1.5rem; font-weight: 400; color: var(--text); margin-bottom: 4px;">
      Iran
    </h1>
    <p style="font-size: 13px; color: var(--text-dim); margin: 0;">
      IRGC claims vs reality, weapon systems, disinformation, strategic calculus.
    </p>
  </div>

  <DataInjector />
  <WarTracker initialTab="Iran" embedded={true} client:only="react" />
</DashboardLayout>
