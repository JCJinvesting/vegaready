---
export const prerender = true;
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import DataInjector from '../../components/dashboard/iwt/DataInjector.astro';
import WarTracker from '../../components/dashboard/iwt/WarTracker.jsx';
---

<DashboardLayout
  title="Casualties — VegaReady"
  description="Casualty tracking — US and coalition military casualties, civilian incidents."
  tab="Casualties"
>
  <div slot="seo">
    <h1 style="font-family: var(--font-display); font-size: 1.5rem; font-weight: 400; color: var(--text); margin-bottom: 4px;">
      Casualties
    </h1>
    <p style="font-size: 13px; color: var(--text-dim); margin: 0;">
      US and coalition casualties, civilian incidents, and casualty timeline.
    </p>
  </div>

  <DataInjector />
  <WarTracker initialTab="Casualties" embedded={true} client:only="react" />
</DashboardLayout>
