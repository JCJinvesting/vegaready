---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import TrackerEmbed from '../../components/dashboard/TrackerEmbed.jsx';
---

<DashboardLayout
  title="Casualties — VegaReady"
  description="Casualty tracking — US and coalition military casualties, civilian incidents, and day-by-country timeline across the conflict."
  tab="Casualties"
>
  <div slot="seo">
    <h1 style="font-family: var(--font-display); font-size: 1.5rem; font-weight: 400; color: var(--text); margin-bottom: 4px;">
      Casualties
    </h1>
    <p style="font-size: 13px; color: var(--text-dim); margin: 0;">
      US and coalition casualties, civilian incidents, and day-by-country casualty timeline.
    </p>
  </div>

  <TrackerEmbed tab="Casualties" client:only="react" />
</DashboardLayout>
