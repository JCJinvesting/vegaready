---
import AnalysisLayout from '../../../layouts/AnalysisLayout.astro';
import SignalPanel from '../../../components/SignalPanel.astro';
import { cards, thesis, dependencyTable, attacks, reserveNote, scenarioMatrix, sourceResolution, dataQuality, investmentImplications } from '../../../data/analysis/water.js';
---

<AnalysisLayout
  title="Water & Desalination — VegaReady"
  description="The Gulf's existential tail risk: 33% of global desalination capacity, near-total drinking-water dependence (Qatar 99%, Bahrain/Kuwait 90%), confirmed strikes on plants, and under two days of stored water."
  section="Water & Desalination"
  area="markets"
>
  <section class="hero">
    <div class="label">Markets · Water & Desalination</div>
    <h1>Two days of water.</h1>
    <p class="lead">No part of this conflict carries a starker tail risk. The Gulf runs 33% of the world's desalination capacity, its drinking water is near-totally dependent on it, and most states hold under two days in reserve. Plants have already been struck. A CIA assessment once called disrupting Gulf desalination worse than the loss of any other commodity.</p>
  </section>

  <SignalPanel page="/markets/water" />

  <div class="thesis">
    <div class="thesis-label">The structural finding</div>
    <p>{thesis}</p>
  </div>

  <section class="mig">
    <div class="dl">Drinking water from desalination</div>
    <div class="bars">
      {dependencyTable.map((r) => (
        <div class="bar-row">
          <span class="bar-label">{r.country}</span>
          <div class="bar-track"><div class="bar-fill" style={`width:${parseInt(r.drinking)}%;background:${parseInt(r.drinking) >= 80 ? '#ef4444' : parseInt(r.drinking) >= 50 ? '#f59e0b' : '#22d3ee'}`}></div></div>
          <span class="bar-val">{r.drinking}</span>
        </div>
      ))}
    </div>
    <p class="prec-note">Desal share of total water: Qatar 77% · Bahrain 68% · UAE 52% · Kuwait 42% · Oman 31% · Saudi 18%. The drinking-water dependence (bars) is the binding number — a strike that takes a plant offline hits the tap directly.</p>
  </section>

  <section class="prec">
    <div class="dl">Infrastructure attacks (confirmed events)</div>
    <div style="overflow-x:auto"><table class="prec-table">
      <thead><tr><th>Date (2026)</th><th>Event</th><th>Status</th></tr></thead>
      <tbody>{attacks.map((a) => (<tr class={a.current ? 'prec-cur-row' : ''}><td class="prec-name">{a.date}</td><td>{a.event}</td><td>{a.status}</td></tr>))}</tbody>
    </table></div>
  </section>

  <div class="callout">
    <div class="callout-label">The storage gap & energy-water nexus</div>
    <p>{reserveNote}</p>
  </div>

  <div class="ev-list">
    {cards.map((c) => (
      <details class="ev">
        <summary class="es">
          <div class="el"><span class="en">{c.icon}</span><div>
            <div class="et">{c.title}<span class="cat">{c.category}</span></div>
            <div class="eb">{c.summary}</div>
          </div></div>
          <span class={`conf conf-${c.confidence}`}>{c.confidence}</span>
        </summary>
        <div class="ey">
          <div class="mgrid">{c.metrics.map((mm) => (<div class="metric"><div class="ml">{mm.label}</div><div class="mv">{mm.value}</div></div>))}</div>
          {c.sources.length > 0 && <div class="ds"><div class="dl">Sources</div><p class="srctext">{c.sources.map((u, i) => (<a href={u.url} target="_blank" rel="noopener" style="color:#60a5fa;margin-right:10px;font-size:13px;text-decoration:none">[{i + 1}]</a>))}</p></div>}
        </div>
      </details>
    ))}
  </div>

  <section class="scen">
    <div class="dl">Scenario impact</div>
    {scenarioMatrix.map((s) => (
      <div class="scen-block" style={`border-left:3px solid ${s.tone}`}>
        <div class="scen-name" style={`color:${s.tone}`}>{s.scenario} — {s.label}</div>
        <p class="scen-impact">{s.impact}</p>
      </div>
    ))}
  </section>

  <section class="inv">
    <div class="dl">Investment implications</div>
    {investmentImplications.map((it) => (<div class="inv-block"><div class="inv-name">{it.stakeholder}</div><p>{it.text}</p></div>))}
  </section>

  <section class="sres">
    <div class="dl">Source-conflict resolution</div>
    {sourceResolution.map((r) => (<div class="sres-block"><span class="sres-item">{r.item}</span><span class="sres-res">{r.resolution}</span></div>))}
  </section>

  <div class="foot-box">
    <div class="dl">Data quality &amp; methodology</div>
    <p><strong style="color:#10b981">HIGH</strong> — {dataQuality.high}</p>
    <p><strong style="color:#f59e0b">MODERATE</strong> — {dataQuality.moderate}</p>
    <p><strong style="color:var(--text-dim)">Quarantined (not anchored)</strong> — {dataQuality.quarantined}</p>
    <p class="next"><strong>Related:</strong> the food side on <a href="/markets/food-agriculture" style="color:var(--cyan)">/markets/food-agriculture</a>; country exposure on <a href="/exposure" style="color:var(--cyan)">/exposure</a>. Cross-section causal link: a desalination strike would reprice GCC sovereign credit and equity (TASI/DFM) — see <a href="/markets/equities" style="color:var(--cyan)">/markets/equities</a> and the causal map on <a href="/connections" style="color:var(--cyan)">/connections</a>.</p>
  </div>
</AnalysisLayout>

<style>
  .hero{margin-bottom:3rem;padding-bottom:2rem;border-bottom:1px solid var(--border)}
  .label{font-family:var(--font-mono);font-size:11px;color:var(--cyan);letter-spacing:3px;text-transform:uppercase;margin-bottom:16px}
  .hero h1{font-family:var(--font-display);font-size:clamp(1.8rem,3.5vw,2.4rem);font-weight:400;color:var(--text);line-height:1.15;margin-bottom:1rem}
  .lead{font-size:15px;color:var(--text-muted);line-height:1.7;max-width:680px}
  .thesis{background:var(--bg-surface);border:1px solid var(--border);border-left:3px solid #ef4444;border-radius:8px;padding:16px 20px;margin-bottom:2.5rem;max-width:800px}
  .thesis-label{font-family:var(--font-mono);font-size:10px;font-weight:700;color:#ef4444;text-transform:uppercase;letter-spacing:1.5px;margin-bottom:8px}
  .thesis p{font-size:14px;color:var(--text-muted);line-height:1.7;margin:0}
  .mig{margin-bottom:3rem}
  .mig-table{width:100%;border-collapse:collapse;font-size:12px;margin-top:12px}
  .mig-table th{padding:8px 10px;text-align:left;border-bottom:2px solid var(--border);font-family:var(--font-mono);font-size:10px;font-weight:700;letter-spacing:1px;text-transform:uppercase;color:var(--text-dim);white-space:nowrap}
  .mig-table td{padding:8px 10px;border-bottom:1px solid var(--border);color:var(--text-dim);line-height:1.4;vertical-align:top}
  .mig-c{font-weight:700;color:var(--text);white-space:nowrap}
  .mig-hi{color:#ef4444;font-weight:700;font-family:var(--font-mono)}
  .prec{margin-bottom:3rem}
  .prec-table{width:100%;border-collapse:collapse;font-size:12px;margin-top:12px}
  .prec-table th{padding:8px 10px;text-align:left;border-bottom:2px solid var(--border);font-family:var(--font-mono);font-size:10px;font-weight:700;letter-spacing:1px;text-transform:uppercase;color:var(--text-dim);white-space:nowrap}
  .prec-table td{padding:7px 10px;border-bottom:1px solid var(--border);color:var(--text-dim);line-height:1.4;vertical-align:top;min-width:120px}
  .prec-name{font-weight:700;color:var(--text);white-space:nowrap}
  .prec-cur-row td{color:#f59e0b}
  .callout{font-size:13px;color:var(--text-muted);line-height:1.65;padding:14px 18px;background:var(--bg-surface);border:1px solid var(--border);border-left:3px solid var(--cyan);border-radius:8px;max-width:820px;margin-bottom:3rem}
  .callout-label{font-family:var(--font-mono);font-size:10px;font-weight:700;color:var(--cyan);text-transform:uppercase;letter-spacing:1.5px;margin-bottom:8px}
  .callout p{margin:0}
  .ev-list{display:flex;flex-direction:column;gap:8px;margin-bottom:3rem}
  .ev{background:var(--bg-surface);border:1px solid var(--border);border-radius:10px;overflow:hidden}
  .ev[open]{border-color:var(--border-light)}
  .ev[open] .es{border-bottom:1px solid var(--border)}
  .es{display:flex;justify-content:space-between;align-items:flex-start;padding:16px 20px;cursor:pointer;list-style:none;gap:12px}
  .es::-webkit-details-marker{display:none}
  .es::marker{content:''}
  .es:hover{background:rgba(255,255,255,0.02)}
  .el{display:flex;gap:14px;flex:1;min-width:0}
  .en{font-family:var(--font-mono);font-size:12px;font-weight:700;color:var(--cyan);min-width:22px;padding-top:2px}
  .et{font-size:15px;font-weight:700;color:var(--text);margin-bottom:4px;display:flex;align-items:center;gap:8px;flex-wrap:wrap}
  .cat{font-family:var(--font-mono);font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:1px;padding:1px 7px;border:1px solid var(--border);border-radius:4px;color:var(--text-dim)}
  .eb{font-size:12px;color:var(--text-dim);line-height:1.5;display:-webkit-box;-webkit-line-clamp:3;-webkit-box-orient:vertical;overflow:hidden}
  .conf{font-family:var(--font-mono);font-size:10px;font-weight:700;padding:2px 8px;border-radius:4px;white-space:nowrap;flex-shrink:0;margin-top:2px}
  .conf-high{color:#10b981;background:rgba(16,185,129,0.1)}
  .conf-medium{color:#f59e0b;background:rgba(245,158,11,0.1)}
  .conf-low{color:#ef4444;background:rgba(239,68,68,0.1)}
  .ey{padding:16px 20px 20px}
  .mgrid{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:16px}
  .metric{padding:10px 14px;background:var(--bg-card);border:1px solid var(--border);border-radius:6px}
  .ml{font-family:var(--font-mono);font-size:9px;font-weight:700;color:var(--cyan);text-transform:uppercase;letter-spacing:1px;margin-bottom:4px}
  .mv{font-size:13px;color:var(--text-muted);line-height:1.45}
  .ds{margin-bottom:0}
  .dl{font-family:var(--font-mono);font-size:10px;font-weight:700;color:var(--cyan);text-transform:uppercase;letter-spacing:1.5px;margin-bottom:6px}
  .srctext{font-size:13px;color:var(--text-muted);line-height:1.6;margin:0}
  .scen{margin-bottom:3rem}
  .scen-block{background:var(--bg-surface);border:1px solid var(--border);border-radius:8px;padding:14px 18px;margin-top:10px}
  .scen-name{font-size:14px;font-weight:700;margin-bottom:6px}
  .scen-impact{font-size:13px;color:var(--text-muted);line-height:1.6;margin:0}
  .sres{margin-bottom:2rem}
  .sres-block{display:flex;gap:14px;padding:8px 0;border-bottom:1px solid var(--border)}
  .sres-item{font-size:12px;font-weight:700;color:var(--text);min-width:230px;flex-shrink:0}
  .sres-res{font-size:12px;color:var(--text-dim);line-height:1.5}
  .foot-box{background:var(--bg-surface);border:1px solid var(--border);border-radius:8px;padding:16px 20px;margin-bottom:1rem}
  .foot-box p{font-size:12px;color:var(--text-dim);line-height:1.6;margin:0 0 8px}
  .foot-box .next{margin:0}
  .foot-box strong{color:var(--cyan)}
  @media(max-width:720px){.mgrid{grid-template-columns:1fr}.eb{display:none}.sres-block{flex-direction:column;gap:4px}.sres-item{min-width:0}}
  .inv{margin-bottom:3rem}
  .inv-block{margin-top:14px}
  .inv-name{font-family:var(--font-mono);font-size:11px;font-weight:700;color:var(--cyan);text-transform:uppercase;letter-spacing:1px;margin-bottom:5px}
  .inv-block p{font-size:13px;color:var(--text-muted);line-height:1.6;margin:0}
  .bars{margin-top:14px;display:flex;flex-direction:column;gap:8px}
  .bar-row{display:grid;grid-template-columns:96px 1fr 56px;align-items:center;gap:10px}
  .bar-label{font-size:12px;font-weight:700;color:var(--text);white-space:nowrap}
  .bar-track{height:18px;background:var(--bg-card);border:1px solid var(--border);border-radius:4px;overflow:hidden}
  .bar-fill{height:100%;border-radius:3px 0 0 3px}
  .bar-val{font-family:var(--font-mono);font-size:12px;font-weight:700;color:var(--text-dim);text-align:right}
  @media(max-width:720px){.bar-row{grid-template-columns:72px 1fr 48px}}
</style>
