---
import AnalysisLayout from '../../../layouts/AnalysisLayout.astro';
import SignalPanel from '../../../components/SignalPanel.astro';
import { cards, thesis, scenarioRegime, indexShock, indexNote, sectorMap, sectorScenario, sectorPrecedent, earningsSummary, passThrough, earningsScenario, factorRotation, factorObservations, countryMatrix, countryScenario, gcc, gccScenario, gccHedge, flows, flowsNote, volOptions, deleveraging, gccFlows, cryptoSpillover, scenarioTrades, precedents, upgradedConfidence, proxyOnly, dataQuality, relatedSectors } from '../../../data/analysis/equities.js';
const sc = (s) => s.startsWith('WINNER') ? '#10b981' : s.startsWith('LOSER') ? '#ef4444' : '#f59e0b';
const dc = (x) => x === 'Long' ? '#10b981' : x === 'Short' ? '#ef4444' : x.startsWith('Crypto') ? '#818cf8' : '#f59e0b';
const cf = (c) => c.startsWith('HIGH') ? '#10b981' : c.startsWith('LOW') ? '#ef4444' : '#f59e0b';
---

<AnalysisLayout
  title="Global Equities & Sector Rotation — VegaReady"
  description="The first-order equity layer: the index bifurcation (S&P −8%→ATH on AI insulation, TASI +5% vs DFM −16%), sector winner/loser map, earnings transmission, factor rotation, country matrix, GCC asymmetry, flows, and a four-scenario trade map."
  section="Equities"
  area="markets"
>
  <section class="hero">
    <div class="label">Markets · Global Equities</div>
    <h1>The same shock.<br/>Opposite outcomes.</h1>
    <p class="lead">Equities are the transmission inflection point between the physical energy shock and everything downstream — including crypto. The 2026 conflict produced a bifurcation that defines the regime: the S&P fell ~8% to a 6,316 trough, then made new highs on AI insulation, while energy importers (Europe, Japan, Korea) took the macro pain and the GCC split violently — Saudi TASI up on oil, Dubai's DFM down ~16% on security risk. This is the upstream layer of the <a href="/markets/cross-asset" style="color:var(--cyan)">Cross-Asset</a> correlation breaks.</p>
  </section>

  <SignalPanel page="/markets/equities" />

  <div class="thesis"><div class="thesis-label">The regime</div><p>{thesis}</p></div>

  <section class="sec">
    <div class="dl">Equity regime by scenario</div>
    <div style="overflow-x:auto"><table class="tbl">
      <thead><tr><th>Scenario</th><th>Oil regime</th><th>Equity regime</th><th>Key equity risk</th></tr></thead>
      <tbody>{scenarioRegime.map((r) => (<tr><td class="nm">{r.scenario}</td><td class="mono">{r.oilRegime}</td><td>{r.equityRegime}</td><td style="color:#f59e0b">{r.keyRisk}</td></tr>))}</tbody>
    </table></div>
  </section>

  <section class="sec">
    <div class="dl">Index shock map — conflict window (Feb 28 – May 31, 2026)</div>
    <div style="overflow-x:auto"><table class="tbl">
      <thead><tr><th>Index</th><th>Region</th><th>Peak decline (trough)</th><th>Recovery to ~May 31</th><th>Sensitivity</th><th>Conf</th></tr></thead>
      <tbody>{indexShock.map((r) => (<tr><td class="nm">{r.index}</td><td class="mono">{r.region}</td><td>{r.decline}</td><td style="color:var(--text-muted)">{r.recovery}</td><td>{r.sensitivity}</td><td class="mono" style={`color:${cf(r.conf)}`}>{r.conf}</td></tr>))}</tbody>
    </table></div>
    <p class="note">{indexNote}</p>
  </section>

  <section class="sec">
    <div class="dl">Sector winner / loser map</div>
    <div style="overflow-x:auto"><table class="tbl">
      <thead><tr><th>Sector</th><th>Status</th><th>Mechanism</th><th>ETF proxy</th><th>Conf</th></tr></thead>
      <tbody>{sectorMap.map((r) => (<tr><td class="nm">{r.sector}</td><td style={`color:${sc(r.status)};font-weight:700;white-space:nowrap`}>{r.status}</td><td>{r.mechanism}</td><td class="mono">{r.etf}</td><td class="mono" style={`color:${cf(r.conf)}`}>{r.conf}</td></tr>))}</tbody>
    </table></div>
    <div class="ssg">{sectorScenario.map((s) => (<div class="ssg-row"><span class="ssg-k">{s.scenario}</span><p>{s.impact}</p></div>))}</div>
    <p class="note"><strong style="color:var(--text)">Precedent:</strong> {sectorPrecedent}</p>
  </section>

  <section class="sec">
    <div class="dl">Earnings &amp; margin transmission</div>
    <p class="lead2">{earningsSummary}</p>
    <div class="chan">{passThrough.map((c) => (<div class="chan-row"><div class="chan-k">{c.channel}</div><p>{c.detail}</p></div>))}</div>
    <div style="overflow-x:auto;margin-top:14px"><table class="tbl">
      <thead><tr><th>Scenario</th><th>S&amp;P 500 EPS impact (12M)</th><th>Sector most affected</th></tr></thead>
      <tbody>{earningsScenario.map((r) => (<tr><td class="nm">{r.scenario}</td><td class="mono" style="color:#f59e0b">{r.eps}</td><td>{r.sectors}</td></tr>))}</tbody>
    </table></div>
  </section>

  <section class="sec">
    <div class="dl">Factor rotation</div>
    <div style="overflow-x:auto"><table class="tbl">
      <thead><tr><th>Factor</th><th>Performance vs market</th><th>Mechanism</th><th>Historical analog</th><th>Conf</th></tr></thead>
      <tbody>{factorRotation.map((r) => (<tr><td class="nm">{r.factor}</td><td>{r.perf}</td><td>{r.mechanism}</td><td style="color:var(--text-dim)">{r.analog}</td><td class="mono" style={`color:${cf(r.conf)}`}>{r.conf}</td></tr>))}</tbody>
    </table></div>
    <div class="take">{factorObservations.map((t, i) => (<div class="take-row"><span class="take-n">{i + 1}</span><p>{t}</p></div>))}</div>
  </section>

  <section class="sec">
    <div class="dl">Country equity impact matrix</div>
    <div style="overflow-x:auto"><table class="tbl">
      <thead><tr><th>Country</th><th>Index</th><th>Oil position</th><th>Tag</th><th>Rationale</th></tr></thead>
      <tbody>{countryMatrix.map((r) => (<tr><td class="nm">{r.country}</td><td class="mono">{r.index}</td><td>{r.oil}</td><td style="font-weight:700;white-space:nowrap">{r.tag}</td><td>{r.rationale}</td></tr>))}</tbody>
    </table></div>
    <div class="dl" style="margin-top:18px">Country × scenario (equity impact)</div>
    <div style="overflow-x:auto"><table class="tbl">
      <thead><tr><th>Country</th><th>hormuz_closure</th><th>oil_strike</th><th>cable_severance</th><th>ceasefire</th></tr></thead>
      <tbody>{countryScenario.map((r) => (<tr><td class="nm">{r.country}</td><td>{r.hormuz}</td><td>{r.oil_strike}</td><td>{r.cable}</td><td style="color:#10b981">{r.ceasefire}</td></tr>))}</tbody>
    </table></div>
  </section>

  <section class="sec">
    <div class="dl">GCC equity asymmetry</div>
    <p class="lead2">{gcc.thesis}</p>
    <div class="gcc"><div class="gcc-b" style="border-left-color:#10b981"><div class="gcc-h" style="color:#10b981">Saudi Arabia — oil-revenue winner</div><p>{gcc.saudi}</p></div>
    <div class="gcc-b" style="border-left-color:#ef4444"><div class="gcc-h" style="color:#ef4444">UAE — geographic/security loser</div><p>{gcc.uae}</p></div>
    <div class="gcc-b" style="border-left-color:#f59e0b"><div class="gcc-h" style="color:#f59e0b">Qatar — LNG-revenue casualty</div><p>{gcc.qatar}</p></div></div>
    <div style="overflow-x:auto;margin-top:14px"><table class="tbl">
      <thead><tr><th>Scenario</th><th>Saudi (TASI)</th><th>UAE (DFM/ADX)</th><th>Qatar (QE)</th><th>Mechanism</th></tr></thead>
      <tbody>{gccScenario.map((r) => (<tr><td class="nm">{r.scenario}</td><td>{r.saudi}</td><td>{r.uae}</td><td>{r.qatar}</td><td style="color:var(--text-dim)">{r.mechanism}</td></tr>))}</tbody>
    </table></div>
    <p class="note"><strong style="color:var(--text)">Hedge:</strong> {gccHedge}</p>
  </section>

  <section class="sec">
    <div class="dl">Market plumbing &amp; flows</div>
    <div style="overflow-x:auto"><table class="tbl">
      <thead><tr><th>ETF segment</th><th>Net flow (2026 YTD)</th><th>YTD performance</th><th>Source</th></tr></thead>
      <tbody>{flows.map((r) => (<tr><td class="nm">{r.segment}</td><td>{r.flow}</td><td class="mono">{r.ytd}</td><td class="mono">{r.src}</td></tr>))}</tbody>
    </table></div>
    <p class="note">{flowsNote}</p>
    <div class="chan" style="margin-top:14px">{volOptions.map((v) => (<div class="chan-row"><div class="chan-k">{v.item}</div><p>{v.detail}</p></div>))}</div>
    <div class="callout"><div class="callout-label">Risk-parity / vol-control deleveraging</div><p>{deleveraging}</p></div>
    <div class="callout" style="border-left-color:#a78bfa"><div class="callout-label" style="color:#a78bfa">GCC flows</div><p>{gccFlows}</p></div>
    <div class="callout" style="border-left-color:#818cf8"><div class="callout-label" style="color:#818cf8">Crypto spillover → Section 10</div><p>{cryptoSpillover}</p></div>
  </section>

  <section class="sec">
    <div class="dl">Equity scenario trade map</div>
    {scenarioTrades.map((s) => (
      <div class="pb" style={`border-left:3px solid ${s.tone}`}>
        <div class="pb-head" style={`color:${s.tone}`}>{s.scenario} — {s.label}</div>
        <p class="pb-regime">{s.regime}</p>
        <div style="overflow-x:auto"><table class="tbl">
          <thead><tr><th>Dir.</th><th>Trade</th><th>Instrument</th><th>Rationale</th></tr></thead>
          <tbody>{s.trades.map((t) => (<tr><td style={`color:${dc(t.direction)};font-weight:700;white-space:nowrap`}>{t.direction}</td><td class="nm">{t.trade}</td><td class="mono">{t.instrument}</td><td>{t.rationale}</td></tr>))}</tbody>
        </table></div>
      </div>
    ))}
  </section>

  <section class="sec">
    <div class="dl">Historical precedent compendium</div>
    {precedents.map((p) => (
      <details class="ev"><summary class="es"><div class="el"><span class="en">∎</span><div class="et">{p.episode}</div></div></summary>
      <div class="ey"><ul class="plist">{p.points.map((pt) => (<li>{pt}</li>))}</ul></div></details>
    ))}
  </section>

  <div class="ev-list">
    {cards.map((c) => (
      <details class="ev"><summary class="es"><div class="el"><span class="en">{c.icon}</span><div>
        <div class="et">{c.title}<span class="cat">{c.category}</span></div><div class="eb">{c.summary}</div></div></div>
        <span class={`conf conf-${c.confidence}`}>{c.confidence}</span></summary>
        <div class="ey"><div class="mgrid">{c.metrics.map((mm) => (<div class="metric"><div class="ml">{mm.label}</div><div class="mv">{mm.value}</div></div>))}</div>
        {c.sources.length > 0 && <div><div class="dl">Sources</div><p class="srctext">{c.sources.map((u, i) => (<a href={u.url} target="_blank" rel="noopener" style="color:#60a5fa;margin-right:10px;font-size:13px;text-decoration:none">[{i + 1}]</a>))}</p></div>}</div>
      </details>
    ))}
  </div>

  <section class="sec">
    <details class="reg"><summary class="reg-s">Numbers upgraded to HIGH confidence ({upgradedConfidence.length})</summary>
    <ol class="reg-list">{upgradedConfidence.map((x) => (<li>{x}</li>))}</ol></details>
    <details class="reg"><summary class="reg-s">Could not verify / proxy only ({proxyOnly.length})</summary>
    <ol class="reg-list">{proxyOnly.map((x) => (<li>{x}</li>))}</ol></details>
  </section>

  <div class="foot-box">
    <div class="dl">Data quality &amp; methodology</div>
    <p><strong style="color:#10b981">HIGH</strong> — {dataQuality.high}</p>
    <p><strong style="color:#f59e0b">MODERATE</strong> — {dataQuality.moderate}</p>
    <p><strong style="color:var(--text-dim)">Quarantined</strong> — {dataQuality.quarantined}</p>
    <p class="next"><strong>Related:</strong> {relatedSectors}</p>
  </div>
</AnalysisLayout>

<style>
  .hero{margin-bottom:2.5rem;padding-bottom:2rem;border-bottom:1px solid var(--border)}
  .label{font-family:var(--font-mono);font-size:11px;color:var(--cyan);letter-spacing:3px;text-transform:uppercase;margin-bottom:16px}
  .hero h1{font-family:var(--font-display);font-size:clamp(1.8rem,3.5vw,2.4rem);font-weight:400;color:var(--text);line-height:1.15;margin-bottom:1rem}
  .lead{font-size:15px;color:var(--text-muted);line-height:1.7;max-width:760px}
  .lead2{font-size:14px;color:var(--text-muted);line-height:1.7;max-width:860px;margin:0 0 14px}
  .thesis{background:var(--bg-surface);border:1px solid var(--border);border-left:3px solid #6366f1;border-radius:8px;padding:16px 20px;margin-bottom:2.5rem;max-width:880px}
  .thesis-label{font-family:var(--font-mono);font-size:10px;font-weight:700;color:#818cf8;text-transform:uppercase;letter-spacing:1.5px;margin-bottom:8px}
  .thesis p{font-size:14px;color:var(--text-muted);line-height:1.7;margin:0}
  .dl{font-family:var(--font-mono);font-size:10px;font-weight:700;color:var(--cyan);text-transform:uppercase;letter-spacing:1.5px;margin-bottom:8px}
  .sec{margin-bottom:3rem}
  .tbl{width:100%;border-collapse:collapse;font-size:12px;margin-top:8px}
  .tbl th{padding:8px 10px;text-align:left;border-bottom:2px solid var(--border);font-family:var(--font-mono);font-size:10px;font-weight:700;letter-spacing:1px;text-transform:uppercase;color:var(--text-dim);white-space:nowrap}
  .tbl td{padding:7px 10px;border-bottom:1px solid var(--border);color:var(--text-dim);line-height:1.45;vertical-align:top;min-width:70px}
  .nm{font-weight:700;color:var(--text)}
  .mono{font-family:var(--font-mono);font-size:11px;color:var(--text-muted)}
  .note{font-size:12px;color:var(--text-dim);line-height:1.6;margin-top:10px;max-width:880px}
  .ssg{display:flex;flex-direction:column;gap:8px;margin-top:14px}
  .ssg-row{display:grid;grid-template-columns:160px 1fr;gap:12px;align-items:baseline}
  .ssg-k{font-family:var(--font-mono);font-size:11px;font-weight:700;color:var(--cyan)}
  .ssg-row p{font-size:12px;color:var(--text-muted);line-height:1.5;margin:0}
  .chan{display:flex;flex-direction:column;gap:10px;margin-top:6px}
  .chan-row{background:var(--bg-surface);border:1px solid var(--border);border-radius:8px;padding:11px 15px}
  .chan-k{font-family:var(--font-mono);font-size:11px;font-weight:700;color:var(--cyan);text-transform:uppercase;letter-spacing:.5px;margin-bottom:4px}
  .chan-row p{font-size:12.5px;color:var(--text-muted);line-height:1.55;margin:0}
  .take{display:flex;flex-direction:column;gap:10px;margin-top:14px}
  .take-row{display:flex;gap:12px;align-items:flex-start}
  .take-n{font-family:var(--font-mono);font-size:13px;font-weight:800;color:var(--cyan);min-width:22px}
  .take-row p{font-size:13px;color:var(--text-muted);line-height:1.6;margin:0}
  .gcc{display:grid;grid-template-columns:1fr;gap:10px;margin-top:6px}
  .gcc-b{background:var(--bg-surface);border:1px solid var(--border);border-left:3px solid;border-radius:8px;padding:12px 16px}
  .gcc-h{font-family:var(--font-mono);font-size:11px;font-weight:700;margin-bottom:5px;letter-spacing:.3px}
  .gcc-b p{font-size:12.5px;color:var(--text-muted);line-height:1.55;margin:0}
  .callout{font-size:13px;color:var(--text-muted);line-height:1.65;padding:13px 17px;background:var(--bg-surface);border:1px solid var(--border);border-left:3px solid var(--cyan);border-radius:8px;max-width:880px;margin-top:14px}
  .callout-label{font-family:var(--font-mono);font-size:10px;font-weight:700;color:var(--cyan);text-transform:uppercase;letter-spacing:1.5px;margin-bottom:7px}
  .callout p{margin:0}
  .pb{background:var(--bg-surface);border:1px solid var(--border);border-radius:8px;padding:14px 18px;margin-top:12px}
  .pb-head{font-family:var(--font-mono);font-size:13px;font-weight:800;margin-bottom:6px;letter-spacing:.3px}
  .pb-regime{font-size:12px;color:var(--text-dim);line-height:1.5;margin:0 0 8px}
  .ev-list{display:flex;flex-direction:column;gap:8px;margin-bottom:3rem}
  .ev{background:var(--bg-surface);border:1px solid var(--border);border-radius:10px;overflow:hidden;margin-bottom:8px}
  .ev[open]{border-color:var(--border-light)}.ev[open] .es{border-bottom:1px solid var(--border)}
  .es{display:flex;justify-content:space-between;align-items:flex-start;padding:15px 20px;cursor:pointer;list-style:none;gap:12px}
  .es::-webkit-details-marker{display:none}.es::marker{content:''}
  .es:hover{background:rgba(255,255,255,0.02)}
  .el{display:flex;gap:14px;flex:1;min-width:0}
  .en{font-family:var(--font-mono);font-size:12px;font-weight:700;color:var(--cyan);min-width:18px;padding-top:2px}
  .et{font-size:15px;font-weight:700;color:var(--text);margin-bottom:4px;display:flex;align-items:center;gap:8px;flex-wrap:wrap}
  .cat{font-family:var(--font-mono);font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:1px;padding:1px 7px;border:1px solid var(--border);border-radius:4px;color:var(--text-dim)}
  .eb{font-size:12px;color:var(--text-dim);line-height:1.5;display:-webkit-box;-webkit-line-clamp:3;-webkit-box-orient:vertical;overflow:hidden}
  .conf{font-family:var(--font-mono);font-size:10px;font-weight:700;padding:2px 8px;border-radius:4px;white-space:nowrap;flex-shrink:0;margin-top:2px}
  .conf-high{color:#10b981;background:rgba(16,185,129,0.1)}.conf-medium{color:#f59e0b;background:rgba(245,158,11,0.1)}.conf-low{color:#ef4444;background:rgba(239,68,68,0.1)}
  .ey{padding:14px 20px 18px}
  .mgrid{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:14px}
  .metric{padding:10px 14px;background:var(--bg-card);border:1px solid var(--border);border-radius:6px}
  .ml{font-family:var(--font-mono);font-size:9px;font-weight:700;color:var(--cyan);text-transform:uppercase;letter-spacing:1px;margin-bottom:4px}
  .mv{font-size:13px;color:var(--text-muted);line-height:1.45}
  .srctext{font-size:13px;color:var(--text-muted);line-height:1.6;margin:0}
  .plist{margin:0;padding-left:18px}.plist li{font-size:13px;color:var(--text-muted);line-height:1.6;margin-bottom:5px}
  .reg{background:var(--bg-surface);border:1px solid var(--border);border-radius:8px;margin-bottom:10px;overflow:hidden}
  .reg-s{padding:13px 18px;cursor:pointer;font-family:var(--font-mono);font-size:11px;font-weight:700;color:var(--cyan);text-transform:uppercase;letter-spacing:1px;list-style:none}
  .reg-s::-webkit-details-marker{display:none}
  .reg-list{margin:0;padding:0 20px 16px 38px}.reg-list li{font-size:12px;color:var(--text-dim);line-height:1.55;margin-bottom:6px}
  .foot-box{background:var(--bg-surface);border:1px solid var(--border);border-radius:8px;padding:16px 20px;margin-bottom:1rem}
  .foot-box p{font-size:12px;color:var(--text-dim);line-height:1.6;margin:0 0 8px}
  .foot-box .next{margin:0}.foot-box strong{color:var(--cyan)}
  @media(max-width:720px){.ssg-row{grid-template-columns:1fr;gap:2px}.mgrid{grid-template-columns:1fr}.eb{display:none}}
</style>
