---
import AnalysisLayout from '../../../layouts/AnalysisLayout.astro';
import SignalPanel from '../../../components/SignalPanel.astro';
import { cards, thesis, premiumTrajectory, scenarioImpact, dataQuality, nextSection, precedents, precedentNote, premiumGeography, investmentImplications } from '../../../data/analysis/insurance.js';
import { termStructure, termMap } from '../../../data/analysis/crossasset.js';
const ca_freight = termStructure.find(t => t.curve.startsWith('Freight'));
const ca_vlcc = termMap.find(t => t.curve.startsWith('VLCC'));
const catColor = { structural: '#a78bfa', sector: '#f59e0b', dynamic: '#22d3ee' };
---

<AnalysisLayout
  title="Insurance, Shipping Finance & Trade Credit — VegaReady"
  description="The insurance market is the transmission mechanism for shipping disruption. War-risk premiums, P&I club cancellations, VLCC freight records, Lloyd's capacity, and reinsurance backstops across the 2026 Gulf conflict."
  section="Insurance"
  area="markets"
>
  <section class="hero">
    <div class="label">Markets · Insurance & Shipping Finance</div>
    <h1>When the premium <br/>is the transmission.</h1>
    <p class="lead">War-risk insurance isn't downstream of the shipping shock — it <em>is</em> the shock's transmission mechanism. When the Joint War Committee re-lists the Gulf and P&I clubs cancel cover, hulls stop moving before a single freight rate prints. These are the dated, hard-number events of that machinery, Feb–May 2026 — each figure carries its source and tier.</p>
  </section>

  <SignalPanel page="/markets/insurance" />

  <div class="thesis">
    <div class="thesis-label">The structural finding</div>
    <p>{thesis}</p>
  </div>

  <section class="traj">
    <div class="dl">War-risk premium trajectory · $100M VLCC, 7-day cover</div>
    <div class="traj-row">
      {premiumTrajectory.map((p) => (
        <div class="traj-step">
          <div class="traj-phase">{p.phase}</div>
          <div class="traj-date">{p.date}</div>
          <div class="traj-awrp">{p.awrp}</div>
          <div class="traj-cost">{p.cost}</div>
          <div class="traj-note">{p.note}</div>
        </div>
      ))}
    </div>
    <p class="geo">{premiumGeography}</p>
  </section>

  <div class="ev-list">
    {cards.map((c) => (
      <details class="ev">
        <summary class="es">
          <div class="el">
            <span class="en">{c.icon}</span>
            <div>
              <div class="et">{c.title}<span class="cat" style={`color:${catColor[c.category] || '#9ca3af'};border-color:${(catColor[c.category] || '#9ca3af')}40`}>{c.category}</span></div>
              <div class="eb">{c.summary}</div>
            </div>
          </div>
          <span class={`conf conf-${c.confidence}`}>{c.confidence}</span>
        </summary>
        <div class="ey">
          <div class="mgrid">
            {c.metrics.map((mm) => (
              <div class="metric"><div class="ml">{mm.label}</div><div class="mv">{mm.value}</div></div>
            ))}
          </div>
          <div class="ds"><div class="dl">Sources</div><p>{c.sources.map((u, i) => (<a href={u} target="_blank" rel="noopener" style="color:#60a5fa;margin-right:10px;font-size:13px;text-decoration:none">[{i + 1}]</a>))}</p></div>
        </div>
      </details>
    ))}
  </div>

  <section class="scen">
    <div class="dl">Scenario impact analysis</div>
    {scenarioImpact.map((sc) => (
      <div class="scen-block" style={`border-left:3px solid ${sc.tone}`}>
        <div class="scen-head"><span class="scen-name" style={`color:${sc.tone}`}>{sc.label}</span><span class="scen-status">{sc.status.replace(/_/g, ' ')}</span></div>
        <div class="ds"><div class="dl">Transmission mechanism</div><p>{sc.mechanism}</p></div>
        <div class="dr">
          <div class="ds"><div class="dl">Winners</div><p>{sc.winners}</p></div>
          <div class="ds"><div class="dl">Losers</div><p>{sc.losers}</p></div>
        </div>
        <div class="ds"><div class="dl">Return dynamics</div><p>{sc.returnDynamics}</p></div>
      </div>
    ))}
  </section>

  <section class="prec">
    <div class="dl">Historical episode comparison</div>
    <div style="overflow-x:auto">
      <table class="prec-table">
        <thead><tr><th>Episode</th><th>Period</th><th>Peak AWRP (% hull, 7-day)</th><th>Mechanism</th></tr></thead>
        <tbody>
          {precedents.map((p) => (
            <tr class={p.current ? 'prec-cur' : ''}>
              <td class="prec-name">{p.episode}</td><td>{p.period}</td><td>{p.peak}</td><td>{p.mechanism}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
    <p class="prec-note">{precedentNote}</p>
  </section>

  <section class="inv">
    <div class="dl">Capital-flow & investment implications</div>
    {investmentImplications.map((it) => (
      <div class="inv-block">
        <div class="inv-name">{it.stakeholder}</div>
        <p>{it.text}</p>
      </div>
    ))}
  </section>

  <section class="mdr">
    <div class="mdr-h">Market-derivative read <span>· Cross-Asset</span></div>
    <div class="mdr-rows">
      <div class="mdr-row"><span class="mdr-k">Freight as volatility</span><span class="mdr-v">{ca_freight.detail}</span></div>
      <div class="mdr-row"><span class="mdr-k">VLCC term structure</span><span class="mdr-v">{ca_vlcc.shape} — {ca_vlcc.duration}</span></div>
      <div class="mdr-row"><span class="mdr-k">War-risk premium</span><span class="mdr-v">AWRP peaked ~2.5% hull/7-day (now ~1%) — among the highest realized-vol instruments of the conflict</span></div>
    </div>
    <a href="/markets/cross-asset" class="mdr-link">Full cross-asset view →</a> <span style="color:var(--text-dim)">·</span> <a href="/markets/equities" class="mdr-link">Insurers (equities) →</a>
  </section>

  <div class="foot-box">
    <div class="dl">Data quality &amp; methodology</div>
    <p><strong style="color:#10b981">HIGH</strong> — {dataQuality.high}</p>
    <p><strong style="color:#f59e0b">MEDIUM</strong> — {dataQuality.medium}</p>
    <p><strong style="color:var(--text-dim)">Quarantined (not anchored)</strong> — {dataQuality.quarantined}</p>
    <p class="next"><strong>Next:</strong> {nextSection} Trade-finance, shadow-fleet, and correspondent-banking plumbing sits on <a href="/markets/credit" style="color:var(--cyan)">/markets/credit</a>. Cross-section causal link: war-risk premiums and freight surcharge the delivered oil barrel and the structural floor — see <a href="/markets/cross-asset" style="color:var(--cyan)">/markets/cross-asset</a> and the causal map on <a href="/connections" style="color:var(--cyan)">/connections</a>.</p>
  </div>
</AnalysisLayout>

<style>
  .hero{margin-bottom:3rem;padding-bottom:2rem;border-bottom:1px solid var(--border)}
  .label{font-family:var(--font-mono);font-size:11px;color:var(--cyan);letter-spacing:3px;text-transform:uppercase;margin-bottom:16px}
  .hero h1{font-family:var(--font-display);font-size:clamp(1.8rem,3.5vw,2.4rem);font-weight:400;color:var(--text);line-height:1.15;margin-bottom:1rem}
  .lead{font-size:15px;color:var(--text-muted);line-height:1.7;max-width:680px}
  .lead em{color:var(--text);font-style:italic}
  .ev-list{display:flex;flex-direction:column;gap:8px;margin-bottom:3rem}
  .ev{background:var(--bg-surface);border:1px solid var(--border);border-radius:10px;overflow:hidden}
  .ev[open]{border-color:var(--border-light)}
  .ev[open] .es{border-bottom:1px solid var(--border)}
  .es{display:flex;justify-content:space-between;align-items:flex-start;padding:16px 20px;cursor:pointer;list-style:none;gap:12px}
  .es::-webkit-details-marker{display:none}
  .es::marker{content:''}
  .es:hover{background:rgba(255,255,255,0.02)}
  .el{display:flex;gap:14px;flex:1;min-width:0}
  .en{font-family:var(--font-mono);font-size:12px;font-weight:700;color:var(--cyan);min-width:22px;padding-top:2px}
  .et{font-size:15px;font-weight:700;color:var(--text);margin-bottom:4px;display:flex;align-items:center;gap:8px;flex-wrap:wrap}
  .cat{font-family:var(--font-mono);font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:1px;padding:1px 7px;border:1px solid;border-radius:4px}
  .eb{font-size:12px;color:var(--text-dim);line-height:1.5;display:-webkit-box;-webkit-line-clamp:3;-webkit-box-orient:vertical;overflow:hidden}
  .conf{font-family:var(--font-mono);font-size:10px;font-weight:700;padding:2px 8px;border-radius:4px;white-space:nowrap;flex-shrink:0;margin-top:2px}
  .conf-high{color:#10b981;background:rgba(16,185,129,0.1)}
  .conf-medium{color:#f59e0b;background:rgba(245,158,11,0.1)}
  .conf-low{color:#ef4444;background:rgba(239,68,68,0.1)}
  .ey{padding:16px 20px 20px}
  .mgrid{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:16px}
  .metric{padding:10px 14px;background:var(--bg-card);border:1px solid var(--border);border-radius:6px}
  .ml{font-family:var(--font-mono);font-size:9px;font-weight:700;color:var(--cyan);text-transform:uppercase;letter-spacing:1px;margin-bottom:4px}
  .mv{font-size:13px;color:var(--text-muted);line-height:1.45}
  .ds{margin-bottom:0}
  .dl{font-family:var(--font-mono);font-size:10px;font-weight:700;color:var(--cyan);text-transform:uppercase;letter-spacing:1.5px;margin-bottom:6px}
  .ds p{font-size:13px;color:var(--text-muted);line-height:1.6;margin:0}
  .foot-box{background:var(--bg-surface);border:1px solid var(--border);border-radius:8px;padding:16px 20px;margin-bottom:1rem}
  .foot-box p{font-size:12px;color:var(--text-dim);line-height:1.6;margin:0 0 8px}
  .foot-box .next{margin:0}
  .foot-box strong{color:var(--cyan)}
  @media(max-width:720px){.mgrid{grid-template-columns:1fr}.eb{display:none}.traj-row{grid-template-columns:1fr 1fr}.dr{grid-template-columns:1fr}}
  .thesis{background:var(--bg-surface);border:1px solid var(--border);border-left:3px solid var(--cyan);border-radius:8px;padding:16px 20px;margin-bottom:2.5rem;max-width:760px}
  .thesis-label{font-family:var(--font-mono);font-size:10px;font-weight:700;color:var(--cyan);text-transform:uppercase;letter-spacing:1.5px;margin-bottom:8px}
  .thesis p{font-size:14px;color:var(--text-muted);line-height:1.7;margin:0}
  .traj{margin-bottom:3rem}
  .traj-row{display:grid;grid-template-columns:repeat(4,1fr);gap:8px;margin-top:12px}
  .traj-step{background:var(--bg-surface);border:1px solid var(--border);border-radius:8px;padding:12px 14px}
  .traj-phase{font-size:13px;font-weight:700;color:var(--text)}
  .traj-date{font-family:var(--font-mono);font-size:10px;color:var(--text-dim);margin-bottom:8px}
  .traj-awrp{font-family:var(--font-mono);font-size:17px;font-weight:700;color:var(--cyan);line-height:1.1}
  .traj-cost{font-size:12px;color:var(--text-muted);margin:2px 0 8px}
  .traj-note{font-size:11px;color:var(--text-dim);line-height:1.45}
  .scen{margin-bottom:3rem}
  .scen-block{background:var(--bg-surface);border:1px solid var(--border);border-radius:8px;padding:14px 18px;margin-top:10px}
  .scen-head{display:flex;align-items:center;gap:10px;margin-bottom:10px}
  .scen-name{font-size:15px;font-weight:700}
  .scen-status{font-family:var(--font-mono);font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:1px;color:var(--text-dim);border:1px solid var(--border);border-radius:4px;padding:1px 7px}
  .dr{display:grid;grid-template-columns:1fr 1fr;gap:16px}
  .geo{font-size:12px;color:var(--text-dim);line-height:1.5;margin:12px 0 0;font-family:var(--font-mono)}
  .prec{margin-bottom:3rem}
  .prec-table{width:100%;border-collapse:collapse;font-size:12px;margin-top:12px}
  .prec-table th{padding:8px 10px;text-align:left;border-bottom:2px solid var(--border);font-family:var(--font-mono);font-size:10px;font-weight:700;letter-spacing:1px;text-transform:uppercase;color:var(--text-dim);white-space:nowrap}
  .prec-table td{padding:7px 10px;border-bottom:1px solid var(--border);color:var(--text-dim);line-height:1.4;vertical-align:top}
  .prec-name{font-weight:700;color:var(--text)}
  .prec-cur td{color:var(--cyan)}
  .prec-cur .prec-name{color:var(--cyan)}
  .prec-note{font-size:12px;color:var(--text-dim);line-height:1.6;margin-top:12px;max-width:760px}
  .inv{margin-bottom:3rem}
  .inv-block{margin-top:14px}
  .inv-name{font-family:var(--font-mono);font-size:11px;font-weight:700;color:var(--cyan);text-transform:uppercase;letter-spacing:1px;margin-bottom:5px}
  .inv-block p{font-size:13px;color:var(--text-muted);line-height:1.6;margin:0}
  .mdr{background:var(--bg-surface);border:1px solid var(--border);border-left:3px solid #818cf8;border-radius:8px;padding:14px 18px;margin:0 0 2rem;max-width:860px}
  .mdr-h{font-family:var(--font-mono);font-size:10px;font-weight:700;color:#818cf8;text-transform:uppercase;letter-spacing:1.5px;margin-bottom:10px}
  .mdr-h span{color:var(--text-dim)}
  .mdr-rows{display:flex;flex-direction:column;gap:7px;margin-bottom:10px}
  .mdr-row{display:grid;grid-template-columns:150px 1fr;gap:12px;align-items:baseline}
  .mdr-k{font-family:var(--font-mono);font-size:10px;font-weight:700;color:var(--cyan);text-transform:uppercase;letter-spacing:.5px}
  .mdr-v{font-size:12px;color:var(--text-muted);line-height:1.5}
  .mdr-note{font-size:11px;color:#f59e0b;margin:0 0 10px;line-height:1.4}
  .mdr-link{font-family:var(--font-mono);font-size:11px;font-weight:700;color:var(--cyan);text-decoration:none}
  @media(max-width:720px){.mdr-row{grid-template-columns:1fr;gap:2px}}
</style>
