---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';

const briefings = (await getCollection('briefings')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const categoryLabels: Record<string, string> = {
  geopolitical: 'Geopolitical',
  macro: 'Macro & Economic',
  crypto: 'Crypto & Digital',
  technical: 'Technical',
  weekly: 'Weekly Digest',
};

const categoryColors: Record<string, string> = {
  geopolitical: '#ef4444',
  macro: '#f59e0b',
  crypto: '#6366f1',
  technical: '#22d3ee',
  weekly: '#10b981',
};
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead
      title="Briefings — VegaReady"
      description="Market intelligence briefings from VegaReady. Geopolitical analysis, macro event tracking, and their market impact — published regularly."
    />
  </head>
  <body>
    <Header />

    <main class="briefings">
      <section class="briefings-hero">
        <div class="briefings-label">Briefings</div>
        <h1>Market intelligence,<br/>published openly.</h1>
        <p class="briefings-lead">
          Analysis of global events and their market transmission paths.
          Geopolitical, macro, crypto, and technical — each briefing maps
          the connection between what happened and what moved.
        </p>
      </section>

      {briefings.length === 0 ? (
        <div class="empty-state">
          <div class="empty-icon">&nu;</div>
          <div class="empty-title">First briefings coming soon</div>
          <div class="empty-desc">
            We're preparing our initial series of market intelligence briefings.
            In the meantime, explore the live dashboard for real-time data.
          </div>
          <a href="/dashboard" class="empty-cta">Open Dashboard</a>
        </div>
      ) : (
        <div class="briefing-list">
          {briefings.map((briefing) => (
            <a href={`/briefings/${briefing.id}`} class="briefing-card">
              <div class="briefing-meta">
                <span
                  class="briefing-cat"
                  style={`color: ${categoryColors[briefing.data.category] || '#8892a4'}; border-color: ${categoryColors[briefing.data.category] || '#8892a4'}30`}
                >
                  {categoryLabels[briefing.data.category] || briefing.data.category}
                </span>
                <span class="briefing-date">
                  {briefing.data.pubDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
                </span>
              </div>
              <h2 class="briefing-title">{briefing.data.title}</h2>
              <p class="briefing-desc">{briefing.data.description}</p>
              {briefing.data.tags.length > 0 && (
                <div class="briefing-tags">
                  {briefing.data.tags.map((tag: string) => (
                    <span class="briefing-tag">{tag}</span>
                  ))}
                </div>
              )}
            </a>
          ))}
        </div>
      )}
    </main>

    <Footer />
  </body>
</html>

<style>
  .briefings {
    max-width: 760px;
    margin: 0 auto;
    padding: 4rem 2rem;
  }
  .briefings-hero {
    margin-bottom: 3rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--border);
  }
  .briefings-label {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--cyan);
    letter-spacing: 3px;
    text-transform: uppercase;
    margin-bottom: 16px;
  }
  .briefings-hero h1 {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw, 2.8rem);
    font-weight: 400;
    color: var(--text);
    line-height: 1.15;
    margin-bottom: 1.5rem;
  }
  .briefings-lead {
    font-size: 15px;
    color: var(--text-muted);
    line-height: 1.7;
    max-width: 520px;
  }

  /* Empty state */
  .empty-state {
    text-align: center;
    padding: 4rem 2rem;
    background: var(--bg-surface);
    border: 1px solid var(--border);
    border-radius: 12px;
  }
  .empty-icon {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 36px;
    color: var(--text-dim);
    margin-bottom: 16px;
  }
  .empty-title {
    font-family: var(--font-mono);
    font-size: 16px;
    font-weight: 700;
    color: var(--text);
    margin-bottom: 8px;
  }
  .empty-desc {
    font-size: 14px;
    color: var(--text-muted);
    max-width: 360px;
    margin: 0 auto 20px;
    line-height: 1.6;
  }
  .empty-cta {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-mono);
    font-size: 13px;
    font-weight: 600;
    color: var(--bg);
    background: var(--cyan);
    padding: 8px 18px;
    border-radius: 6px;
  }

  /* Briefing list */
  .briefing-list {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .briefing-card {
    display: block;
    background: var(--bg-surface);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 20px 24px;
    transition: all 0.2s;
    text-decoration: none;
    color: inherit;
  }
  .briefing-card:hover {
    border-color: var(--border-light);
    transform: translateY(-2px);
    box-shadow: 0 4px 16px rgba(0,0,0,0.2);
    opacity: 1;
  }
  .briefing-meta {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 8px;
  }
  .briefing-cat {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
    padding: 2px 8px;
    border: 1px solid;
    border-radius: 4px;
  }
  .briefing-date {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--text-dim);
  }
  .briefing-title {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 400;
    color: var(--text);
    margin-bottom: 6px;
    line-height: 1.3;
  }
  .briefing-desc {
    font-size: 13px;
    color: var(--text-muted);
    line-height: 1.6;
    margin: 0;
  }
  .briefing-tags {
    display: flex;
    gap: 4px;
    margin-top: 10px;
    flex-wrap: wrap;
  }
  .briefing-tag {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--text-dim);
    padding: 2px 8px;
    background: rgba(255,255,255,0.04);
    border-radius: 3px;
  }
</style>
