---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const briefings = await getCollection('briefings');
  return briefings.map((entry) => ({
    params: { slug: entry.id },
    props: entry,
  }));
}

const entry = Astro.props;
const { Content } = await render(entry);

const categoryLabels: Record<string, string> = {
  geopolitical: 'Geopolitical',
  macro: 'Macro & Economic',
  crypto: 'Crypto & Digital',
  technical: 'Technical',
  weekly: 'Weekly Digest',
};
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead
      title={`${entry.data.title} — VegaReady`}
      description={entry.data.description}
    />
  </head>
  <body>
    <Header />

    <main class="briefing-page">
      <article>
        <div class="briefing-header">
          <a href="/briefings" class="back-link">&larr; All Briefings</a>
          <div class="briefing-meta">
            <span class="briefing-cat">{categoryLabels[entry.data.category] || entry.data.category}</span>
            <span class="briefing-date">
              {entry.data.pubDate.toLocaleDateString('en-US', { weekday: 'long', month: 'long', day: 'numeric', year: 'numeric' })}
            </span>
          </div>
          <h1>{entry.data.title}</h1>
          <p class="briefing-desc">{entry.data.description}</p>
        </div>

        <div class="briefing-content">
          <Content />
        </div>

        {entry.data.tags.length > 0 && (
          <div class="briefing-footer-tags">
            {entry.data.tags.map((tag: string) => (
              <span class="tag">{tag}</span>
            ))}
          </div>
        )}
      </article>

      <div class="briefing-nav">
        <a href="/briefings">&larr; Back to all briefings</a>
        <a href="/dashboard">Open Dashboard &rarr;</a>
      </div>
    </main>

    <Footer />
  </body>
</html>

<style>
  .briefing-page {
    max-width: 680px;
    margin: 0 auto;
    padding: 3rem 2rem;
  }
  .back-link {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--text-dim);
    margin-bottom: 2rem;
    display: inline-block;
  }
  .briefing-header {
    margin-bottom: 3rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--border);
  }
  .briefing-meta {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 16px;
  }
  .briefing-cat {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 700;
    color: var(--cyan);
    text-transform: uppercase;
    letter-spacing: 1px;
    padding: 2px 8px;
    border: 1px solid rgba(34, 211, 238, 0.3);
    border-radius: 4px;
  }
  .briefing-date {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--text-dim);
  }
  .briefing-header h1 {
    font-family: var(--font-display);
    font-size: clamp(1.8rem, 3.5vw, 2.4rem);
    font-weight: 400;
    color: var(--text);
    line-height: 1.2;
    margin-bottom: 12px;
  }
  .briefing-desc {
    font-size: 16px;
    color: var(--text-muted);
    line-height: 1.6;
    margin: 0;
  }
  .briefing-content {
    font-size: 15px;
    color: var(--text-muted);
    line-height: 1.8;
  }
  .briefing-content :global(h2) {
    font-family: var(--font-display);
    font-size: 1.4rem;
    color: var(--text);
    margin: 2.5rem 0 1rem;
  }
  .briefing-content :global(h3) {
    font-family: var(--font-mono);
    font-size: 14px;
    font-weight: 700;
    color: var(--text);
    text-transform: uppercase;
    letter-spacing: 1px;
    margin: 2rem 0 0.75rem;
  }
  .briefing-content :global(p) {
    margin-bottom: 1.2rem;
  }
  .briefing-content :global(strong) {
    color: var(--text);
  }
  .briefing-content :global(code) {
    font-family: var(--font-mono);
    font-size: 13px;
    background: var(--bg-card);
    padding: 2px 6px;
    border-radius: 3px;
    color: var(--cyan);
  }
  .briefing-content :global(blockquote) {
    border-left: 2px solid var(--cyan);
    padding-left: 16px;
    margin: 1.5rem 0;
    font-family: var(--font-display);
    font-style: italic;
    color: var(--text);
    font-size: 17px;
  }
  .briefing-content :global(ul), .briefing-content :global(ol) {
    padding-left: 20px;
    margin-bottom: 1.2rem;
  }
  .briefing-content :global(li) {
    margin-bottom: 0.4rem;
  }
  .briefing-footer-tags {
    display: flex;
    gap: 4px;
    flex-wrap: wrap;
    margin-top: 2rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border);
  }
  .tag {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--text-dim);
    padding: 3px 10px;
    background: rgba(255,255,255,0.04);
    border-radius: 4px;
  }
  .briefing-nav {
    display: flex;
    justify-content: space-between;
    margin-top: 3rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border);
    font-family: var(--font-mono);
    font-size: 13px;
  }
</style>
