---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Header />

    <main>
      <!-- ═══ HERO ═══ -->
      <section class="hero">
        <div class="hero-inner">
          <div class="hero-definition">
            <span class="def-label">/ vega /</span>
            <span class="def-greek">&nu;</span>
          </div>
          <h1 class="hero-title">
            Sensitivity to<br/>
            <span class="hero-accent">volatility.</span>
          </h1>
          <p class="hero-sub">
            Markets move when the world shakes. VegaReady tracks global events,
            measures their impact across market sectors, and delivers the intelligence
            that separates reactive traders from prepared ones.
          </p>
          <div class="hero-tagline">Volatility isn't risk. It's signal.</div>
          <div class="hero-actions">
            <a href="/dashboard" class="btn-primary">
              <span class="btn-dot"></span>
              Open Dashboard
            </a>
            <a href="/about" class="btn-ghost">How it works</a>
          </div>
        </div>

        <!-- Terminal definition card -->
        <div class="terminal-card">
          <div class="terminal-bar">
            <span class="terminal-dot red"></span>
            <span class="terminal-dot amber"></span>
            <span class="terminal-dot green"></span>
            <span class="terminal-title">vegarready.com</span>
          </div>
          <div class="terminal-body">
            <div class="term-line"><span class="term-key">term</span> <span class="term-colon">:</span> <span class="term-val">Vega (&nu;)</span></div>
            <div class="term-line"><span class="term-key">meaning</span> <span class="term-colon">:</span> <span class="term-val">How sensitive a position is to changes in market volatility</span></div>
            <div class="term-line"><span class="term-key">in practice</span> <span class="term-colon">:</span> <span class="term-val">High-vega strategies profit when volatility spikes</span></div>
            <div class="term-line dim"><span class="term-key">problem</span> <span class="term-colon">:</span> <span class="term-val">Most traders absorb volatility. They react after the damage.</span></div>
            <div class="term-divider"></div>
            <div class="term-line highlight"><span class="term-key">our edge</span> <span class="term-colon">:</span> <span class="term-val">We see the volatility coming. We enter fast. We exit faster.</span></div>
            <div class="term-line highlight"><span class="term-key">&nbsp;</span> <span class="term-colon">&nbsp;</span> <span class="term-val">We make you vega-ready.</span></div>
          </div>
        </div>
      </section>

      <!-- ═══ INTELLIGENCE LAYERS ═══ -->
      <section class="cascade">
        <div class="cascade-label">Macro event intelligence</div>
        <h2 class="section-title">Global events. Market reactions. Connected.</h2>
        <p class="section-sub">We track macro events across geopolitics, regulation, economics, and technology — then map how each event cascades through the markets that matter.</p>

        <div class="cascade-flow">
          <div class="cascade-node event">
            <div class="node-icon">!</div>
            <div class="node-label">Global Event</div>
            <div class="node-detail">Conflicts, sanctions, policy shifts, regulatory changes, supply shocks</div>
          </div>
          <div class="cascade-arrow"></div>
          <div class="cascade-node oil">
            <div class="node-icon">&bull;</div>
            <div class="node-label">Fundamentals</div>
            <div class="node-detail">Commodities, energy, trade flows, supply chains, currency stress</div>
          </div>
          <div class="cascade-arrow"></div>
          <div class="cascade-node shipping">
            <div class="node-icon">&bull;</div>
            <div class="node-label">Market Sectors</div>
            <div class="node-detail">Crypto, equities, derivatives, fixed income, forex, risk premiums</div>
          </div>
          <div class="cascade-arrow"></div>
          <div class="cascade-node markets">
            <div class="node-icon">&bull;</div>
            <div class="node-label">Technical Signals</div>
            <div class="node-detail">Momentum shifts, volatility spikes, correlation breaks, flow reversals</div>
          </div>
          <div class="cascade-arrow"></div>
          <div class="cascade-node alpha">
            <div class="node-icon">&nu;</div>
            <div class="node-label">Position</div>
            <div class="node-detail">Enter fast, defend against drawdown, capitalize on dislocation</div>
          </div>
        </div>
      </section>

      <!-- ═══ VERTICALS ═══ -->
      <section class="capabilities">
        <div class="cap-grid">
          <div class="cap-card">
            <div class="cap-number">&bull;</div>
            <div class="cap-label">Geopolitical</div>
            <div class="cap-detail">Conflicts, military operations, territorial disputes, and their market transmission paths — tracked in real time with AI-verified intelligence</div>
          </div>
          <div class="cap-card">
            <div class="cap-number">&bull;</div>
            <div class="cap-label">Macro & Economic</div>
            <div class="cap-detail">Central bank policy, sanctions regimes, trade agreements, inflation shocks — the fundamental drivers that move every asset class</div>
          </div>
          <div class="cap-card">
            <div class="cap-number">&bull;</div>
            <div class="cap-label">Crypto & Digital</div>
            <div class="cap-detail">On-chain signals, regulatory developments, exchange dynamics, stablecoin stress — where our algo trading engine operates daily</div>
          </div>
          <div class="cap-card">
            <div class="cap-number">&bull;</div>
            <div class="cap-label">Technical Metrics</div>
            <div class="cap-detail">Proprietary momentum indicators, volatility regime detection, and correlation analysis from JCJ's algorithmic trading systems</div>
          </div>
        </div>
      </section>

      <!-- ═══ JCJ POSITIONING ═══ -->
      <section class="positioning">
        <div class="pos-inner">
          <div class="pos-badge">JCJ Investing</div>
          <h2 class="pos-title">Built by people who<br/>trade on this data.</h2>
          <p class="pos-text">
            VegaReady is built and maintained by JCJ Investing — a quantitative,
            event-driven trading firm. This isn't academic research or news
            aggregation. It's the same macro intelligence we use to make
            real trading decisions, every day.
          </p>
          <p class="pos-text dim">
            We publish what we track because good intelligence gets better
            when more eyes are on it. Global event monitoring, market sector
            analysis, and the connections between them — transparent and open.
          </p>
          <div class="pos-coming">
            <div class="coming-item">
              <span class="coming-dot live"></span>
              <span class="coming-label">Live Dashboard</span>
              <span class="coming-status">Active</span>
            </div>
            <div class="coming-item">
              <span class="coming-dot building"></span>
              <span class="coming-label">Market Briefings</span>
              <span class="coming-status">Coming soon</span>
            </div>
            <div class="coming-item">
              <span class="coming-dot building"></span>
              <span class="coming-label">Podcast & Analysis</span>
              <span class="coming-status">Coming soon</span>
            </div>
            <div class="coming-item">
              <span class="coming-dot building"></span>
              <span class="coming-label">Technical Signals Feed</span>
              <span class="coming-status">Coming soon</span>
            </div>
          </div>
          <a href="/dashboard" class="btn-primary" style="margin-top: 2rem;">
            <span class="btn-dot"></span>
            Explore the dashboard
          </a>
        </div>
      </section>
    </main>

    <Footer />
  </body>
</html>

<style>
  /* ═══ HERO ═══ */
  .hero {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 5rem 2rem 4rem;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: center;
  }
  .hero-definition {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 1.5rem;
  }
  .def-label {
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--cyan);
    letter-spacing: 2px;
    text-transform: uppercase;
    padding: 4px 12px;
    border: 1px solid rgba(34, 211, 238, 0.3);
    border-radius: 4px;
  }
  .def-greek {
    font-family: var(--font-display);
    font-size: 24px;
    color: var(--text-dim);
    font-style: italic;
  }
  .hero-title {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 5vw, 3.5rem);
    font-weight: 400;
    line-height: 1.1;
    color: var(--text);
    margin-bottom: 1.5rem;
  }
  .hero-accent {
    color: var(--cyan);
    font-style: italic;
  }
  .hero-sub {
    font-size: 15px;
    color: var(--text-muted);
    line-height: 1.7;
    max-width: 460px;
    margin-bottom: 1.5rem;
  }
  .hero-tagline {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 18px;
    color: var(--text);
    margin-bottom: 2rem;
    padding-left: 16px;
    border-left: 2px solid var(--cyan);
  }
  .hero-actions {
    display: flex;
    gap: 12px;
    align-items: center;
  }

  /* Buttons */
  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-mono);
    font-size: 13px;
    font-weight: 600;
    color: var(--bg);
    background: var(--cyan);
    padding: 10px 22px;
    border-radius: 6px;
    transition: all 0.2s;
  }
  .btn-primary:hover { opacity: 0.9; transform: translateY(-1px); }
  .btn-dot {
    width: 6px; height: 6px;
    background: var(--bg);
    border-radius: 50%;
    opacity: 0.6;
  }
  .btn-ghost {
    font-family: var(--font-mono);
    font-size: 13px;
    font-weight: 500;
    color: var(--text-muted);
    padding: 10px 18px;
    border: 1px solid var(--border);
    border-radius: 6px;
    transition: all 0.2s;
  }
  .btn-ghost:hover { color: var(--text); border-color: var(--border-light); opacity: 1; }

  /* Terminal card */
  .terminal-card {
    background: var(--bg-surface);
    border: 1px solid var(--border);
    border-radius: 10px;
    overflow: hidden;
    box-shadow: 0 8px 32px rgba(0,0,0,0.4);
  }
  .terminal-bar {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 10px 14px;
    background: var(--bg-card);
    border-bottom: 1px solid var(--border);
  }
  .terminal-dot {
    width: 10px; height: 10px;
    border-radius: 50%;
  }
  .terminal-dot.red { background: #ef4444; }
  .terminal-dot.amber { background: #f59e0b; }
  .terminal-dot.green { background: #22c55e; }
  .terminal-title {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--text-dim);
    margin-left: 8px;
  }
  .terminal-body { padding: 16px 18px; }
  .term-line {
    font-family: var(--font-mono);
    font-size: 12px;
    line-height: 2;
    display: flex;
    gap: 6px;
  }
  .term-line.dim { opacity: 0.6; }
  .term-line.highlight .term-val { color: var(--cyan); font-weight: 600; }
  .term-key {
    color: var(--text-dim);
    min-width: 70px;
    text-align: right;
  }
  .term-colon { color: var(--border-light); }
  .term-val { color: var(--text-muted); }
  .term-divider {
    height: 1px;
    background: var(--border);
    margin: 8px 0;
  }

  /* ═══ CASCADE ═══ */
  .cascade {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 5rem 2rem;
    text-align: center;
  }
  .cascade-label {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--cyan);
    letter-spacing: 3px;
    text-transform: uppercase;
    margin-bottom: 12px;
  }
  .section-title {
    font-family: var(--font-display);
    font-size: clamp(1.8rem, 3.5vw, 2.4rem);
    font-weight: 400;
    color: var(--text);
    margin-bottom: 10px;
  }
  .section-sub {
    font-size: 15px;
    color: var(--text-muted);
    max-width: 520px;
    margin: 0 auto 3rem;
  }
  .cascade-flow {
    display: flex;
    align-items: flex-start;
    justify-content: center;
    gap: 0;
    padding: 0 1rem;
  }
  .cascade-node {
    flex: 0 0 160px;
    text-align: center;
    padding: 20px 12px;
    border-radius: 10px;
    border: 1px solid var(--border);
    background: var(--bg-surface);
    transition: all 0.3s;
  }
  .cascade-node:hover {
    border-color: var(--border-light);
    transform: translateY(-4px);
    box-shadow: 0 8px 24px rgba(0,0,0,0.3);
  }
  .cascade-node.event { border-color: rgba(239, 68, 68, 0.3); }
  .cascade-node.event .node-icon { color: var(--red); }
  .cascade-node.oil { border-color: rgba(245, 158, 11, 0.3); }
  .cascade-node.oil .node-icon { color: var(--amber); }
  .cascade-node.shipping { border-color: rgba(59, 130, 246, 0.3); }
  .cascade-node.shipping .node-icon { color: var(--blue); }
  .cascade-node.markets { border-color: rgba(99, 102, 241, 0.3); }
  .cascade-node.markets .node-icon { color: var(--indigo); }
  .cascade-node.alpha { border-color: rgba(34, 211, 238, 0.3); background: rgba(34, 211, 238, 0.05); }
  .cascade-node.alpha .node-icon { color: var(--cyan); }
  .node-icon {
    font-family: var(--font-mono);
    font-size: 20px;
    font-weight: 800;
    margin-bottom: 8px;
  }
  .node-label {
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: 700;
    color: var(--text);
    margin-bottom: 6px;
    letter-spacing: 0.3px;
  }
  .node-detail {
    font-size: 11px;
    color: var(--text-dim);
    line-height: 1.4;
  }
  .cascade-arrow {
    flex: 0 0 32px;
    height: 2px;
    background: linear-gradient(90deg, var(--border-light), var(--text-dim));
    align-self: center;
    margin-top: -20px;
    position: relative;
  }
  .cascade-arrow::after {
    content: '';
    position: absolute;
    right: -1px;
    top: -3px;
    border: 4px solid transparent;
    border-left: 6px solid var(--text-dim);
  }

  /* ═══ CAPABILITIES ═══ */
  .capabilities {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 2rem 2rem 4rem;
  }
  .cap-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 12px;
  }
  .cap-card {
    background: var(--bg-surface);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 24px 20px;
    transition: all 0.3s;
  }
  .cap-card:hover {
    border-color: var(--border-light);
    transform: translateY(-2px);
  }
  .cap-number {
    font-family: var(--font-mono);
    font-size: 28px;
    font-weight: 800;
    color: var(--cyan);
    line-height: 1;
    margin-bottom: 4px;
  }
  .cap-label {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 700;
    color: var(--text);
    text-transform: uppercase;
    letter-spacing: 1.5px;
    margin-bottom: 10px;
  }
  .cap-detail {
    font-size: 12px;
    color: var(--text-dim);
    line-height: 1.5;
  }

  /* ═══ POSITIONING ═══ */
  .positioning {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 4rem 2rem;
  }
  .pos-inner {
    background: var(--bg-surface);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 3rem;
    max-width: 640px;
  }
  .pos-badge {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 700;
    color: var(--cyan);
    letter-spacing: 2px;
    text-transform: uppercase;
    margin-bottom: 16px;
  }
  .pos-title {
    font-family: var(--font-display);
    font-size: 2rem;
    font-weight: 400;
    color: var(--text);
    line-height: 1.2;
    margin-bottom: 1.5rem;
  }
  .pos-text {
    font-size: 15px;
    color: var(--text-muted);
    line-height: 1.7;
    margin-bottom: 1rem;
  }
  .pos-text.dim { color: var(--text-dim); }
  .pos-coming {
    margin-top: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .coming-item {
    display: flex;
    align-items: center;
    gap: 10px;
    font-family: var(--font-mono);
    font-size: 12px;
  }
  .coming-dot {
    width: 8px; height: 8px;
    border-radius: 50%;
    flex-shrink: 0;
  }
  .coming-dot.live {
    background: var(--green);
    box-shadow: 0 0 8px rgba(16, 185, 129, 0.4);
  }
  .coming-dot.building {
    background: var(--amber);
    opacity: 0.6;
  }
  .coming-label {
    color: var(--text);
    font-weight: 600;
    min-width: 180px;
  }
  .coming-status {
    color: var(--text-dim);
    font-weight: 400;
  }

  /* ═══ PROOF ═══ */
  .proof {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 4rem 2rem 3rem;
    text-align: center;
  }
  .proof-label {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--cyan);
    letter-spacing: 3px;
    text-transform: uppercase;
    margin-bottom: 12px;
  }
  .proof-grid {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0;
    margin: 2.5rem 0;
  }
  .proof-card {
    padding: 28px 36px;
    border-radius: 12px;
    text-align: center;
    min-width: 180px;
  }
  .market-card {
    background: rgba(239, 68, 68, 0.06);
    border: 1px solid rgba(239, 68, 68, 0.2);
  }
  .jcj-card {
    background: rgba(34, 211, 238, 0.06);
    border: 1px solid rgba(34, 211, 238, 0.25);
  }
  .proof-icon {
    font-family: var(--font-mono);
    font-size: 18px;
    margin-bottom: 4px;
  }
  .market-card .proof-icon { color: var(--red); }
  .jcj-card .proof-icon { color: var(--cyan); }
  .proof-stat {
    font-family: var(--font-mono);
    font-size: 36px;
    font-weight: 800;
    line-height: 1;
    margin-bottom: 4px;
  }
  .market-card .proof-stat { color: var(--red); }
  .jcj-card .proof-stat { color: var(--cyan); }
  .proof-desc {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 700;
    color: var(--text);
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 2px;
  }
  .proof-context {
    font-size: 11px;
    color: var(--text-dim);
  }
  .proof-vs {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 16px;
    color: var(--text-dim);
    padding: 0 20px;
  }
  .proof-points {
    max-width: 520px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .proof-point {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    text-align: left;
  }
  .pp-marker {
    width: 6px; height: 6px;
    background: var(--cyan);
    border-radius: 50%;
    flex-shrink: 0;
    margin-top: 7px;
  }
  .pp-text {
    font-size: 14px;
    color: var(--text-muted);
    line-height: 1.5;
  }

  /* ═══ RESPONSIVE ═══ */
  @media (max-width: 900px) {
    .hero {
      grid-template-columns: 1fr;
      padding: 3rem 1.5rem 2rem;
    }
    .cascade-flow {
      flex-direction: column;
      align-items: center;
    }
    .cascade-arrow {
      width: 2px;
      height: 24px;
      margin-top: 0;
      flex: 0 0 24px;
    }
    .cascade-arrow::after {
      right: -3px;
      top: auto;
      bottom: -1px;
      border: 4px solid transparent;
      border-top: 6px solid var(--text-dim);
      border-left: 4px solid transparent;
    }
    .cascade-node { flex: 0 0 auto; width: 200px; }
    .cap-grid { grid-template-columns: 1fr 1fr; }
    .pos-inner { padding: 2rem; }
    .proof-grid { flex-direction: column; gap: 12px; }
    .proof-vs { padding: 4px 0; }
  }
  @media (max-width: 520px) {
    .cap-grid { grid-template-columns: 1fr; }
    .coming-label { min-width: auto; }
  }
</style>
