---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Header />

    <main>
      <!-- ═══ HERO ═══ -->
      <section class="hero">
        <div class="hero-inner">
          <div class="hero-definition">
            <span class="def-label">/ vega /</span>
            <span class="def-greek">&nu;</span>
          </div>
          <h1 class="hero-title">
            Sensitivity to<br/>
            <span class="hero-accent">volatility.</span>
          </h1>
          <p class="hero-sub">
            We built the intelligence platform for high-vega thinking.
            When geopolitical shocks move markets, our AI is already tracking
            the cascade — from the event, through oil and shipping, into
            equities and credit.
          </p>
          <div class="hero-tagline">Volatility isn't risk. It's signal.</div>
          <div class="hero-actions">
            <a href="/dashboard" class="btn-primary">
              <span class="btn-dot"></span>
              Open Dashboard
            </a>
            <a href="/about" class="btn-ghost">How it works</a>
          </div>
        </div>

        <!-- Terminal definition card -->
        <div class="terminal-card">
          <div class="terminal-bar">
            <span class="terminal-dot red"></span>
            <span class="terminal-dot amber"></span>
            <span class="terminal-dot green"></span>
            <span class="terminal-title">vegarready.com — vega definition</span>
          </div>
          <div class="terminal-body">
            <div class="term-line"><span class="term-key">term</span> <span class="term-colon">:</span> <span class="term-val">Vega (&nu;)</span></div>
            <div class="term-line"><span class="term-key">field</span> <span class="term-colon">:</span> <span class="term-val">Options pricing, Greeks</span></div>
            <div class="term-line"><span class="term-key">measures</span> <span class="term-colon">:</span> <span class="term-val">Sensitivity of option price to changes in implied volatility</span></div>
            <div class="term-line"><span class="term-key">unit</span> <span class="term-colon">:</span> <span class="term-val">$/1% &Delta;IV</span></div>
            <div class="term-line dim"><span class="term-key">example</span> <span class="term-colon">:</span> <span class="term-val">Vega = 0.15 means option gains $0.15 per 1% rise in IV</span></div>
            <div class="term-divider"></div>
            <div class="term-line highlight"><span class="term-key">thesis</span> <span class="term-colon">:</span> <span class="term-val">A high-vega portfolio profits when volatility spikes.</span></div>
            <div class="term-line highlight"><span class="term-key">&nbsp;</span> <span class="term-colon">&nbsp;</span> <span class="term-val">We make you vega-ready.</span></div>
          </div>
        </div>
      </section>

      <!-- ═══ CASCADE VISUALIZATION ═══ -->
      <section class="cascade">
        <div class="cascade-label">The cascade methodology</div>
        <h2 class="section-title">One event. Every market.</h2>
        <p class="section-sub">We trace the transmission path from geopolitical shock to portfolio impact across every asset class.</p>

        <div class="cascade-flow">
          <div class="cascade-node event">
            <div class="node-icon">!</div>
            <div class="node-label">Event</div>
            <div class="node-detail">Strait of Hormuz closure, sanctions, military strikes</div>
          </div>
          <div class="cascade-arrow"></div>
          <div class="cascade-node oil">
            <div class="node-icon">&bull;</div>
            <div class="node-label">Oil &amp; Energy</div>
            <div class="node-detail">Brent crude, LNG, refinery shutdowns, force majeure</div>
          </div>
          <div class="cascade-arrow"></div>
          <div class="cascade-node shipping">
            <div class="node-icon">&bull;</div>
            <div class="node-label">Shipping</div>
            <div class="node-detail">War-risk premiums, vessel attacks, Hormuz transits</div>
          </div>
          <div class="cascade-arrow"></div>
          <div class="cascade-node markets">
            <div class="node-icon">&bull;</div>
            <div class="node-label">Equities &amp; Credit</div>
            <div class="node-detail">GCC equity selloffs, CDS widening, currency stress</div>
          </div>
          <div class="cascade-arrow"></div>
          <div class="cascade-node alpha">
            <div class="node-icon">&nu;</div>
            <div class="node-label">Alpha</div>
            <div class="node-detail">Volatility-aware positioning across the cascade</div>
          </div>
        </div>
      </section>

      <!-- ═══ CAPABILITIES ═══ -->
      <section class="capabilities">
        <div class="cap-grid">
          <div class="cap-card">
            <div class="cap-number">54</div>
            <div class="cap-label">Data arrays</div>
            <div class="cap-detail">Across 13 scopes covering Gulf states, Iran military operations, US/Israel coalition, casualties, and market instruments</div>
          </div>
          <div class="cap-card">
            <div class="cap-number">3&times;</div>
            <div class="cap-label">Daily updates</div>
            <div class="cap-detail">AI-powered ingest pipeline scans, extracts, verifies, and publishes intelligence with 7-layer anti-hallucination safeguards</div>
          </div>
          <div class="cap-card">
            <div class="cap-number">&lt;30s</div>
            <div class="cap-label">Event to dashboard</div>
            <div class="cap-detail">From git push to global CDN deployment on Cloudflare's edge network across 300+ locations</div>
          </div>
          <div class="cap-card">
            <div class="cap-number">7</div>
            <div class="cap-label">Defense layers</div>
            <div class="cap-detail">Conflict phase registry, phase-aware prompts, per-scope tracking, WARN gating, backfill chunking, anomaly detection, memory injection</div>
          </div>
        </div>
      </section>

      <!-- ═══ JCJ POSITIONING ═══ -->
      <section class="positioning">
        <div class="pos-inner">
          <div class="pos-badge">JCJ Investing</div>
          <h2 class="pos-title">Built by traders,<br/>for traders.</h2>
          <p class="pos-text">
            VegaReady is the intelligence arm of JCJ Investing — a quantitative,
            event-driven trading firm. We built this platform to give ourselves an
            edge in volatile markets. Now we're sharing the methodology.
          </p>
          <p class="pos-text dim">
            Our thesis: geopolitical events create predictable cascade patterns
            across asset classes. By tracking the event, measuring the transmission,
            and quantifying the impact in real time, we position ahead of the market.
          </p>
          <a href="/dashboard" class="btn-primary" style="margin-top: 2rem;">
            <span class="btn-dot"></span>
            Explore the dashboard
          </a>
        </div>
      </section>
    </main>

    <Footer />
  </body>
</html>

<style>
  /* ═══ HERO ═══ */
  .hero {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 5rem 2rem 4rem;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: center;
  }
  .hero-definition {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 1.5rem;
  }
  .def-label {
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--cyan);
    letter-spacing: 2px;
    text-transform: uppercase;
    padding: 4px 12px;
    border: 1px solid rgba(34, 211, 238, 0.3);
    border-radius: 4px;
  }
  .def-greek {
    font-family: var(--font-display);
    font-size: 24px;
    color: var(--text-dim);
    font-style: italic;
  }
  .hero-title {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 5vw, 3.5rem);
    font-weight: 400;
    line-height: 1.1;
    color: var(--text);
    margin-bottom: 1.5rem;
  }
  .hero-accent {
    color: var(--cyan);
    font-style: italic;
  }
  .hero-sub {
    font-size: 15px;
    color: var(--text-muted);
    line-height: 1.7;
    max-width: 460px;
    margin-bottom: 1.5rem;
  }
  .hero-tagline {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 18px;
    color: var(--text);
    margin-bottom: 2rem;
    padding-left: 16px;
    border-left: 2px solid var(--cyan);
  }
  .hero-actions {
    display: flex;
    gap: 12px;
    align-items: center;
  }

  /* Buttons */
  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-mono);
    font-size: 13px;
    font-weight: 600;
    color: var(--bg);
    background: var(--cyan);
    padding: 10px 22px;
    border-radius: 6px;
    transition: all 0.2s;
  }
  .btn-primary:hover { opacity: 0.9; transform: translateY(-1px); }
  .btn-dot {
    width: 6px; height: 6px;
    background: var(--bg);
    border-radius: 50%;
    opacity: 0.6;
  }
  .btn-ghost {
    font-family: var(--font-mono);
    font-size: 13px;
    font-weight: 500;
    color: var(--text-muted);
    padding: 10px 18px;
    border: 1px solid var(--border);
    border-radius: 6px;
    transition: all 0.2s;
  }
  .btn-ghost:hover { color: var(--text); border-color: var(--border-light); opacity: 1; }

  /* Terminal card */
  .terminal-card {
    background: var(--bg-surface);
    border: 1px solid var(--border);
    border-radius: 10px;
    overflow: hidden;
    box-shadow: 0 8px 32px rgba(0,0,0,0.4);
  }
  .terminal-bar {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 10px 14px;
    background: var(--bg-card);
    border-bottom: 1px solid var(--border);
  }
  .terminal-dot {
    width: 10px; height: 10px;
    border-radius: 50%;
  }
  .terminal-dot.red { background: #ef4444; }
  .terminal-dot.amber { background: #f59e0b; }
  .terminal-dot.green { background: #22c55e; }
  .terminal-title {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--text-dim);
    margin-left: 8px;
  }
  .terminal-body { padding: 16px 18px; }
  .term-line {
    font-family: var(--font-mono);
    font-size: 12px;
    line-height: 2;
    display: flex;
    gap: 6px;
  }
  .term-line.dim { opacity: 0.6; }
  .term-line.highlight .term-val { color: var(--cyan); font-weight: 600; }
  .term-key {
    color: var(--text-dim);
    min-width: 70px;
    text-align: right;
  }
  .term-colon { color: var(--border-light); }
  .term-val { color: var(--text-muted); }
  .term-divider {
    height: 1px;
    background: var(--border);
    margin: 8px 0;
  }

  /* ═══ CASCADE ═══ */
  .cascade {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 5rem 2rem;
    text-align: center;
  }
  .cascade-label {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--cyan);
    letter-spacing: 3px;
    text-transform: uppercase;
    margin-bottom: 12px;
  }
  .section-title {
    font-family: var(--font-display);
    font-size: clamp(1.8rem, 3.5vw, 2.4rem);
    font-weight: 400;
    color: var(--text);
    margin-bottom: 10px;
  }
  .section-sub {
    font-size: 15px;
    color: var(--text-muted);
    max-width: 520px;
    margin: 0 auto 3rem;
  }
  .cascade-flow {
    display: flex;
    align-items: flex-start;
    justify-content: center;
    gap: 0;
    padding: 0 1rem;
  }
  .cascade-node {
    flex: 0 0 160px;
    text-align: center;
    padding: 20px 12px;
    border-radius: 10px;
    border: 1px solid var(--border);
    background: var(--bg-surface);
    transition: all 0.3s;
  }
  .cascade-node:hover {
    border-color: var(--border-light);
    transform: translateY(-4px);
    box-shadow: 0 8px 24px rgba(0,0,0,0.3);
  }
  .cascade-node.event { border-color: rgba(239, 68, 68, 0.3); }
  .cascade-node.event .node-icon { color: var(--red); }
  .cascade-node.oil { border-color: rgba(245, 158, 11, 0.3); }
  .cascade-node.oil .node-icon { color: var(--amber); }
  .cascade-node.shipping { border-color: rgba(59, 130, 246, 0.3); }
  .cascade-node.shipping .node-icon { color: var(--blue); }
  .cascade-node.markets { border-color: rgba(99, 102, 241, 0.3); }
  .cascade-node.markets .node-icon { color: var(--indigo); }
  .cascade-node.alpha { border-color: rgba(34, 211, 238, 0.3); background: rgba(34, 211, 238, 0.05); }
  .cascade-node.alpha .node-icon { color: var(--cyan); }
  .node-icon {
    font-family: var(--font-mono);
    font-size: 20px;
    font-weight: 800;
    margin-bottom: 8px;
  }
  .node-label {
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: 700;
    color: var(--text);
    margin-bottom: 6px;
    letter-spacing: 0.3px;
  }
  .node-detail {
    font-size: 11px;
    color: var(--text-dim);
    line-height: 1.4;
  }
  .cascade-arrow {
    flex: 0 0 32px;
    height: 2px;
    background: linear-gradient(90deg, var(--border-light), var(--text-dim));
    align-self: center;
    margin-top: -20px;
    position: relative;
  }
  .cascade-arrow::after {
    content: '';
    position: absolute;
    right: -1px;
    top: -3px;
    border: 4px solid transparent;
    border-left: 6px solid var(--text-dim);
  }

  /* ═══ CAPABILITIES ═══ */
  .capabilities {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 2rem 2rem 4rem;
  }
  .cap-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 12px;
  }
  .cap-card {
    background: var(--bg-surface);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 24px 20px;
    transition: all 0.3s;
  }
  .cap-card:hover {
    border-color: var(--border-light);
    transform: translateY(-2px);
  }
  .cap-number {
    font-family: var(--font-mono);
    font-size: 28px;
    font-weight: 800;
    color: var(--cyan);
    line-height: 1;
    margin-bottom: 4px;
  }
  .cap-label {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 700;
    color: var(--text);
    text-transform: uppercase;
    letter-spacing: 1.5px;
    margin-bottom: 10px;
  }
  .cap-detail {
    font-size: 12px;
    color: var(--text-dim);
    line-height: 1.5;
  }

  /* ═══ POSITIONING ═══ */
  .positioning {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 4rem 2rem;
  }
  .pos-inner {
    background: var(--bg-surface);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 3rem;
    max-width: 640px;
  }
  .pos-badge {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 700;
    color: var(--cyan);
    letter-spacing: 2px;
    text-transform: uppercase;
    margin-bottom: 16px;
  }
  .pos-title {
    font-family: var(--font-display);
    font-size: 2rem;
    font-weight: 400;
    color: var(--text);
    line-height: 1.2;
    margin-bottom: 1.5rem;
  }
  .pos-text {
    font-size: 15px;
    color: var(--text-muted);
    line-height: 1.7;
    margin-bottom: 1rem;
  }
  .pos-text.dim { color: var(--text-dim); }

  /* ═══ RESPONSIVE ═══ */
  @media (max-width: 900px) {
    .hero {
      grid-template-columns: 1fr;
      padding: 3rem 1.5rem 2rem;
    }
    .cascade-flow {
      flex-direction: column;
      align-items: center;
    }
    .cascade-arrow {
      width: 2px;
      height: 24px;
      margin-top: 0;
      flex: 0 0 24px;
    }
    .cascade-arrow::after {
      right: -3px;
      top: auto;
      bottom: -1px;
      border: 4px solid transparent;
      border-top: 6px solid var(--text-dim);
      border-left: 4px solid transparent;
    }
    .cascade-node { flex: 0 0 auto; width: 200px; }
    .cap-grid { grid-template-columns: 1fr 1fr; }
    .pos-inner { padding: 2rem; }
  }
  @media (max-width: 520px) {
    .cap-grid { grid-template-columns: 1fr; }
  }
</style>
