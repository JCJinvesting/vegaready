---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description: string;
  tab: string;
}

const { title, description, tab } = Astro.props;

const dashboardTabs = [
  { slug: '', label: 'War Room', short: 'War Room' },
  { slug: 'gulf', label: 'Gulf Countries', short: 'Gulf' },
  { slug: 'economics', label: 'Economics', short: 'Econ' },
  { slug: 'markets', label: 'Markets', short: 'Mkts' },
  { slug: 'casualties', label: 'Casualties', short: 'Cas' },
  { slug: 'iran', label: 'Iran', short: 'Iran' },
  { slug: 'us', label: 'US Operations', short: 'US' },
  { slug: 'israel', label: 'Israel', short: 'Israel' },
  { slug: 'analytics', label: 'Analytics', short: 'Analytics' },
  { slug: 'sources', label: 'Sources', short: 'Sources' },
];
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={title} description={description} />
  </head>
  <body>
    <Header />

    <!-- Dashboard sub-navigation -->
    <nav class="dash-nav">
      <div class="dash-nav-inner">
        <div class="dash-nav-label">Dashboard</div>
        <div class="dash-nav-tabs">
          {dashboardTabs.map(t => (
            <a
              href={t.slug ? `/dashboard/${t.slug}` : '/dashboard'}
              class:list={['dash-tab', { active: tab === t.label }]}
            >
              {t.label}
            </a>
          ))}
        </div>
      </div>
    </nav>

    <!-- Data freshness / QC status — fed by public/data-status.json (written by publish-from-iwt.cjs) -->
    <div class="dash-status-bar"><span id="dashStatus" class="dash-status" aria-live="polite"></span></div>
    <script is:inline>
      (async function () {
        var el = document.getElementById('dashStatus');
        if (!el) return;
        try {
          var r = await fetch('/data-status.json', { cache: 'no-store' });
          if (!r.ok) return;
          var s = await r.json();
          var when = s.dataDate || (s.metrics && s.metrics.newest) || (s.baseline && s.baseline.newest) || '';
          if (s.state === 'ok') {
            el.textContent = '● Data current as of ' + (when || '—') + (s.day ? ' · day ' + s.day : '') + (s.pushPending ? ' · sync pending' : '');
            el.className = 'dash-status' + (s.pushPending ? ' warn' : '');
          } else if (s.state === 'blocked' || s.state === 'error') {
            el.textContent = '⚠ Latest refresh blocked — showing last good data' + (when ? ' (' + when + ')' : '');
            el.className = 'dash-status warn';
            if (s.failures && s.failures.length) el.title = s.failures.join(' · ');
          }
        } catch (e) {}
      })();
    </script>

    <!-- SEO content slot — each page provides static HTML context -->
    <div class="dash-seo">
      <slot name="seo" />
    </div>

    <!-- React island mounts here -->
    <div class="dash-app">
      <slot />
    </div>

    <Footer />
  </body>
</html>

<style>
  .dash-nav {
    background: var(--bg-surface);
    border-bottom: 1px solid var(--border);
    overflow-x: auto;
  }
  .dash-nav-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 2rem;
    display: flex;
    align-items: center;
    gap: 20px;
    height: 44px;
  }
  .dash-nav-label {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 700;
    color: var(--text-dim);
    text-transform: uppercase;
    letter-spacing: 1.5px;
    flex-shrink: 0;
  }
  .dash-nav-tabs {
    display: flex;
    gap: 2px;
    overflow-x: auto;
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
  .dash-nav-tabs::-webkit-scrollbar { display: none; }
  .dash-tab {
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: 500;
    color: var(--text-muted);
    padding: 6px 12px;
    border-radius: 5px;
    white-space: nowrap;
    transition: all 0.15s;
    text-decoration: none;
  }
  .dash-tab:hover {
    color: var(--text);
    background: rgba(255,255,255,0.05);
    opacity: 1;
  }
  .dash-tab.active {
    color: var(--cyan);
    background: var(--cyan-muted);
    font-weight: 700;
  }
  .dash-seo {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 1.5rem 2rem 0;
  }
  .dash-app {
    max-width: 100%;
    min-height: 60vh;
  }
  .dash-status-bar {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 6px 2rem 0;
  }
  .dash-status {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--text-dim);
    letter-spacing: 0.3px;
  }
  .dash-status.warn { color: #E0A030; font-weight: 700; }
  @media (max-width: 720px) {
    .dash-nav-inner { padding: 0 1rem; gap: 12px; }
    .dash-seo { padding: 1rem 1rem 0; }
    .dash-status-bar { padding: 6px 1rem 0; }
  }
</style>
