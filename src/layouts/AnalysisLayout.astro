---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { freshness } from '../data/analysis/freshness.js';

interface Props {
  title: string;
  description: string;
  section?: string;
  area?: string; // 'markets' | 'transmission' | 'exposure' | 'outlook'
}

const { title, description, section, area = 'markets' } = Astro.props;

const navByArea: Record<string, {slug:string, label:string, base:string}[]> = {
  markets: [
    { slug: '', label: 'Overview', base: '/markets' },
    { slug: 'gold-fx', label: 'Gold & FX', base: '/markets' },
    { slug: 'energy', label: 'Energy', base: '/markets' },
    { slug: 'crypto', label: 'Crypto', base: '/markets' },
    { slug: 'credit', label: 'Credit', base: '/markets' },
  ],
  transmission: [
    { slug: '', label: 'Sector Cascade', base: '/transmission' },
  ],
  exposure: [
    { slug: '', label: 'Regional Impact', base: '/exposure' },
  ],
  outlook: [
    { slug: '', label: 'Gap Dynamics', base: '/outlook' },
    { slug: 'precedents', label: 'Precedents', base: '/outlook' },
    { slug: 'infrastructure', label: 'Infrastructure', base: '/outlook' },
  ],
  connections: [
    { slug: '', label: 'Connections', base: '/connections' },
  ],
  profits: [
    { slug: '', label: 'Who Profits', base: '/profits' },
  ],
};

const areaLabels: Record<string, string> = {
  markets: 'Markets',
  transmission: 'Transmission',
  exposure: 'Exposure',
  outlook: 'Outlook',
  connections: 'Connections',
  profits: 'Who Profits',
};

const nav = navByArea[area] || navByArea.markets;
const areaLabel = areaLabels[area] || 'Markets';
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={title} description={description} />
  </head>
  <body>
    <Header />

    <nav class="sc-nav">
      <div class="sc-nav-inner">
        <div class="sc-nav-label">{areaLabel}</div>
        <div class="sc-nav-tabs">
          {nav.map(t => (
            <a
              href={t.slug ? `${t.base}/${t.slug}` : t.base}
              class:list={['sc-tab', { active: section === t.label }]}
            >
              {t.label}
            </a>
          ))}
        </div>
      </div>
    </nav>

    <div class="fresh">
      <div class="fresh-inner">
        <span class="fresh-asof"><span class="freshdot"></span>Live &middot; as of {freshness.asOf}</span>
        <div class="freshrow">{freshness.scenarios.map(s => (<span class:list={["freshchip", s.tone]}>{s.label}: <b>{s.status}</b></span>))}</div>
        <div class="freshrow freshanch">{freshness.anchors.map(a => (<span class="freshanchor" title={a.note}>{a.k} <b>{a.v}</b></span>))}</div>
      </div>
    </div>

    <main class="sc-main">
      <slot />
    </main>

    <Footer />
  </body>
</html>

<style>
  .sc-nav {
    background: var(--bg-surface);
    border-bottom: 1px solid var(--border);
    overflow-x: auto;
  }
  .sc-nav-inner {
    max-width: 1080px;
    margin: 0 auto;
    padding: 0 2rem;
    display: flex;
    align-items: center;
    gap: 20px;
    height: 44px;
  }
  .sc-nav-label {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 700;
    color: var(--text-dim);
    text-transform: uppercase;
    letter-spacing: 1.5px;
    flex-shrink: 0;
  }
  .sc-nav-tabs {
    display: flex;
    gap: 2px;
    overflow-x: auto;
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
  .sc-nav-tabs::-webkit-scrollbar { display: none; }
  .sc-tab {
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: 500;
    color: var(--text-muted);
    padding: 6px 12px;
    border-radius: 5px;
    white-space: nowrap;
    transition: all 0.15s;
    text-decoration: none;
  }
  .sc-tab:hover {
    color: var(--text);
    background: rgba(255,255,255,0.05);
    opacity: 1;
  }
  .sc-tab.active {
    color: var(--cyan);
    background: var(--cyan-muted);
    font-weight: 700;
  }
  .sc-main {
    max-width: 1080px;
    margin: 0 auto;
    padding: 3rem 2rem;
  }
  @media (max-width: 720px) {
    .sc-nav-inner { padding: 0 1rem; gap: 12px; }
    .sc-main { padding: 2rem 1rem; }
  }
  .fresh{background:var(--bg-card,#0d1117);border-bottom:1px solid var(--border)}
  .fresh-inner{max-width:1080px;margin:0 auto;padding:8px 2rem;display:flex;align-items:center;gap:16px;flex-wrap:wrap;font-family:var(--font-mono)}
  .fresh-asof{font-size:10px;font-weight:700;letter-spacing:1px;text-transform:uppercase;color:var(--cyan,#22d3ee);display:flex;align-items:center;gap:6px;flex-shrink:0}
  .freshdot{width:7px;height:7px;border-radius:50%;background:var(--cyan,#22d3ee);animation:freshpulse 2s infinite}
  @keyframes freshpulse{0%{box-shadow:0 0 0 0 rgba(34,211,238,.5)}70%{box-shadow:0 0 0 6px rgba(34,211,238,0)}100%{box-shadow:0 0 0 0 rgba(34,211,238,0)}}
  .freshrow{display:flex;gap:6px;flex-wrap:wrap}
  .freshchip{font-size:10px;padding:2px 8px;border-radius:4px;border:1px solid;white-space:nowrap}
  .freshchip.red{color:#ef4444;border-color:rgba(239,68,68,.3);background:rgba(239,68,68,.08)}
  .freshchip.amber{color:#f59e0b;border-color:rgba(245,158,11,.3);background:rgba(245,158,11,.08)}
  .freshchip.green{color:#10b981;border-color:rgba(16,185,129,.3);background:rgba(16,185,129,.08)}
  .freshanchor{font-size:10px;color:var(--text-dim);white-space:nowrap;cursor:help}
  .freshanchor b{color:var(--text);font-weight:700}
  @media(max-width:720px){.freshanch{display:none}}
</style>>
